+import pytest
+from types import SimpleNamespace
+
+from apps.api.app.models.tenant import Business
+from apps.api.app.models.identity import User, Membership, MembershipStatus
+
+
+@pytest.mark.asyncio
+async def test_get_my_businesses_requires_auth(client):
+    # Clear auth overrides to simulate unauthenticated request
+    from apps.api.app.core.auth_deps import get_current_user as _auth_get_current_user
+    from apps.api.app.core.security import get_current_user as _sec_get_current_user
+    from apps.api.app.main import app
+    app.dependency_overrides.pop(_auth_get_current_user, None)
+    app.dependency_overrides.pop(_sec_get_current_user, None)
+
+    res = await client.get("/api/v1/me/businesses")
+    assert res.status_code == 401 or res.status_code == 403
+
+
+@pytest.mark.asyncio
+async def test_get_my_businesses_returns_list(client):
+    # Register a user and create a business via public endpoints so membership is created
+    # Clear test auth overrides so real token-based auth is used
+    from apps.api.app.core.auth_deps import get_current_user as _auth_get_current_user
+    from apps.api.app.core.security import get_current_user as _sec_get_current_user
+    from apps.api.app.main import app
+    app.dependency_overrides.pop(_auth_get_current_user, None)
+    app.dependency_overrides.pop(_sec_get_current_user, None)
+
+    payload = {"email": "me@example.com", "password": "Password123!"}
+    res = await client.post("/api/v1/auth/register", json=payload)
+    assert res.status_code == 201
+
+    # Login to obtain token
+    res = await client.post("/api/v1/auth/login", json={"email": "me@example.com", "password": "Password123!"})
+    assert res.status_code == 200
+    token = res.json()["access_token"]
+    headers = {"Authorization": f"Bearer {token}"}
+
+    # Register a business as the new user (creates membership)
+    biz_payload = {"business_name": "Acme Co", "business_email": "biz@example.com"}
+    res = await client.post("/api/v1/businesses/register", json=biz_payload, headers=headers)
+    assert res.status_code == 201
+
+    # Call the business selector endpoint
+    res = await client.get("/api/v1/me/businesses", headers=headers)
+    assert res.status_code == 200
+    data = res.json()
+    assert isinstance(data, list)
+    assert len(data) >= 1
+    first = data[0]
+    assert "id" in first and "name" in first and "is_default" in first
