+async def my_businesses(user=Depends(get_current_user), session: AsyncSession = Depends(get_async_session)):
+    businesses = {}
+
+    # Try membership-based lookup first (if memberships table exists)
+    try:
+        stmt = select(Business, Membership).join(Membership, Business.id == Membership.business_id).where(
+            Membership.user_id == user.id,
+            Membership.status == MembershipStatus.active,
+        )
+        result = await session.execute(stmt)
+        for biz, mem in result.all():
+            businesses[str(biz.id)] = {"id": str(biz.id), "name": biz.name, "is_default": False}
+    except OperationalError:
+        # memberships table may not be present in all deployments; ignore
+        pass
+
+    # Also include businesses from user role assignments (registration path uses this)
+    try:
+        stmt2 = select(Business, UserRoleAssignment).join(UserRoleAssignment, Business.id == UserRoleAssignment.business_id).where(
+            UserRoleAssignment.user_id == user.id,
+        )
+        result2 = await session.execute(stmt2)
+        for biz, ura in result2.all():
+            businesses[str(biz.id)] = {"id": str(biz.id), "name": biz.name, "is_default": False}
+    except OperationalError:
+        pass
+
+    return list(businesses.values())
