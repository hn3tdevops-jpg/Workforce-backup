<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cloud Workforce</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<style>
  :root{--sidebar-w:240px;--accent:#6366f1;--accent-dark:#4f46e5}
  body{background:#f1f5f9;font-family:'Segoe UI',system-ui,sans-serif}
  #sidebar{width:var(--sidebar-w);min-height:100vh;background:#1e1b4b;position:fixed;top:0;left:0;z-index:100;display:flex;flex-direction:column}
  .brand{padding:20px 18px 12px;color:#fff;font-size:1.05rem;font-weight:700;border-bottom:1px solid rgba(255,255,255,.1)}
  .brand small{display:block;font-size:.7rem;font-weight:400;color:#a5b4fc;margin-top:2px}
  .nav-section{font-size:.65rem;color:#818cf8;text-transform:uppercase;letter-spacing:1px;padding:14px 18px 4px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none}
  .nav-section:hover{color:#c7d2fe}
  .nav-section .chev{font-size:.75rem;transition:transform .2s;color:#818cf8}
  .nav-section.collapsed .chev{transform:rotate(-90deg)}
  .nav-section-links{overflow:hidden;transition:max-height .25s ease}
  .nav-section-links.collapsed{max-height:0!important}
  .nav-link{color:#c7d2fe;padding:8px 18px;font-size:.875rem;display:flex;align-items:center;gap:10px;transition:.15s}
  .nav-link:hover,.nav-link.active{background:rgba(255,255,255,.1);color:#fff}
  .nav-link i{width:18px;text-align:center;font-size:1rem}
  .nav-sub-link{padding-left:36px!important;font-size:.82rem!important;border-left:2px solid rgba(99,102,241,.35);margin-left:18px;width:calc(100% - 18px)}
  .user-area{margin-top:auto;padding:14px 18px;border-top:1px solid rgba(255,255,255,.1);font-size:.8rem;color:#a5b4fc}
  #main{margin-left:var(--sidebar-w);min-height:100vh}
  #topbar{background:#fff;border-bottom:1px solid #e2e8f0;padding:12px 28px;display:flex;align-items:center;gap:12px}
  #topbar h5{margin:0;font-size:1rem;font-weight:600;color:#1e293b}
  .view{display:none;padding:28px}
  .view.active{display:block}
  .card{border:none;box-shadow:0 1px 3px rgba(0,0,0,.08);border-radius:12px}
  .card-header{background:#fff;border-bottom:1px solid #f1f5f9;font-weight:600;font-size:.9rem;padding:14px 20px}
  .stat-card{border-radius:12px;padding:22px;color:#fff}
  .stat-card .num{font-size:2rem;font-weight:700}
  .stat-card .lbl{font-size:.8rem;opacity:.85}
  .btn-accent{background:var(--accent);border-color:var(--accent);color:#fff}
  .btn-accent:hover{background:var(--accent-dark);border-color:var(--accent-dark);color:#fff}
  .table{font-size:.875rem}
  .table th{font-weight:600;color:#64748b;text-transform:uppercase;font-size:.72rem;letter-spacing:.5px}
  #auth-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1e1b4b,#312e81)}
  .auth-box{width:420px}
  .toast-container{position:fixed;bottom:20px;right:20px;z-index:9999}
  .key-reveal{background:#0f172a;color:#86efac;font-family:monospace;font-size:.8rem;padding:12px;border-radius:8px;word-break:break-all}
  #biz-selector{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;border-radius:6px;font-size:.8rem;padding:4px 8px;width:calc(100% - 36px);margin:0 18px 10px}
  #biz-selector option{background:#1e1b4b}
  .empty-state{text-align:center;padding:40px;color:#94a3b8}
  .empty-state i{font-size:2.5rem;display:block;margin-bottom:10px}
  .perm-badge{font-size:.7rem;padding:2px 8px;border-radius:10px;margin:2px;display:inline-block;background:rgba(99,102,241,.25);color:#a5b4fc;border:1px solid rgba(99,102,241,.4)}
  .role-owner{background:#fef9c3;color:#713f12}
  .role-worker{background:#dcfce7;color:#14532d}
  .role-admin{background:#fce7f3;color:#831843}
  .no-access{text-align:center;padding:60px 20px;color:#94a3b8}
  .no-access i{font-size:3rem;display:block;margin-bottom:16px;color:#cbd5e1}
  .demo-card{background:linear-gradient(135deg,#1e1b4b,#4338ca);color:#fff;border-radius:12px;padding:20px;margin-bottom:24px}

  /* ── Schedule Calendar ── */
  .cal-grid{display:grid;grid-template-columns:52px repeat(7,1fr);border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;background:#fff;font-size:.78rem}
  .cal-header{background:#f8fafc;font-weight:600;text-align:center;padding:10px 4px;border-bottom:2px solid #e2e8f0;position:sticky;top:0;z-index:5}
  .cal-header.today{background:#ede9fe;color:#4f46e5}
  .cal-time-col{border-right:1px solid #e2e8f0}
  .cal-time-label{height:60px;display:flex;align-items:flex-start;justify-content:flex-end;padding:4px 6px 0 0;color:#94a3b8;font-size:.7rem;border-bottom:1px solid #f1f5f9}
  .cal-day-col{border-right:1px solid #e2e8f0;position:relative;min-height:900px}
  .cal-day-col:last-child{border-right:none}
  .cal-hour-row{height:60px;border-bottom:1px solid #f1f5f9;cursor:pointer}
  .cal-hour-row:hover{background:#f8fafc}
  .cal-half{height:30px;border-bottom:1px dashed #f1f5f9}
  .shift-block{position:absolute;left:2px;right:2px;border-radius:6px;padding:4px 6px;cursor:pointer;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.15);transition:.1s;z-index:2;border-left:3px solid rgba(0,0,0,.2)}
  .shift-block:hover{transform:translateY(-1px);box-shadow:0 3px 8px rgba(0,0,0,.2);z-index:3}
  .shift-block .sb-title{font-weight:600;font-size:.75rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .shift-block .sb-time{font-size:.68rem;opacity:.85}
  .shift-block .sb-people{font-size:.68rem;margin-top:2px;opacity:.9}
  .shift-block.status-draft{background:#e0e7ff;color:#3730a3;border-left-color:#6366f1}
  .shift-block.status-published{background:#d1fae5;color:#065f46;border-left-color:#10b981}
  .shift-block.status-cancelled{background:#fee2e2;color:#991b1b;border-left-color:#ef4444;opacity:.6}
  .cal-now-line{position:absolute;left:0;right:0;height:2px;background:#ef4444;z-index:4;pointer-events:none}
  .cal-now-line::before{content:'';position:absolute;left:-4px;top:-4px;width:10px;height:10px;border-radius:50%;background:#ef4444}
  /* Timeclock widget */
  .tc-widget #tcw-time-0,
  [id^="tcw-time-"]{font-feature-settings:"tnum";transition:color .4s}
  .tc-widget .btn{border-radius:8px;padding:.55rem 1rem;font-size:.9rem}
  .tc-widget input.form-control{background:rgba(255,255,255,.07)!important;border-color:rgba(255,255,255,.15)!important;border-radius:8px}
  .tc-widget input.form-control::placeholder{color:#64748b}
  .tc-widget input.form-control:focus{background:rgba(255,255,255,.12)!important;border-color:#6366f1!important;box-shadow:0 0 0 .2rem rgba(99,102,241,.25)}
  /* Messaging FAB */
  #msg-fab{position:fixed;bottom:28px;right:28px;z-index:1040;width:54px;height:54px;border-radius:50%;background:#6366f1;color:#fff;border:none;box-shadow:0 4px 18px rgba(99,102,241,.5);font-size:1.4rem;cursor:pointer;display:none;align-items:center;justify-content:center;transition:transform .2s,box-shadow .2s}
  #msg-fab:hover{transform:scale(1.08);box-shadow:0 6px 24px rgba(99,102,241,.65)}
  #msg-fab-badge{position:absolute;top:-5px;right:-5px;background:#ef4444;color:#fff;font-size:.65rem;font-weight:700;min-width:20px;height:20px;border-radius:10px;padding:0 4px;display:none;align-items:center;justify-content:center;line-height:1;border:2px solid #fff}
  /* Messaging slide-over panel */
  #msg-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1045;display:none;animation:fadeIn .2s}
  #msg-panel{position:fixed;top:0;right:-660px;width:640px;max-width:100vw;height:100vh;background:#1e1b4b;z-index:1050;display:flex;flex-direction:column;transition:right .3s cubic-bezier(.4,0,.2,1);box-shadow:-6px 0 40px rgba(0,0,0,.35)}
  #msg-panel.open{right:0}
  @media(max-width:680px){ #msg-panel{width:100vw} }
  @keyframes fadeIn{ from{ opacity:0 } to{ opacity:1 } }
  @keyframes pulse{ 0%,100%{ box-shadow:0 4px 18px rgba(99,102,241,.5) } 50%{ box-shadow:0 0 0 8px rgba(239,68,68,.3),0 4px 18px rgba(99,102,241,.5) } }
  /* Messaging widget */
  .msg-widget-ch{padding:8px 10px;border-radius:8px;cursor:pointer;transition:.15s;border-bottom:1px solid rgba(255,255,255,.06)}
  .msg-widget-ch:hover{background:rgba(255,255,255,.08)}
  .msg-widget-ch.has-unread{background:rgba(99,102,241,.15)}
</style>
</head>
<body>

<!-- AUTH -->
<div id="auth-screen">
  <div class="auth-box">
    <div class="text-center mb-4">
      <div style="font-size:2.2rem;color:#818cf8"><i class="bi bi-people-fill"></i></div>
      <h4 class="text-white fw-bold mt-2">Cloud Workforce</h4>
      <p style="color:#a5b4fc;font-size:.85rem">Multi-tenant workforce platform</p>
    </div>
    <div class="card shadow-lg">
      <div class="card-body p-4">
        <ul class="nav nav-tabs mb-4" id="authTabs">
          <li class="nav-item"><a class="nav-link active" href="#" data-tab="login">Sign In</a></li>
          <li class="nav-item"><a class="nav-link" href="#" data-tab="register">Register</a></li>
        </ul>
        <div id="tab-login">
          <div class="mb-3"><label class="form-label small fw-semibold">Email</label><input type="email" class="form-control" id="login-email" placeholder="you@example.com"></div>
          <div class="mb-3"><label class="form-label small fw-semibold">Password</label><input type="password" class="form-control" id="login-password"></div>
          <button class="btn btn-accent w-100 mb-3" onclick="doLogin()"><i class="bi bi-box-arrow-in-right me-2"></i>Sign In</button>
          <div id="login-err" class="text-danger small"></div>
          <script>
            document.getElementById('login-err').textContent='TINY-v3';
            document.addEventListener('DOMContentLoaded', function() {
              var btn = document.querySelector('.btn-accent[onclick="doLogin()"]');
              if (btn) btn.addEventListener('click', function() {
                var el = document.getElementById('login-err');
                if (el) el.textContent = 'ms=' + window._mainScript + ' doLogin=' + (typeof window.doLogin) + ' onerror=' + (typeof window.onerror);
              });
            });
          </script>
          <hr class="my-3">
          <p class="text-muted small mb-2 fw-semibold">Demo accounts:</p>
          <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-sm btn-outline-secondary" onclick="fillLogin('demo-owner@workforce.app','DemoOwner2026!')"><i class="bi bi-person-badge me-1"></i>Business Owner</button>
            <button class="btn btn-sm btn-outline-secondary" onclick="fillLogin('demo-worker@workforce.app','DemoWorker2026!')"><i class="bi bi-person me-1"></i>Worker</button>
          </div>
        </div>
        <div id="tab-register" style="display:none">
          <div class="mb-3"><label class="form-label small fw-semibold">Email</label><input type="email" class="form-control" id="reg-email"></div>
          <div class="mb-3"><label class="form-label small fw-semibold">Password</label><input type="password" class="form-control" id="reg-password"></div>
          <div class="mb-4 form-check"><input type="checkbox" class="form-check-input" id="reg-superadmin"><label class="form-check-label small" for="reg-superadmin">Superadmin account</label></div>
          <button class="btn btn-accent w-100" onclick="doRegister()"><i class="bi bi-person-plus me-2"></i>Create Account</button>
          <div id="reg-err" class="text-danger small mt-2"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- APP -->
<div id="app-shell" style="display:none">
  <div id="sidebar">
    <div class="brand">
      <i class="bi bi-people-fill me-2" style="color:#818cf8"></i>Cloud Workforce
      <small id="user-role-label">—</small>
    </div>

    <div id="biz-wrap" style="display:none;padding-top:10px">
      <select id="biz-selector" onchange="selectBusiness(this.value)">
        <option value="">— Select Business —</option>
      </select>
    </div>

    <!-- Superadmin only -->
    <div id="nav-control" style="display:none">
      <div class="nav-section" onclick="toggleNavSection(this)">Platform Admin<i class="bi bi-chevron-down chev"></i></div>
      <div class="nav-section-links" style="max-height:500px">
        <a class="nav-link" href="#" onclick="nav('ctrl-panel')"><i class="bi bi-terminal-dash"></i>Control Panel</a>
      </div>
    </div>

    <!-- Shown if user has any tenant perms -->
    <div id="nav-tenant" style="display:none">
      <div class="nav-section" onclick="toggleNavSection(this)">Business<i class="bi bi-chevron-down chev"></i></div>
      <div class="nav-section-links" style="max-height:500px">
        <a class="nav-link" id="nav-members-link" href="#" onclick="nav('tenant-members')" style="display:none"><i class="bi bi-person-badge"></i>Members</a>
        <a class="nav-link" id="nav-schedule-edit-link" href="#" onclick="nav('tenant-schedule')" style="display:none"><i class="bi bi-calendar3"></i>Schedule Editor</a>
        <a class="nav-link nav-sub-link" id="nav-swap-review-link" href="#" onclick="nav('tenant-swap-review')" style="display:none"><i class="bi bi-arrow-left-right"></i>Swap Requests</a>
        <a class="nav-link nav-sub-link" id="nav-swap-rules-link" href="#" onclick="nav('tenant-swap-rules')" style="display:none"><i class="bi bi-sliders"></i>Swap Rules</a>
        <a class="nav-link" id="nav-dashboard-admin-link" href="#" onclick="nav('tenant-dashboard-admin')" style="display:none"><i class="bi bi-layout-wtf"></i>Dashboard Admin</a>
        <a class="nav-link" id="nav-roles-link" href="#" onclick="nav('tenant-roles')" style="display:none"><i class="bi bi-shield-check"></i>Roles</a>
        <a class="nav-link" id="nav-locations-link" href="#" onclick="nav('tenant-locations')" style="display:none"><i class="bi bi-geo-alt"></i>Locations</a>
        <a class="nav-link" id="nav-timesheets-link" href="#" onclick="nav('tenant-timesheets')" style="display:none"><i class="bi bi-clock-history"></i>Timesheets</a>
        <a class="nav-link" id="nav-job-postings-link" href="#" onclick="nav('tenant-job-postings')" style="display:none"><i class="bi bi-briefcase"></i>Job Postings</a>
        <a class="nav-link" id="nav-shift-review-link" href="#" onclick="nav('tenant-shift-review')" style="display:none"><i class="bi bi-card-checklist"></i>Shift Requests</a>
      </div>
    </div>

    <!-- Always shown for authenticated users -->
    <div id="nav-worker">
      <div class="nav-section" onclick="toggleNavSection(this)">My Portal<i class="bi bi-chevron-down chev"></i></div>
      <div class="nav-section-links" style="max-height:500px">
        <a class="nav-link" href="#" onclick="nav('dashboard')"><i class="bi bi-speedometer2"></i>Dashboard</a>
        <a class="nav-link" href="#" onclick="nav('worker-profile')"><i class="bi bi-person-circle"></i>My Profile</a>
        <a class="nav-link" id="nav-worker-hub-link" href="#" onclick="nav('worker-hub')" style="display:none"><i class="bi bi-grid-1x2"></i>My Work</a>
      </div>
    </div>

    <div class="user-area">
      <div id="user-email-disp" class="mb-1 text-truncate fw-semibold" style="color:#e0e7ff"></div>
      <div id="user-perms-summary" class="mb-2" style="font-size:.7rem"></div>
      <a href="#" class="text-danger small" onclick="doLogout()"><i class="bi bi-box-arrow-right me-1"></i>Sign Out</a>
    </div>
  </div>

  <div id="main">
    <div id="topbar">
      <h5 id="page-title">Dashboard</h5>
      <span id="biz-badge" class="badge bg-indigo ms-2" style="background:#6366f1;display:none"></span>
      <div class="ms-auto" id="topbar-actions"></div>
    </div>

    <!-- DASHBOARD -->
    <div class="view active" id="view-dashboard">
      <div id="demo-banner" style="display:none" class="demo-card">
        <div class="d-flex align-items-center gap-3">
          <i class="bi bi-stars fs-2"></i>
          <div>
            <div class="fw-bold">Demo Account</div>
            <div id="demo-banner-text" style="font-size:.85rem;opacity:.85"></div>
          </div>
        </div>
      </div>
      <!-- Widget grid -->
      <div id="dash-toolbar" class="d-flex align-items-center gap-2 mb-3">
        <span class="text-muted small" id="dash-biz-label"></span>
        <div class="ms-auto d-flex gap-2">
          <button class="btn btn-outline-secondary btn-sm" id="dash-customize-btn" onclick="enterDashEditMode()" style="display:none">
            <i class="bi bi-pencil-square me-1"></i>Customize
          </button>
          <button class="btn btn-outline-secondary btn-sm d-none" id="dash-save-btn" onclick="saveDashLayout()">
            <i class="bi bi-floppy me-1"></i>Save Layout
          </button>
          <button class="btn btn-outline-light btn-sm d-none" id="dash-cancel-btn" onclick="cancelDashEdit()">
            Cancel
          </button>
        </div>
      </div>
      <div id="dash-grid" class="row g-3"></div>
      <!-- Edit mode: add widget panel -->
      <div id="dash-add-panel" class="d-none mt-3">
        <div class="card bg-dark border-secondary">
          <div class="card-header text-light">Add Widget</div>
          <div class="card-body">
            <div id="dash-widget-palette" class="row g-2"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTRL: BUSINESSES -->
    <!-- ═══════════════════════════════════════════════════════════════════
         SUPERADMIN CONTROL PANEL (single tabbed view)
    ═══════════════════════════════════════════════════════════════════ -->
    <div class="view" id="view-ctrl-panel">

      <!-- Panel header -->
      <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
          <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;flex-shrink:0">
            <i class="bi bi-terminal-dash"></i>
          </div>
          <div>
            <div class="fw-bold fs-5 mb-0">Platform Control Panel</div>
            <div class="text-muted small">Superadmin access — all tenants &amp; system configuration</div>
          </div>
        </div>
        <!-- Quick stats bar -->
        <div class="d-flex gap-3" id="ctrl-stats-bar">
          <div class="text-center px-3 py-1 rounded" style="background:var(--card-bg);border:1px solid var(--border-color)">
            <div class="fw-bold" id="ctrl-stat-biz">—</div><div class="text-muted" style="font-size:.7rem">BUSINESSES</div>
          </div>
          <div class="text-center px-3 py-1 rounded" style="background:var(--card-bg);border:1px solid var(--border-color)">
            <div class="fw-bold" id="ctrl-stat-users">—</div><div class="text-muted" style="font-size:.7rem">USERS</div>
          </div>
          <div class="text-center px-3 py-1 rounded" style="background:var(--card-bg);border:1px solid var(--border-color)">
            <div class="fw-bold" id="ctrl-stat-agents">—</div><div class="text-muted" style="font-size:.7rem">AGENTS</div>
          </div>
        </div>
      </div>

      <!-- Tab navigation -->
      <ul class="nav nav-tabs mb-4" id="ctrl-panel-tabs" style="border-bottom:2px solid var(--border-color)">
        <li class="nav-item">
          <a class="nav-link active" href="#" id="ctrl-tab-businesses" onclick="ctrlTab('businesses',this);return false">
            <i class="bi bi-building me-2"></i>Businesses
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#" id="ctrl-tab-users" onclick="ctrlTab('users',this);return false">
            <i class="bi bi-people me-2"></i>Users
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#" id="ctrl-tab-agents" onclick="ctrlTab('agents',this);return false">
            <i class="bi bi-robot me-2"></i>Agents
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#" id="ctrl-tab-audit" onclick="ctrlTab('audit',this);return false">
            <i class="bi bi-journal-text me-2"></i>Audit Log
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#" id="ctrl-tab-widgets" onclick="ctrlTab('widgets',this);return false">
            <i class="bi bi-grid-3x3-gap me-2"></i>Widgets
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#" id="ctrl-tab-perms" onclick="ctrlTab('perms',this);return false">
            <i class="bi bi-shield-lock me-2"></i>Permissions
          </a>
        </li>
      </ul>

      <!-- ── Tab: Businesses ─────────────────────────────── -->
      <div id="ctrl-pane-businesses">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="fw-semibold text-muted small text-uppercase" style="letter-spacing:.5px"><i class="bi bi-building me-1"></i>All Registered Businesses</div>
          <button class="btn btn-accent btn-sm" onclick="openModal('modal-new-biz')"><i class="bi bi-plus-lg me-1"></i>New Business</button>
        </div>
        <div class="card"><div class="card-body p-0">
          <div class="table-responsive"><table class="table table-hover mb-0">
            <thead><tr><th>Name</th><th>Plan</th><th>ID</th><th></th></tr></thead>
            <tbody id="biz-table"></tbody>
          </table></div>
        </div></div>
      </div>

      <!-- ── Tab: Users ──────────────────────────────────── -->
      <div id="ctrl-pane-users" style="display:none">
        <div class="fw-semibold text-muted small text-uppercase mb-3" style="letter-spacing:.5px"><i class="bi bi-people me-1"></i>All Platform Users</div>
        <div class="card"><div class="card-body p-0">
          <div class="table-responsive"><table class="table table-hover mb-0">
            <thead><tr><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody id="users-table"></tbody>
          </table></div>
        </div></div>
      </div>

      <!-- ── Tab: Agents ─────────────────────────────────── -->
      <div id="ctrl-pane-agents" style="display:none">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="fw-semibold text-muted small text-uppercase" style="letter-spacing:.5px"><i class="bi bi-robot me-1"></i>Agent Registry</div>
          <button class="btn btn-accent btn-sm" onclick="openModal('modal-new-agent')"><i class="bi bi-plus-lg me-1"></i>New Agent</button>
        </div>
        <div class="card"><div class="card-body p-0">
          <div class="table-responsive"><table class="table table-hover mb-0">
            <thead><tr><th>Name</th><th>Type</th><th>Status</th><th>Business</th><th></th></tr></thead>
            <tbody id="agents-table"></tbody>
          </table></div>
        </div></div>
      </div>

      <!-- ── Tab: Audit Log ──────────────────────────────── -->
      <div id="ctrl-pane-audit" style="display:none">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="fw-semibold text-muted small text-uppercase" style="letter-spacing:.5px"><i class="bi bi-journal-text me-1"></i>Global Audit Log</div>
          <button class="btn btn-outline-secondary btn-sm" onclick="loadAudit()"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</button>
        </div>
        <div class="card"><div class="card-body p-0">
          <div class="table-responsive"><table class="table table-hover mb-0">
            <thead><tr><th>Time</th><th>Actor</th><th>Action</th><th>Entity</th><th>Business</th><th>Correlation</th></tr></thead>
            <tbody id="audit-table"></tbody>
          </table></div>
        </div></div>
      </div>

      <!-- ── Tab: Widget Editor ──────────────────────────── -->
      <div id="ctrl-pane-widgets" style="display:none">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="fw-semibold text-muted small text-uppercase" style="letter-spacing:.5px"><i class="bi bi-grid-3x3-gap me-1"></i>Widget Definitions</div>
          <button class="btn btn-accent btn-sm" onclick="openModal('modal-new-widget')"><i class="bi bi-plus-lg me-1"></i>New Widget</button>
        </div>
        <div class="card"><div class="card-body p-0">
          <div class="table-responsive"><table class="table table-hover mb-0">
            <thead><tr><th>Icon</th><th>Type</th><th>Title</th><th>Description</th><th>Scope</th><th>System</th><th></th></tr></thead>
            <tbody id="widgets-table"></tbody>
          </table></div>
        </div></div>
      </div>

      <!-- ── Tab: Permissions Manager ────────────────────── -->
      <div id="ctrl-pane-perms" style="display:none">
        <div class="d-flex align-items-center gap-2 mb-3">
          <input type="text" id="perms-filter" class="form-control form-control-sm" placeholder="Filter businesses or permissions…" oninput="filterPermsManager()">
          <button class="btn btn-outline-secondary btn-sm" onclick="openModal('modal-add-perm')">
            <i class="bi bi-plus-lg me-1"></i>Add Permission
          </button>
          <button class="btn btn-accent btn-sm" onclick="loadPermissionsManager()"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</button>
        </div>
        <div id="perms-manager-body" class="accordion"></div>
      </div>

    </div><!-- /view-ctrl-panel -->

    <!-- TENANT: MEMBERS -->
    <div class="view" id="view-tenant-members">
      <!-- Filter bar -->
      <div class="card mb-3">
        <div class="card-body py-2">
          <div class="row g-2 align-items-end">
            <div class="col">
              <input class="form-control form-control-sm" id="dir-q" placeholder="Search by email…" oninput="loadMembers()">
            </div>
            <div class="col-auto">
              <select class="form-select form-select-sm" id="dir-status" onchange="loadMembers()">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="invited">Invited</option>
                <option value="inactive">Inactive</option>
                <option value="removed">Removed</option>
              </select>
            </div>
            <div class="col-auto">
              <select class="form-select form-select-sm" id="dir-role" onchange="loadMembers()">
                <option value="">All Roles</option>
              </select>
            </div>
            <div class="col-auto">
              <select class="form-select form-select-sm" id="dir-location" onchange="loadMembers()">
                <option value="">All Locations</option>
              </select>
            </div>
            <div class="col-auto">
              <select class="form-select form-select-sm" id="dir-view" onchange="renderDirectory()">
                <option value="cards">Cards</option>
                <option value="table">Table</option>
              </select>
            </div>
            <div class="col-auto" id="invite-btn-wrap">
              <button class="btn btn-accent btn-sm" onclick="openModal('modal-invite')"><i class="bi bi-person-plus me-1"></i>Invite</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats row -->
      <div class="row g-2 mb-3" id="dir-stats"></div>

      <!-- Directory results -->
      <div id="dir-results"></div>
    </div>

    <!-- TENANT: ROLES -->
    <div class="view" id="view-tenant-roles">
      <div class="d-flex justify-content-end mb-3" id="new-role-btn-wrap">
        <button class="btn btn-accent btn-sm" onclick="openModal('modal-new-role')"><i class="bi bi-plus-lg me-1"></i>New Role</button>
      </div>
      <div class="card mb-4"><div class="card-header">Business Roles & Permissions</div>
        <div class="table-responsive"><table class="table table-hover mb-0">
          <thead><tr><th>Role</th><th>Permissions</th><th>Actions</th></tr></thead>
          <tbody id="roles-table"></tbody></table></div></div>
      <!-- Messaging API Keys (shown with messaging:manage) -->
      <div id="msg-apikey-section" style="display:none">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-key me-2"></i>Messaging API Keys</span>
            <button class="btn btn-sm btn-outline-accent" onclick="msgOpenNewApiKey()"><i class="bi bi-plus-lg me-1"></i>New Key</button>
          </div>
          <div id="msg-apikey-list" class="p-3">
            <div class="text-muted small">Loading…</div>
          </div>
        </div>
      </div>
    </div>

    <!-- TENANT: LOCATIONS -->
    <div class="view" id="view-tenant-locations">
      <div class="d-flex justify-content-end mb-3" id="new-loc-btn-wrap">
        <button class="btn btn-accent btn-sm" onclick="openModal('modal-new-loc')"><i class="bi bi-plus-lg me-1"></i>New Location</button>
      </div>
      <div class="card"><div class="card-header">Locations</div>
        <div class="table-responsive"><table class="table table-hover mb-0">
          <thead><tr><th>Name</th><th>Timezone</th><th>ID</th></tr></thead>
          <tbody id="locations-table"></tbody></table></div></div>
    </div>

    <!-- WORKER: MESSAGES -->
    <div class="view" id="view-worker-messages">
      <div class="card" style="height:calc(100vh - 140px);min-height:400px;overflow:hidden">
        <div class="row g-0" style="height:100%">
          <!-- Sidebar: channel list -->
          <div class="col-lg-3 col-md-4" style="border-right:1px solid #e2e8f0;display:flex;flex-direction:column;background:#f8fafc">
            <div class="p-3 d-flex align-items-center justify-content-between" style="border-bottom:1px solid #e2e8f0">
              <span class="fw-semibold text-dark">Channels</span>
              <div class="d-flex gap-1">
                <button class="btn btn-sm btn-outline-secondary" onclick="msgNewChannel()" id="msg-new-ch-btn" style="display:none" title="New Channel"><i class="bi bi-plus-circle"></i></button>
                <button class="btn btn-sm btn-outline-primary" onclick="msgNewDm()" id="msg-dm-btn" style="display:none" title="New DM"><i class="bi bi-person-plus"></i></button>
              </div>
            </div>
            <div id="msg-channel-list" style="flex:1;overflow-y:auto;padding:.5rem"></div>
          </div>
          <!-- Main: messages panel -->
          <div class="col-lg-9 col-md-8" style="display:flex;flex-direction:column;background:#fff">
            <!-- Channel header -->
            <div id="msg-channel-header" class="p-3 d-flex align-items-center justify-content-between" style="border-bottom:1px solid #e2e8f0;min-height:56px">
              <div>
                <span id="msg-channel-name" class="fw-semibold text-dark">Select a channel</span>
                <span id="msg-channel-type-badge" class="badge ms-2" style="font-size:.65rem"></span>
              </div>
              <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-warning" id="msg-broadcast-btn" onclick="msgBroadcast()" style="display:none" title="Broadcast to all channels">
                  <i class="bi bi-megaphone me-1"></i>Broadcast
                </button>
                <button class="btn btn-sm btn-outline-secondary" id="msg-members-btn" onclick="msgShowMembers()" style="display:none" title="Channel members">
                  <i class="bi bi-people"></i>
                </button>
              </div>
            </div>
            <!-- Message list -->
            <div id="msg-message-list" style="flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.5rem;background:#fafbfc">
              <div class="text-muted text-center small py-5">Select a channel to start messaging</div>
            </div>
            <!-- Input area -->
            <div id="msg-input-area" style="padding:.75rem;border-top:1px solid #e2e8f0;background:#fff;display:none">
              <div class="d-flex gap-2">
                <input type="text" id="msg-input" class="form-control border"
                       placeholder="Type a message… (Enter to send)"
                       onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();msgSend();}">
                <button class="btn btn-primary" onclick="msgSend()" title="Send">
                  <i class="bi bi-send"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- WORKER: SCHEDULE -->
    <!-- WORKER: MY WORK HUB (Schedule · Availability · Job Board · Requests) -->
    <div class="view" id="view-worker-hub">
      <!-- Tab navigation -->
      <ul class="nav nav-tabs mb-4" id="worker-hub-tabs">
        <li class="nav-item" id="hub-li-schedule">
          <a class="nav-link active" href="#" onclick="hubTab('schedule',this);return false">
            <i class="bi bi-calendar-week me-1"></i>My Schedule
          </a>
        </li>
        <li class="nav-item" id="hub-li-availability">
          <a class="nav-link" href="#" onclick="hubTab('availability',this);return false">
            <i class="bi bi-clock me-1"></i>Availability
          </a>
        </li>
        <li class="nav-item" id="hub-li-jobboard">
          <a class="nav-link" href="#" onclick="hubTab('jobboard',this);return false">
            <i class="bi bi-search me-1"></i>Job Board
          </a>
        </li>
        <li class="nav-item" id="hub-li-requests">
          <a class="nav-link" href="#" onclick="hubTab('requests',this);return false">
            <i class="bi bi-inbox me-1"></i>My Requests
            <span id="hub-req-badge" class="badge bg-danger ms-1" style="display:none;font-size:.65rem"></span>
          </a>
        </li>
      </ul>

      <!-- ── SCHEDULE PANE ──────────────────────────────────────────────── -->
      <div id="hub-pane-schedule">
        <div class="card"><div class="card-header d-flex align-items-center gap-2">
          <i class="bi bi-calendar-week text-primary"></i><span>My Upcoming Shifts</span>
        </div>
          <div id="schedule-content" class="p-4"><div class="empty-state"><i class="bi bi-calendar-x"></i>No shifts assigned yet</div></div>
        </div>
      </div>

      <!-- ── AVAILABILITY PANE ──────────────────────────────────────────── -->
      <div id="hub-pane-availability" style="display:none">
        <div class="row g-3">
          <div class="col-md-5">
            <div class="card"><div class="card-header"><i class="bi bi-plus-circle me-2 text-primary"></i>Add Availability Block</div>
              <div class="card-body">
                <div class="mb-3"><label class="form-label small fw-semibold">Day</label>
                  <select class="form-select" id="av-day">
                    <option value="0">Monday</option><option value="1">Tuesday</option>
                    <option value="2">Wednesday</option><option value="3">Thursday</option>
                    <option value="4">Friday</option><option value="5">Saturday</option><option value="6">Sunday</option>
                  </select></div>
                <div class="row g-2 mb-3">
                  <div class="col"><label class="form-label small fw-semibold">Start (hr)</label><input type="number" class="form-control" id="av-start" min="0" max="23" value="9"></div>
                  <div class="col"><label class="form-label small fw-semibold">End (hr)</label><input type="number" class="form-control" id="av-end" min="1" max="24" value="17"></div>
                </div>
                <button class="btn btn-accent w-100" onclick="saveAvailability()"><i class="bi bi-plus-circle me-2"></i>Add Block</button>
              </div></div>
          </div>
          <div class="col-md-7">
            <div class="card"><div class="card-header"><i class="bi bi-clock me-2 text-primary"></i>My Weekly Availability</div>
              <div id="av-list" class="p-3"></div></div>
          </div>
        </div>
      </div>

      <!-- ── JOB BOARD PANE ─────────────────────────────────────────────── -->
      <div id="hub-pane-jobboard" style="display:none">
        <div class="row g-2 mb-3 align-items-end">
          <div class="col"><input class="form-control" id="jb-q" placeholder="Search title, role, tags…" oninput="loadJobBoard()"></div>
          <div class="col-auto"><input class="form-control" id="jb-date" type="date" onchange="loadJobBoard()"></div>
          <div class="col-auto"><input class="form-control" id="jb-role" placeholder="Role filter" oninput="loadJobBoard()"></div>
          <div class="col-auto"><button class="btn btn-accent" onclick="loadJobBoard()"><i class="bi bi-search me-1"></i>Search</button></div>
        </div>
        <div id="jb-results" class="row g-3"></div>
      </div>

      <!-- ── REQUESTS PANE ──────────────────────────────────────────────── -->
      <div id="hub-pane-requests" style="display:none">
        <ul class="nav nav-pills mb-3" id="req-tabs">
          <li class="nav-item"><a class="nav-link active" href="#" onclick="showReqTab('shift-reqs');return false"><i class="bi bi-file-earmark-text me-1"></i>Shift Requests</a></li>
          <li class="nav-item"><a class="nav-link" href="#" onclick="showReqTab('training-reqs');return false"><i class="bi bi-mortarboard me-1"></i>Training</a></li>
          <li class="nav-item"><a class="nav-link" href="#" onclick="showReqTab('swap-reqs');return false"><i class="bi bi-arrow-left-right me-1"></i>Shift Swaps</a></li>
        </ul>

        <!-- Shift Requests -->
        <div id="req-tab-shift-reqs">
          <div id="my-shift-reqs" class="mb-3"></div>
        </div>

        <!-- Training Requests -->
        <div id="req-tab-training-reqs" style="display:none">
          <div class="card mb-3">
            <div class="card-header">Request Training</div>
            <div class="card-body">
              <input class="form-control mb-2" id="tr-skill" placeholder="Skill / certification name">
              <textarea class="form-control mb-2" id="tr-notes" rows="2" placeholder="Notes (optional)"></textarea>
              <button class="btn btn-accent" onclick="submitTrainingRequest()"><i class="bi bi-mortarboard me-1"></i>Submit Request</button>
            </div>
          </div>
          <div id="my-training-reqs"></div>
        </div>

        <!-- Swap Requests -->
        <div id="req-tab-swap-reqs" style="display:none">
          <div class="card mb-3">
            <div class="card-header"><i class="bi bi-arrow-left-right me-2"></i>Request a Shift Swap</div>
            <div class="card-body row g-2">
              <div class="col-md-6"><label class="form-label small fw-semibold">My Shift Date</label><input class="form-control" id="sw-my-date" type="date"></div>
              <div class="col-md-3"><label class="form-label small fw-semibold">Start</label><input class="form-control" id="sw-my-start" type="time"></div>
              <div class="col-md-3"><label class="form-label small fw-semibold">End</label><input class="form-control" id="sw-my-end" type="time"></div>
              <div class="col-12 mt-1"><label class="form-label small fw-semibold text-muted">Target peer (optional — leave blank for open offer)</label></div>
              <div class="col-md-6"><input class="form-control" id="sw-peer-id" placeholder="Peer worker User ID (optional)"></div>
              <div class="col-md-6"><input class="form-control" id="sw-peer-date" type="date" placeholder="Their shift date"></div>
              <div class="col-md-3"><input class="form-control" id="sw-peer-start" type="time"></div>
              <div class="col-md-3"><input class="form-control" id="sw-peer-end" type="time"></div>
              <div class="col-12"><textarea class="form-control" id="sw-msg" rows="1" placeholder="Message (optional)"></textarea></div>
              <div class="col-auto"><button class="btn btn-accent" onclick="submitSwapRequest()"><i class="bi bi-arrow-left-right me-1"></i>Submit Swap Request</button></div>
            </div>
          </div>
          <div id="my-swap-reqs"></div>
        </div>
      </div>
    </div><!-- end view-worker-hub -->

    <!-- TENANT: TIMESHEETS -->
    <div class="view" id="view-tenant-timesheets">

      <!-- Live status panel -->
      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <div class="card h-100" style="border-left:4px solid #10b981">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
              <span><i class="bi bi-circle-fill text-success me-2" style="font-size:.65rem"></i>Clocked In Now</span>
              <span id="live-clocked-count" class="badge bg-success">0</span>
            </div>
            <div id="live-clocked-list" class="p-2" style="max-height:220px;overflow-y:auto">
              <div class="text-muted small p-2">Loading…</div>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card h-100" style="border-left:4px solid #ef4444">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
              <span><i class="bi bi-exclamation-circle-fill text-danger me-2" style="font-size:.85rem"></i>Expected But Not Clocked In</span>
              <span id="live-expected-count" class="badge bg-danger">0</span>
            </div>
            <div id="live-expected-list" class="p-2" style="max-height:220px;overflow-y:auto">
              <div class="text-muted small p-2">Loading…</div>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-auto">
          <select class="form-select form-select-sm" id="ts-filter-status" onchange="loadTimesheets()">
            <option value="">All Status</option>
            <option value="active">Active (clocked in)</option>
            <option value="completed">Completed</option>
            <option value="approved">Approved</option>
            <option value="disputed">Disputed</option>
          </select>
        </div>
        <div class="col-auto ms-auto">
          <button class="btn btn-sm btn-outline-primary" onclick="loadTimesheetSummary()"><i class="bi bi-bar-chart me-1"></i>Summary</button>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header">Employee Timesheets</div>
        <div id="ts-list" class="p-3"></div>
      </div>
      <div class="card" id="ts-summary-card" style="display:none">
        <div class="card-header">Hours Summary</div>
        <div id="ts-summary" class="p-3"></div>
      </div>
    </div>

    <!-- TENANT: SCHEDULE EDITOR -->
    <div class="view" id="view-tenant-schedule">
      <!-- Toolbar -->
      <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <button class="btn btn-outline-secondary btn-sm" onclick="calNav(-1)"><i class="bi bi-chevron-left"></i></button>
        <button class="btn btn-outline-secondary btn-sm" onclick="calNav(0)">Today</button>
        <button class="btn btn-outline-secondary btn-sm" onclick="calNav(1)"><i class="bi bi-chevron-right"></i></button>
        <span id="cal-week-label" class="fw-semibold ms-1" style="font-size:.95rem"></span>
        <div class="ms-auto d-flex gap-2">
          <select class="form-select form-select-sm" id="cal-filter-location" onchange="_calLoadShifts()" style="width:160px">
            <option value="">All Locations</option>
          </select>
          <select class="form-select form-select-sm" id="cal-filter-status" onchange="renderCalendar()" style="width:140px">
            <option value="">All Statuses</option>
            <option value="draft">Draft</option>
            <option value="published">Published</option>
            <option value="cancelled">Cancelled</option>
          </select>
          <button class="btn btn-accent btn-sm" onclick="openShiftModal()" id="cal-add-btn" style="display:none"><i class="bi bi-plus-lg me-1"></i>Add Shift</button>
        </div>
      </div>
      <!-- Legend -->
      <div class="d-flex gap-3 mb-3" style="font-size:.75rem">
        <span><span class="shift-block status-draft d-inline-block" style="position:static;width:12px;height:12px;border-radius:3px;margin-right:4px;padding:0;vertical-align:middle"></span>Draft</span>
        <span><span class="shift-block status-published d-inline-block" style="position:static;width:12px;height:12px;border-radius:3px;margin-right:4px;padding:0;vertical-align:middle"></span>Published</span>
        <span><span class="shift-block status-cancelled d-inline-block" style="position:static;width:12px;height:12px;border-radius:3px;margin-right:4px;padding:0;vertical-align:middle"></span>Cancelled</span>
      </div>
      <!-- Calendar -->
      <div style="overflow-x:auto">
        <div class="cal-grid" id="cal-grid" style="min-width:700px"></div>
      </div>
    </div>

    <!-- TENANT: JOB POSTINGS MANAGEMENT -->
    <div class="view" id="view-tenant-job-postings">
      <div class="row g-3">
        <div class="col-lg-4">
          <div class="card">
            <div class="card-header">Post a Job / Open Shift</div>
            <div class="card-body">
              <input class="form-control mb-2" id="jp-title" placeholder="Title *">
              <input class="form-control mb-2" id="jp-role" placeholder="Role (e.g. Barista)">
              <textarea class="form-control mb-2" id="jp-desc" rows="2" placeholder="Description"></textarea>
              <div class="row g-1 mb-2">
                <div class="col"><input class="form-control" id="jp-date" type="date" placeholder="Shift date"></div>
                <div class="col"><input class="form-control" id="jp-start" type="time" placeholder="Start"></div>
                <div class="col"><input class="form-control" id="jp-end" type="time" placeholder="End"></div>
              </div>
              <input class="form-control mb-2" id="jp-pay" placeholder="Pay rate (e.g. $18/hr)">
              <input class="form-control mb-2" id="jp-slots" type="number" value="1" min="1" placeholder="Slots needed">
              <input class="form-control mb-2" id="jp-tags" placeholder="Tags (comma-separated)">
              <button class="btn btn-accent w-100" onclick="createPosting()"><i class="bi bi-plus-circle me-1"></i>Post</button>
            </div>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="d-flex gap-2 mb-2">
            <select class="form-select form-select-sm w-auto" id="jp-filter" onchange="loadTenantPostings()">
              <option value="">All Status</option>
              <option value="open">Open</option>
              <option value="filled">Filled</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </div>
          <div id="tenant-postings-list"></div>
        </div>
      </div>
    </div>

    <!-- TENANT: SHIFT REQUESTS REVIEW -->
    <div class="view" id="view-tenant-shift-review">
      <div class="d-flex gap-2 mb-3">
        <select class="form-select form-select-sm w-auto" id="sr-filter" onchange="loadTenantShiftRequests()">
          <option value="pending">Pending</option>
          <option value="">All</option>
          <option value="approved">Approved</option>
          <option value="denied">Denied</option>
        </select>
        <button class="btn btn-sm btn-outline-secondary" onclick="loadTenantShiftRequests()"><i class="bi bi-arrow-clockwise"></i></button>
      </div>
      <div id="tenant-shift-reqs"></div>
    </div>

    <!-- TENANT: SWAP REQUESTS REVIEW -->
    <div class="view" id="view-tenant-swap-review">
      <div class="d-flex gap-2 mb-3">
        <select class="form-select form-select-sm w-auto" id="swp-filter" onchange="loadTenantSwapRequests()">
          <option value="pending">Pending</option>
          <option value="awaiting_peer">Awaiting Peer</option>
          <option value="">All</option>
        </select>
        <button class="btn btn-sm btn-outline-secondary" onclick="loadTenantSwapRequests()"><i class="bi bi-arrow-clockwise"></i></button>
      </div>
      <div id="tenant-swap-reqs"></div>
    </div>

    <!-- TENANT: SWAP PERMISSION RULES -->
    <div class="view" id="view-tenant-swap-rules">
      <div class="row g-3">
        <div class="col-lg-5">
          <div class="card">
            <div class="card-header">Add Swap Rule</div>
            <div class="card-body">
              <div class="mb-2">
                <label class="form-label small fw-semibold">Effect</label>
                <select class="form-select" id="rule-effect">
                  <option value="allow">✅ Allow (auto-approve)</option>
                  <option value="deny">🚫 Deny (block swap)</option>
                </select>
              </div>
              <div class="mb-2">
                <label class="form-label small fw-semibold">Employee (Membership ID — blank = all)</label>
                <input class="form-control" id="rule-member" placeholder="Leave blank for all employees">
              </div>
              <div class="mb-2">
                <label class="form-label small fw-semibold">Role name (blank = any role)</label>
                <input class="form-control" id="rule-role" placeholder="e.g. Barista">
              </div>
              <div class="mb-2">
                <label class="form-label small fw-semibold">Day of week (blank = any)</label>
                <select class="form-select" id="rule-dow">
                  <option value="">Any day</option>
                  <option value="0">Monday</option><option value="1">Tuesday</option>
                  <option value="2">Wednesday</option><option value="3">Thursday</option>
                  <option value="4">Friday</option><option value="5">Saturday</option>
                  <option value="6">Sunday</option>
                </select>
              </div>
              <div class="row g-1 mb-2">
                <div class="col">
                  <label class="form-label small fw-semibold">Time window start</label>
                  <input class="form-control" id="rule-wstart" type="time">
                </div>
                <div class="col">
                  <label class="form-label small fw-semibold">Time window end</label>
                  <input class="form-control" id="rule-wend" type="time">
                </div>
              </div>
              <div class="mb-2">
                <label class="form-label small fw-semibold">Priority (higher = checked first)</label>
                <input class="form-control" id="rule-priority" type="number" value="10">
              </div>
              <div class="mb-2">
                <input class="form-control" id="rule-note" placeholder="Admin note (optional)">
              </div>
              <button class="btn btn-accent w-100" onclick="createSwapRule()"><i class="bi bi-plus-circle me-1"></i>Add Rule</button>
            </div>
          </div>
        </div>
        <div class="col-lg-7">
          <div class="card">
            <div class="card-header">Active Rules <small class="text-muted">(highest priority wins)</small></div>
            <div id="swap-rules-list" class="p-3"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- NO ACCESS -->
    <div class="view" id="view-no-access">
      <div class="no-access"><i class="bi bi-shield-x"></i><h5>Access Denied</h5><p class="text-muted">You don't have permission to view this page.</p></div>
    </div>

    <!-- TENANT: DASHBOARD ADMIN -->
    <div class="view" id="view-tenant-dashboard-admin">
      <div class="row g-4">
        <!-- Templates panel -->
        <div class="col-lg-5">
          <div class="card">
            <div class="card-header d-flex align-items-center">
              <i class="bi bi-layout-wtf me-2 text-primary"></i>Templates
              <button class="btn btn-accent btn-sm ms-auto" onclick="openModal('modal-new-template')"><i class="bi bi-plus-lg me-1"></i>New</button>
            </div>
            <div class="card-body p-0"><div id="tpl-list" class="p-3"></div></div>
          </div>
        </div>
        <!-- Members assignment panel -->
        <div class="col-lg-7">
          <div class="card">
            <div class="card-header"><i class="bi bi-people me-2 text-success"></i>Member Dashboard Assignments</div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                  <thead><tr><th>Member</th><th>Template</th><th>Locked</th><th>Custom</th><th></th></tr></thead>
                  <tbody id="dash-members-table"></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Template layout preview / editor -->
      <div id="tpl-editor" class="mt-4 d-none">
        <div class="card">
          <div class="card-header d-flex align-items-center">
            <i class="bi bi-pencil-square me-2"></i><span id="tpl-editor-title">Edit Template</span>
            <div class="ms-auto d-flex gap-2">
              <button class="btn btn-accent btn-sm" onclick="saveTplLayout()"><i class="bi bi-floppy me-1"></i>Save</button>
              <button class="btn btn-outline-secondary btn-sm" onclick="closeTplEditor()">Close</button>
            </div>
          </div>
          <div class="card-body">
            <div id="tpl-editor-grid" class="row g-3"></div>
            <div class="mt-3">
              <div class="fw-semibold small mb-2">Add Widget</div>
              <div id="tpl-widget-palette" class="row g-2"></div>
            </div>
          </div>
        </div>
      </div>
    </div>


    <!-- MY PROFILE -->
    <div class="view" id="view-worker-profile">
      <div class="row g-4" style="max-width:860px">
        <div class="col-md-4">
          <div class="card p-4 text-center">
            <div id="profile-avatar" style="width:80px;height:80px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;color:#fff;margin:0 auto 14px;background:#6366f1"></div>
            <div id="profile-display-name" class="fw-bold fs-5"></div>
            <div id="profile-email" class="text-muted small mb-2"></div>
            <div id="profile-role-badge" class="mb-3"></div>
            <button class="btn btn-sm btn-accent w-100" onclick="toggleProfileEdit()"><i class="bi bi-pencil me-1"></i>Edit Profile</button>
          </div>
          <div class="card p-3 mt-3">
            <div class="fw-semibold small text-muted mb-2 text-uppercase" style="font-size:.7rem;letter-spacing:.5px">Emergency Contact</div>
            <div id="profile-ec-name" class="small mb-1"></div>
            <div id="profile-ec-phone" class="small text-muted"></div>
          </div>
        </div>
        <div class="col-md-8">
          <!-- View mode -->
          <div id="profile-view-mode">
            <div class="card p-4 mb-3">
              <div class="fw-semibold mb-3">Personal Info</div>
              <div class="row g-3">
                <div class="col-6"><div class="text-muted small">Phone</div><div id="pv-phone">—</div></div>
                <div class="col-12"><div class="text-muted small">Bio</div><div id="pv-bio" style="white-space:pre-line">—</div></div>
              </div>
            </div>
            <div class="card p-4" id="profile-worker-card" style="display:none">
              <div class="fw-semibold mb-3">Work Info</div>
              <div class="row g-3">
                <div class="col-6"><div class="text-muted small">Job Title</div><div id="pv-job-title">—</div></div>
                <div class="col-6"><div class="text-muted small">Pay Rate</div><div id="pv-pay-rate">—</div></div>
                <div class="col-6"><div class="text-muted small">Hire Date</div><div id="pv-hire-date">—</div></div>
                <div class="col-6"><div class="text-muted small">Member Since</div><div id="pv-member-since">—</div></div>
              </div>
            </div>
          </div>
          <!-- Edit mode -->
          <div id="profile-edit-mode" style="display:none">
            <div class="card p-4 mb-3">
              <div class="fw-semibold mb-3">Edit Personal Info</div>
              <div class="row g-3">
                <div class="col-6"><label class="form-label small fw-semibold">First Name</label><input class="form-control" id="pe-first-name"></div>
                <div class="col-6"><label class="form-label small fw-semibold">Last Name</label><input class="form-control" id="pe-last-name"></div>
                <div class="col-6"><label class="form-label small fw-semibold">Phone</label><input class="form-control" id="pe-phone"></div>
                <div class="col-12"><label class="form-label small fw-semibold">Bio</label><textarea class="form-control" id="pe-bio" rows="3"></textarea></div>
                <div class="col-6"><label class="form-label small fw-semibold">Emergency Contact Name</label><input class="form-control" id="pe-ec-name"></div>
                <div class="col-6"><label class="form-label small fw-semibold">Emergency Contact Phone</label><input class="form-control" id="pe-ec-phone"></div>
              </div>
              <div class="mt-3 d-flex gap-2">
                <button class="btn btn-accent" onclick="saveMyProfile()"><i class="bi bi-check2 me-1"></i>Save</button>
                <button class="btn btn-outline-secondary" onclick="toggleProfileEdit()">Cancel</button>
              </div>
            </div>
            <div class="card p-4" id="profile-worker-edit-card" style="display:none">
              <div class="fw-semibold mb-3">Edit Work Info</div>
              <div class="row g-3">
                <div class="col-6"><label class="form-label small fw-semibold">Job Title</label><input class="form-control" id="pe-job-title"></div>
                <div class="col-6"><label class="form-label small fw-semibold">Hire Date</label><input type="date" class="form-control" id="pe-hire-date"></div>
              </div>
              <div class="mt-3"><button class="btn btn-accent" onclick="saveMyWorkerProfile()"><i class="bi bi-check2 me-1"></i>Save Work Info</button></div>
            </div>
            <div class="card p-4 mt-3" id="profile-skills-edit-card" style="display:none">
              <div class="fw-semibold mb-1">Skills &amp; Qualifications</div>
              <p class="text-muted small mb-3">These are used to match you with eligible shifts on the job board and swap requests.</p>
              <div class="mb-3">
                <label class="form-label small fw-semibold">Qualified Roles <span class="text-muted fw-normal">(comma-separated)</span></label>
                <input class="form-control" id="pe-qualified-roles" placeholder="e.g. Barista, Cashier, Shift Lead">
              </div>
              <div class="mb-3">
                <label class="form-label small fw-semibold">Skills <span class="text-muted fw-normal">(comma-separated)</span></label>
                <input class="form-control" id="pe-skills" placeholder="e.g. Latte Art, POS System, Inventory">
              </div>
              <div class="mb-3">
                <label class="form-label small fw-semibold">Certifications <span class="text-muted fw-normal">(comma-separated)</span></label>
                <input class="form-control" id="pe-certifications" placeholder="e.g. Food Handler, First Aid">
              </div>
              <div class="mb-3">
                <label class="form-label small fw-semibold">Max Weekly Hours <span class="text-muted fw-normal">(optional)</span></label>
                <input class="form-control" type="number" id="pe-max-hours" min="1" max="80" placeholder="e.g. 40">
              </div>
              <button class="btn btn-accent" onclick="saveMySkillsProfile()"><i class="bi bi-check2 me-1"></i>Save Skills</button>
            </div>
      <!-- Availability section in profile -->
      <div class="row g-4 mt-1" style="max-width:860px" id="profile-avail-section" style="display:none">
        <div class="col-12">
          <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
              <i class="bi bi-clock text-primary"></i>
              <span class="fw-semibold">My Weekly Availability</span>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-5">
                  <div class="fw-semibold small mb-2">Add Block</div>
                  <div class="row g-2 mb-2">
                    <div class="col-12">
                      <select class="form-select form-select-sm" id="prof-av-day">
                        <option value="0">Monday</option><option value="1">Tuesday</option>
                        <option value="2">Wednesday</option><option value="3">Thursday</option>
                        <option value="4">Friday</option><option value="5">Saturday</option><option value="6">Sunday</option>
                      </select>
                    </div>
                    <div class="col-6"><label class="form-label small">Start (hour)</label><input type="number" class="form-control form-control-sm" id="prof-av-start" min="0" max="23" value="9"></div>
                    <div class="col-6"><label class="form-label small">End (hour)</label><input type="number" class="form-control form-control-sm" id="prof-av-end" min="1" max="24" value="17"></div>
                  </div>
                  <button class="btn btn-accent btn-sm w-100" onclick="availSave('prof-av-day','prof-av-start','prof-av-end','prof-av-list')"><i class="bi bi-plus-circle me-1"></i>Add Block</button>
                </div>
                <div class="col-md-7">
                  <div class="fw-semibold small mb-2">Current Schedule</div>
                  <div id="prof-av-list"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODALS -->

<!-- Modal: New Dashboard Template -->
<div class="modal fade" id="modal-new-template" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">New Dashboard Template</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-3"><label class="form-label small fw-semibold">Template Name</label><input class="form-control" id="tpl-name-input" placeholder="e.g. Manager Layout"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Description (optional)</label><input class="form-control" id="tpl-desc-input" placeholder="Short description"></div>
    <div class="form-check"><input class="form-check-input" type="checkbox" id="tpl-default-cb"><label class="form-check-label small">Set as default for this business</label></div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-accent" onclick="createTemplate()">Create</button>
  </div>
</div></div></div>

<!-- Modal: Assign Dashboard to Member -->
<div class="modal fade" id="modal-assign-dash" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">Assign Dashboard Template</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <input type="hidden" id="assign-mid">
    <div class="mb-3 small fw-semibold" id="assign-member-label"></div>
    <div class="mb-3">
      <label class="form-label small fw-semibold">Template</label>
      <select class="form-select" id="assign-tpl-sel"></select>
    </div>
    <div class="form-check mb-2"><input class="form-check-input" type="checkbox" id="assign-locked-cb"><label class="form-check-label small">Lock dashboard (prevent customization)</label></div>
    <div class="form-check"><input class="form-check-input" type="checkbox" id="assign-reset-cb"><label class="form-check-label small">Reset user's custom layout</label></div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-accent" onclick="saveDashAssignment()">Save</button>
  </div>
</div></div></div>

<!-- Modal: New Widget Definition -->
<div class="modal fade" id="modal-new-widget" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title" id="widget-modal-title">New Widget</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <input type="hidden" id="widget-edit-id">
    <div class="mb-3"><label class="form-label small fw-semibold">Type Key</label><input class="form-control" id="widget-type-input" placeholder="custom_text, my_widget…"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Title</label><input class="form-control" id="widget-title-input" placeholder="Widget display name"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Description</label><input class="form-control" id="widget-desc-input" placeholder="Short description"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Bootstrap Icon class</label><input class="form-control" id="widget-icon-input" placeholder="bi-grid" value="bi-grid"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Default Config (JSON)</label><textarea class="form-control font-monospace" id="widget-cfg-input" rows="4">{}</textarea></div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-accent" onclick="saveWidgetDef()">Save</button>
  </div>
</div></div></div>

<!-- Modal: Add global permission -->
<div class="modal fade" id="modal-add-perm" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">Add Global Permission</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-3"><label class="form-label small fw-semibold">Permission Key</label><input class="form-control" id="add-perm-key" placeholder="e.g. reports:read"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Description</label><input class="form-control" id="add-perm-desc" placeholder="What this permission grants"></div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-accent" onclick="addGlobalPerm()">Add</button>
  </div>
</div></div></div>


<div class="modal fade" id="modal-member-profile" tabindex="-1"><div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content">
  <div class="modal-header">
    <div class="d-flex align-items-center gap-3">
      <div id="mp-avatar" style="width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:700;color:#fff;background:#6366f1;flex-shrink:0"></div>
      <div><h5 class="modal-title mb-0" id="mp-name">Member Profile</h5><small class="text-muted" id="mp-email"></small></div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
  </div>
  <div class="modal-body">
    <ul class="nav nav-tabs mb-3" id="mp-tabs">
      <li class="nav-item"><a class="nav-link active" href="#" data-mptab="info">Info</a></li>
      <li class="nav-item"><a class="nav-link" href="#" data-mptab="work">Work</a></li>
      <li class="nav-item" id="mp-edit-tab-li" style="display:none"><a class="nav-link" href="#" data-mptab="edit">Edit</a></li>
      <li class="nav-item" id="mp-locroles-tab-li" style="display:none"><a class="nav-link" href="#" data-mptab="locroles"><i class="bi bi-geo-alt me-1"></i>Location Roles</a></li>
    </ul>
    <div id="mp-tab-info">
      <div class="row g-3">
        <div class="col-6"><div class="text-muted small">Phone</div><div id="mp-phone">—</div></div>
        <div class="col-6"><div class="text-muted small">Status</div><div id="mp-status"></div></div>
        <div class="col-6"><div class="text-muted small">Roles</div><div id="mp-roles"></div></div>
        <div class="col-6"><div class="text-muted small">Location</div><div id="mp-location">—</div></div>
        <div class="col-12"><div class="text-muted small">Bio</div><div id="mp-bio" style="white-space:pre-line">—</div></div>
        <div class="col-6"><div class="text-muted small">Emergency Contact</div><div id="mp-ec-name">—</div></div>
        <div class="col-6"><div class="text-muted small">Emergency Phone</div><div id="mp-ec-phone">—</div></div>
      </div>
    </div>
    <div id="mp-tab-work" style="display:none">
      <div class="row g-3">
        <div class="col-6"><div class="text-muted small">Job Title</div><div id="mp-job-title">—</div></div>
        <div class="col-6"><div class="text-muted small">Pay Rate</div><div id="mp-pay-rate">—</div></div>
        <div class="col-6"><div class="text-muted small">Hire Date</div><div id="mp-hire-date">—</div></div>
        <div class="col-6"><div class="text-muted small">Member Since</div><div id="mp-member-since">—</div></div>
        <div class="col-12"><div class="text-muted small">Notes</div><div id="mp-notes" style="white-space:pre-line">—</div></div>
      </div>
    </div>
    <div id="mp-tab-edit" style="display:none">
      <div class="row g-3">
        <div class="col-6"><label class="form-label small fw-semibold">First Name</label><input class="form-control" id="mpe-first-name"></div>
        <div class="col-6"><label class="form-label small fw-semibold">Last Name</label><input class="form-control" id="mpe-last-name"></div>
        <div class="col-6"><label class="form-label small fw-semibold">Phone</label><input class="form-control" id="mpe-phone"></div>
        <div class="col-6"><label class="form-label small fw-semibold">Status</label>
          <select class="form-select" id="mpe-status">
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
            <option value="invited">Invited</option>
            <option value="removed">Removed</option>
          </select>
        </div>
        <div class="col-12"><label class="form-label small fw-semibold">Bio</label><textarea class="form-control" id="mpe-bio" rows="2"></textarea></div>
        <div class="col-6"><label class="form-label small fw-semibold">Emergency Contact Name</label><input class="form-control" id="mpe-ec-name"></div>
        <div class="col-6"><label class="form-label small fw-semibold">Emergency Contact Phone</label><input class="form-control" id="mpe-ec-phone"></div>
        <div class="col-6"><label class="form-label small fw-semibold">Job Title</label><input class="form-control" id="mpe-job-title"></div>
        <div class="col-6"><label class="form-label small fw-semibold">Pay Rate ($/hr)</label><input type="number" step="0.01" class="form-control" id="mpe-pay-rate"></div>
        <div class="col-6"><label class="form-label small fw-semibold">Hire Date</label><input type="date" class="form-control" id="mpe-hire-date"></div>
        <div class="col-6"><label class="form-label small fw-semibold">Primary Location</label>
          <select class="form-select" id="mpe-location"><option value="">— None —</option></select>
        </div>
        <div class="col-12"><label class="form-label small fw-semibold">Notes (manager only)</label><textarea class="form-control" id="mpe-notes" rows="2"></textarea></div>
        <div class="col-12">
          <label class="form-label small fw-semibold">Roles</label>
          <div id="mpe-roles-wrap" class="d-flex flex-wrap gap-3 p-2 border rounded" style="min-height:42px;background:var(--bs-body-bg,#f8f9fa)"></div>
        </div>
      </div>
      <div class="mt-3 d-flex gap-2">
        <button class="btn btn-accent" onclick="saveMemberProfile()"><i class="bi bi-check2 me-1"></i>Save Changes</button>
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
      </div>
    </div>
    <!-- Location Roles tab -->
    <div id="mp-tab-locroles" style="display:none">
      <p class="text-muted small mb-3">Assign roles at specific locations. These permissions are <strong>additive</strong> — they stack on top of this member's business-wide roles.</p>
      <div id="mpe-locroles-body">
        <div class="text-muted text-center py-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading…</div>
      </div>
      <div class="mt-3">
        <button class="btn btn-accent" onclick="saveLocationRoles()"><i class="bi bi-check2 me-1"></i>Save Location Roles</button>
      </div>
    </div>
  </div>
</div></div></div>

<!-- Shift Editor Modal -->
<div class="modal fade" id="modal-shift" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">
  <div class="modal-header">
    <h5 class="modal-title" id="shift-modal-title">New Shift</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
  </div>
  <div class="modal-body">
    <div class="row g-3">
      <div class="col-8"><label class="form-label small fw-semibold">Title <span class="text-danger">*</span></label><input class="form-control" id="sm-title" placeholder="e.g. Morning Shift, Opening Barista"></div>
      <div class="col-4"><label class="form-label small fw-semibold">Spots Needed</label><input type="number" class="form-control" id="sm-count" value="1" min="1"></div>
      <div class="col-6"><label class="form-label small fw-semibold">Start</label><input type="datetime-local" class="form-control" id="sm-start"></div>
      <div class="col-6"><label class="form-label small fw-semibold">End</label><input type="datetime-local" class="form-control" id="sm-end"></div>
      <div class="col-6"><label class="form-label small fw-semibold">Role / Position</label><input class="form-control" id="sm-role" placeholder="Barista, Cashier…"></div>
      <div class="col-6"><label class="form-label small fw-semibold">Status</label>
        <select class="form-select" id="sm-status">
          <option value="draft">Draft</option>
          <option value="published">Published</option>
          <option value="cancelled">Cancelled</option>
        </select>
      </div>
      <div class="col-6"><label class="form-label small fw-semibold">Color (optional)</label>
        <div class="d-flex gap-2 align-items-center">
          <input type="color" class="form-control form-control-color" id="sm-color" value="#6366f1" style="width:48px">
          <span class="text-muted small">Leave as-is to use status color</span>
        </div>
      </div>
      <div class="col-6"><label class="form-label small fw-semibold">Location</label>
        <select class="form-select" id="sm-location"><option value="">— None —</option></select>
      </div>
      <div class="col-12"><label class="form-label small fw-semibold">Notes</label><textarea class="form-control" id="sm-notes" rows="2"></textarea></div>
    </div>
    <!-- Assignments section (shown when editing existing shift) -->
    <div id="sm-assignments-section" class="mt-4" style="display:none">
      <div class="d-flex align-items-center justify-content-between mb-2">
        <div class="fw-semibold small">Assigned Employees</div>
        <div class="d-flex gap-2">
          <select class="form-select form-select-sm" id="sm-assign-member" style="width:220px"><option value="">— Select member —</option></select>
          <button class="btn btn-sm btn-accent" onclick="addShiftAssignment()"><i class="bi bi-person-plus"></i></button>
        </div>
      </div>
      <div id="sm-assignments-list"></div>
    </div>
  </div>
  <div class="modal-footer d-flex justify-content-between">
    <div>
      <button class="btn btn-danger btn-sm" id="sm-delete-btn" style="display:none" onclick="deleteShiftFromModal()"><i class="bi bi-trash me-1"></i>Delete</button>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
      <button class="btn btn-accent" onclick="saveShift()"><i class="bi bi-check2 me-1"></i>Save Shift</button>
    </div>
  </div>
</div></div></div>

<div class="modal fade" id="modal-new-biz" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">New Business</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-3"><label class="form-label small fw-semibold">Name</label><input class="form-control" id="nb-name"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Plan</label><select class="form-select" id="nb-plan"><option value="free">Free</option><option value="starter">Starter</option><option value="pro">Pro</option></select></div>
  </div>
  <div class="modal-footer"><button class="btn btn-accent" onclick="createBusiness()">Create</button></div>
</div></div></div>

<div class="modal fade" id="modal-new-agent" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">New Agent</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-3"><label class="form-label small fw-semibold">Name</label><input class="form-control" id="na-name" placeholder="Scheduling Bot"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Type</label><select class="form-select" id="na-type"><option value="service">Service</option><option value="ai">AI</option><option value="integration">Integration</option><option value="webhook">Webhook</option></select></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Scopes (comma-separated)</label><input class="form-control" id="na-scopes" value="schedule:read,runs:write,runs:read,ping"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Expires (days, blank = never)</label><input type="number" class="form-control" id="na-expires"></div>
  </div>
  <div class="modal-footer"><button class="btn btn-accent" onclick="createAgent()">Create &amp; Get Key</button></div>
</div></div></div>

<div class="modal fade" id="modal-apikey" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-key-fill me-2 text-warning"></i>API Key — Save This Now</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="alert alert-warning py-2 small">Shown <strong>once only</strong>. Store it securely.</div>
    <div class="key-reveal mb-3" id="apikey-display"></div>
    <button class="btn btn-sm btn-outline-secondary" onclick="copyKey()"><i class="bi bi-clipboard me-1"></i>Copy</button>
  </div>
</div></div></div>

<div class="modal fade" id="modal-invite" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">Invite Member</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body"><div class="mb-3"><label class="form-label small fw-semibold">Email</label><input type="email" class="form-control" id="inv-email"></div></div>
  <div class="modal-footer"><button class="btn btn-accent" onclick="inviteMember()">Invite</button></div>
</div></div></div>

<div class="modal fade" id="modal-new-role" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">New Role</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body"><div class="mb-3"><label class="form-label small fw-semibold">Role Name</label><input class="form-control" id="nr-name" placeholder="Manager"></div></div>
  <div class="modal-footer"><button class="btn btn-accent" onclick="createRole()">Create</button></div>
</div></div></div>

<div class="modal fade" id="modal-new-loc" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">New Location</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-3"><label class="form-label small fw-semibold">Name</label><input class="form-control" id="nl-name" placeholder="Main Street Branch"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Timezone</label>
      <select class="form-select" id="nl-tz">
        <option value="UTC">UTC</option><option value="America/New_York">America/New_York</option>
        <option value="America/Chicago">America/Chicago</option><option value="America/Los_Angeles">America/Los_Angeles</option>
        <option value="Europe/London">Europe/London</option><option value="Asia/Tokyo">Asia/Tokyo</option>
      </select></div>
  </div>
  <div class="modal-footer"><button class="btn btn-accent" onclick="createLocation()">Create</button></div>
</div></div></div>

<!-- ADD PERMISSION MODAL -->
<div class="modal fade" id="modal-add-perm" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">Add Permission to <span id="perm-role-name"></span></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <p class="text-muted small mb-3">Check one or more permissions to add to this role.</p>
    <div class="row g-2 mb-3" id="perm-checkboxes">
      <div class="col-12"><div class="fw-semibold small text-muted mb-1">Members</div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="members:read" id="p-mr"><label class="form-check-label small" for="p-mr">members:read</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="members:write" id="p-mw"><label class="form-check-label small" for="p-mw">members:write</label></div>
      </div>
      <div class="col-12"><div class="fw-semibold small text-muted mb-1">Roles</div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="roles:read" id="p-rr"><label class="form-check-label small" for="p-rr">roles:read</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="roles:write" id="p-rw"><label class="form-check-label small" for="p-rw">roles:write</label></div>
      </div>
      <div class="col-12"><div class="fw-semibold small text-muted mb-1">Locations</div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="locations:read" id="p-lr"><label class="form-check-label small" for="p-lr">locations:read</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="locations:write" id="p-lw"><label class="form-check-label small" for="p-lw">locations:write</label></div>
      </div>
      <div class="col-12"><div class="fw-semibold small text-muted mb-1">Schedule</div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="schedule:read" id="p-sr"><label class="form-check-label small" for="p-sr">schedule:read</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="schedule:write" id="p-sw"><label class="form-check-label small" for="p-sw">schedule:write</label></div>
      </div>
      <div class="col-12"><div class="fw-semibold small text-muted mb-1">Time Clock</div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="timeclock:read" id="p-tcr"><label class="form-check-label small" for="p-tcr">timeclock:read</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="timeclock:write" id="p-tcw"><label class="form-check-label small" for="p-tcw">timeclock:write</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="timeclock:manage" id="p-tcm"><label class="form-check-label small" for="p-tcm">timeclock:manage</label></div>
      </div>
      <div class="col-12"><div class="fw-semibold small text-muted mb-1">Marketplace</div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="marketplace:read" id="p-mkr"><label class="form-check-label small" for="p-mkr">marketplace:read</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="marketplace:write" id="p-mkw"><label class="form-check-label small" for="p-mkw">marketplace:write</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="marketplace:manage" id="p-mkm"><label class="form-check-label small" for="p-mkm">marketplace:manage</label></div>
      </div>
      <div class="col-12"><div class="fw-semibold small text-muted mb-1">Reports</div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="reports:read" id="p-repread"><label class="form-check-label small" for="p-repread">reports:read</label></div>
      </div>
      <div class="col-12"><div class="fw-semibold small text-muted mb-1">Messaging</div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="messaging:read" id="p-msgr"><label class="form-check-label small" for="p-msgr">messaging:read</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="messaging:write" id="p-msgw"><label class="form-check-label small" for="p-msgw">messaging:write</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="messaging:broadcast" id="p-msgb"><label class="form-check-label small" for="p-msgb">messaging:broadcast</label></div>
        <div class="form-check form-check-inline"><input class="form-check-input perm-cb" type="checkbox" value="messaging:manage" id="p-msgm"><label class="form-check-label small" for="p-msgm">messaging:manage</label></div>
      </div>
    </div>
    <div class="mb-2">
      <label class="form-label small fw-semibold text-muted">Custom permission key (optional, e.g. <code>payroll:read</code>)</label>
      <input class="form-control form-control-sm" id="perm-custom" placeholder="custom:key">
    </div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-accent" onclick="submitAddPerms()">Add Selected</button>
  </div>
</div></div></div>

<!-- APPLY TO POSTING MODAL -->
<div class="modal fade" id="modal-apply-posting" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">Apply for Shift</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div id="apply-posting-summary" class="alert alert-info small mb-3"></div>
    <div class="mb-3">
      <label class="form-label small fw-semibold">Message to manager <span class="text-muted">(optional)</span></label>
      <textarea class="form-control" id="apply-msg" rows="3" placeholder="e.g. I'm available all day and have experience in this role…"></textarea>
    </div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-accent" onclick="submitApply()"><i class="bi bi-send me-1"></i>Submit Application</button>
  </div>
</div></div></div>

<!-- DENY REQUEST MODAL -->
<div class="modal fade" id="modal-deny" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title" id="deny-modal-title">Deny Request</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <p class="text-muted small mb-2">Select a reason or write your own:</p>
    <div class="mb-3">
      <div class="form-check mb-1"><input class="form-check-input" type="radio" name="deny-reason-radio" id="dr-1" value="Shift already filled"><label class="form-check-label small" for="dr-1">Shift already filled</label></div>
      <div class="form-check mb-1"><input class="form-check-input" type="radio" name="deny-reason-radio" id="dr-2" value="Insufficient experience for this role"><label class="form-check-label small" for="dr-2">Insufficient experience for this role</label></div>
      <div class="form-check mb-1"><input class="form-check-input" type="radio" name="deny-reason-radio" id="dr-3" value="Swap violates scheduling policy"><label class="form-check-label small" for="dr-3">Swap violates scheduling policy</label></div>
      <div class="form-check mb-1"><input class="form-check-input" type="radio" name="deny-reason-radio" id="dr-4" value="Business need requires original assignment"><label class="form-check-label small" for="dr-4">Business need requires original assignment</label></div>
      <div class="form-check mb-1"><input class="form-check-input" type="radio" name="deny-reason-radio" id="dr-other" value="__other__"><label class="form-check-label small" for="dr-other">Other (specify below)</label></div>
    </div>
    <textarea class="form-control" id="deny-note-text" rows="2" placeholder="Additional notes…"></textarea>
  </div>
  <div class="modal-footer">
    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-danger" onclick="submitDeny()"><i class="bi bi-x-circle me-1"></i>Confirm Deny</button>
  </div>
</div></div></div>

<!-- CONFIRM ACTION MODAL -->
<div class="modal fade" id="modal-confirm" tabindex="-1"><div class="modal-dialog modal-sm"><div class="modal-content">
  <div class="modal-header py-2"><h6 class="modal-title mb-0" id="confirm-title">Confirm</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body py-3"><p id="confirm-msg" class="mb-0 small"></p></div>
  <div class="modal-footer py-2">
    <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-sm" id="confirm-ok-btn" onclick="confirmOk()">Confirm</button>
  </div>
</div></div></div>

<!-- Messaging: New Channel modal -->
<div class="modal fade" id="modal-msg-channel" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">New Channel</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-3"><label class="form-label small fw-semibold">Name</label><input class="form-control" id="msg-ch-name" placeholder="e.g. Kitchen Team"></div>
    <div class="mb-3"><label class="form-label small fw-semibold">Type</label>
      <select class="form-select" id="msg-ch-type">
        <option value="group">Group (any member can post)</option>
        <option value="announcement">Announcement (managers only post)</option>
      </select>
    </div>
    <div class="mb-3"><label class="form-label small fw-semibold">Description (optional)</label><input class="form-control" id="msg-ch-desc" placeholder="What is this channel for?"></div>
  </div>
  <div class="modal-footer"><button class="btn btn-accent" onclick="msgCreateChannel()">Create</button></div>
</div></div></div>

<!-- Messaging: New DM modal -->
<div class="modal fade" id="modal-msg-dm" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">New Direct Message</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-3"><label class="form-label small fw-semibold">Select Member</label>
      <select class="form-select" id="msg-dm-target"></select>
    </div>
    <div class="mb-3"><label class="form-label small fw-semibold">First Message</label><input class="form-control" id="msg-dm-first" placeholder="Say hello…"></div>
  </div>
  <div class="modal-footer"><button class="btn btn-accent" onclick="msgSendDm()">Send</button></div>
</div></div></div>

<!-- Messaging: Broadcast modal -->
<div class="modal fade" id="modal-msg-broadcast" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-megaphone me-2"></i>Broadcast to All</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <p class="text-muted small">This message will be posted to all announcement channels in your business.</p>
    <div class="mb-3"><textarea class="form-control" id="msg-broadcast-text" rows="3" placeholder="Enter your announcement…"></textarea></div>
  </div>
  <div class="modal-footer"><button class="btn btn-warning" onclick="msgSendBroadcast()"><i class="bi bi-megaphone me-1"></i>Send Broadcast</button></div>
</div></div></div>

<!-- Messaging: API Key modal -->
<div class="modal fade" id="modal-msg-apikey" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title">New API Key</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-3"><label class="form-label small fw-semibold">Key Name</label><input class="form-control" id="msg-ak-name" placeholder="e.g. DriveUp Integration"></div>
    <div class="mb-3">
      <label class="form-label small fw-semibold">Permissions</label>
      <div><div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="msg-ak-read" checked><label class="form-check-label small" for="msg-ak-read">read</label></div>
      <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="msg-ak-write" checked><label class="form-check-label small" for="msg-ak-write">write</label></div></div>
    </div>
    <div class="mb-1 small text-muted">Leave channel list empty to allow access to all channels.</div>
    <div id="msg-ak-key-display" class="alert alert-success d-none">
      <strong>API Key (save now — shown once):</strong><br>
      <code id="msg-ak-key-value" style="word-break:break-all;font-size:.8rem"></code>
    </div>
  </div>
  <div class="modal-footer"><button class="btn btn-accent" onclick="msgCreateApiKey()">Create Key</button></div>
</div></div></div>

<!-- Quick Shift Swap Modal -->
<div class="modal fade" id="modal-quick-swap" tabindex="-1"><div class="modal-dialog modal-sm"><div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-arrow-left-right me-2"></i>Request Shift Swap</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="mb-2 p-2 rounded" style="background:rgba(0,0,0,.05);font-size:.85rem">
      <div class="fw-semibold" id="qswap-shift-label"></div>
      <div class="text-muted small" id="qswap-shift-time"></div>
    </div>
    <p class="small text-muted mb-2">This will post an open swap offer. Any eligible colleague can accept it (subject to manager approval).</p>
    <div class="mb-2">
      <label class="form-label small fw-semibold">Message <span class="text-muted fw-normal">(optional)</span></label>
      <textarea class="form-control" id="qswap-msg" rows="2" placeholder="e.g. Family commitment, need coverage"></textarea>
    </div>
    <input type="hidden" id="qswap-date">
    <input type="hidden" id="qswap-start">
    <input type="hidden" id="qswap-end">
    <input type="hidden" id="qswap-ref">
  </div>
  <div class="modal-footer">
    <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-accent btn-sm" onclick="submitQuickSwap()"><i class="bi bi-arrow-left-right me-1"></i>Submit Swap Request</button>
  </div>
</div></div></div>

<div class="toast-container">

<!-- ARRANGE COVERAGE MODAL -->
<div class="modal fade" id="modal-arrange-coverage" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">
  <div class="modal-header">
    <h5 class="modal-title"><i class="bi bi-person-fill-gear me-2"></i>Arrange Swap Coverage</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
  </div>
  <div class="modal-body p-0">
    <ul class="nav nav-tabs px-3 pt-3" id="cov-tabs">
      <li class="nav-item"><a class="nav-link active" href="#" onclick="covTab('manual',this)"><i class="bi bi-person-check me-1"></i>Manual Assignment</a></li>
      <li class="nav-item"><a class="nav-link" href="#" onclick="covTab('job_board',this)"><i class="bi bi-megaphone me-1"></i>Post to Job Board</a></li>
    </ul>
    <div class="p-3">
      <input type="hidden" id="cov-swap-id">
      <!-- Manual tab -->
      <div id="cov-tab-manual">
        <p class="text-muted small mb-2">Select an eligible worker to directly assign to this shift. Eligibility is based on role qualification, availability, and schedule conflicts.</p>
        <div id="cov-eligible-list"><div class="text-muted small text-center py-3"><i class="bi bi-hourglass"></i> Loading eligible workers…</div></div>
      </div>
      <!-- Job Board tab -->
      <div id="cov-tab-job_board" style="display:none">
        <p class="text-muted small mb-2">Post this shift to the job board. Only eligible workers will see it.</p>
        <div class="row g-2 mb-2">
          <div class="col-md-8">
            <label class="form-label small fw-semibold">Posting Title</label>
            <input class="form-control form-control-sm" id="cov-title" placeholder="e.g. Coverage needed – Feb 23 Morning Shift">
          </div>
          <div class="col-md-4">
            <label class="form-label small fw-semibold">Pay Rate</label>
            <input class="form-control form-control-sm" id="cov-pay" placeholder="e.g. $18/hr">
          </div>
        </div>
        <div class="mb-2">
          <label class="form-label small fw-semibold">Description</label>
          <textarea class="form-control form-control-sm" id="cov-desc" rows="2" placeholder="Additional details for workers…"></textarea>
        </div>
        <div class="card p-2 mb-2" style="background:rgba(255,255,255,.05)">
          <div class="fw-semibold small mb-2"><i class="bi bi-funnel me-1"></i>Eligibility Rules</div>
          <div class="row g-2">
            <div class="col-md-4">
              <label class="form-label small">Required Role</label>
              <input class="form-control form-control-sm" id="cov-rule-role" placeholder="e.g. Barista">
            </div>
            <div class="col-md-4">
              <label class="form-label small">Max Weekly Hours</label>
              <input class="form-control form-control-sm" type="number" id="cov-rule-hours" placeholder="e.g. 40">
            </div>
            <div class="col-md-4 d-flex align-items-end">
              <div class="form-check mb-1">
                <input class="form-check-input" type="checkbox" id="cov-rule-avail" checked>
                <label class="form-check-label small" for="cov-rule-avail">Require availability match</label>
              </div>
            </div>
          </div>
          <div class="form-check mt-1">
            <input class="form-check-input" type="checkbox" id="cov-rule-loc">
            <label class="form-check-label small" for="cov-rule-loc">Require location connection</label>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-accent btn-sm" id="cov-submit-btn" onclick="submitArrangeCoverage()"><i class="bi bi-check-circle me-1"></i>Assign</button>
  </div>
</div></div></div>

  <div id="toast" class="toast align-items-center border-0" role="alert">
    <div class="d-flex"><div class="toast-body" id="toast-msg"></div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
window._mainScript = true; // marker: main script started
document.getElementById('login-err').textContent = 'MAIN-SCRIPT-STARTED'; // immediate visible test
// JS error handler — show in login error div so we can see what's wrong
window.onerror = function(msg, src, line, col, err) {
  const el = document.getElementById('login-err');
  if (el) el.textContent = 'JS Error (line ' + line + '): ' + msg;
  console.error('JS ERROR:', msg, 'line:', line, err);
  return false;
};
window.addEventListener('unhandledrejection', function(e) {
  console.error('Unhandled promise rejection:', e.reason);
});
// ─────────────────────────────────────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────────────────────────────────────
const S = {
  token: localStorage.getItem('wf_token'),
  user: JSON.parse(localStorage.getItem('wf_user') || 'null'),
  businessId: localStorage.getItem('wf_biz') || '',
  perms: new Set(),          // permission keys for current business
  businesses: [],
  myLocations: [],           // locations this user can access in current business
};

const DEMO_EMAILS = {
  'demo-owner@workforce.app': { role: 'Business Owner', color: '#f59e0b', desc: 'You have Owner permissions: manage members, roles, locations, and view scheduling.' },
  'demo-worker@workforce.app': { role: 'Worker', color: '#10b981', desc: 'You have Worker permissions: view your schedule and set your availability.' },
};

// ─────────────────────────────────────────────────────────────────────────────
// API
// ─────────────────────────────────────────────────────────────────────────────
async function api(method, path, body) {
  const res = await fetch(path, {
    method,
    headers: { 'Content-Type': 'application/json', ...(S.token ? { Authorization: `Bearer ${S.token}` } : {}) },
    body: body ? JSON.stringify(body) : undefined,
  });
  const data = await res.json().catch(() => ({}));
  if (!res.ok) throw data;
  return data;
}

// ─────────────────────────────────────────────────────────────────────────────
// PERMISSIONS
// ─────────────────────────────────────────────────────────────────────────────
function can(perm) {
  return S.user?.is_superadmin || S.perms.has('*') || S.perms.has(perm);
}

async function loadPerms(bizId) {
  S.perms = new Set();
  if (!bizId) return;
  if (S.user?.is_superadmin) { S.perms.add('*'); return; }
  try {
    const d = await api('GET', `/api/v1/worker/me/permissions/${bizId}`);
    d.permissions.forEach(p => S.perms.add(p));
  } catch(e) {}
}

function applyPermGates() {
  // Worker portal — show hub if user has any worker permission
  const showHub = can('schedule:read') || can('marketplace:read') || can('marketplace:write');
  setVis('nav-worker-hub-link', showHub);
  // Show/hide individual tabs inside hub based on permissions
  const hubLiAvail = document.getElementById('hub-li-availability');
  const hubLiJob   = document.getElementById('hub-li-jobboard');
  const hubLiReqs  = document.getElementById('hub-li-requests');
  if (hubLiAvail) hubLiAvail.style.display = can('schedule:read') ? '' : 'none';
  if (hubLiJob)   hubLiJob.style.display   = can('marketplace:read') ? '' : 'none';
  if (hubLiReqs)  hubLiReqs.style.display  = (can('marketplace:read') || can('marketplace:write')) ? '' : 'none';
  // Show messaging FAB instead of sidebar link
  const fab = document.getElementById('msg-fab');
  if (fab) fab.style.display = can('messaging:read') ? 'flex' : 'none';

  // Tenant nav section — show if any tenant perm exists
  const hasTenant = can('members:read') || can('roles:read') || can('locations:read')
    || can('timeclock:manage') || can('marketplace:manage') || can('schedule:read');
  setVis('nav-tenant', hasTenant || S.user?.is_superadmin);
  setVis('nav-members-link',      can('members:read'));
  setVis('nav-schedule-edit-link',can('schedule:write'));
  setVis('nav-dashboard-admin-link', can('schedule:write'));
  setVis('nav-roles-link',        can('roles:read'));
  setVis('nav-locations-link',    can('locations:read'));
  setVis('nav-timesheets-link',   can('timeclock:manage'));
  setVis('nav-job-postings-link', can('marketplace:manage'));
  setVis('nav-shift-review-link', can('marketplace:manage'));
  setVis('nav-swap-review-link',  can('schedule:write'));
  setVis('nav-swap-rules-link',   can('schedule:write'));
  // Show add-shift button only for schedule:write
  setVis('cal-add-btn',           can('schedule:write'));

  // Action buttons within views
  setVis('invite-btn-wrap',    can('members:write'));
  setVis('new-role-btn-wrap',  can('roles:write'));
  setVis('new-loc-btn-wrap',   can('locations:write'));
}

function setVis(id, show) {
  const el = document.getElementById(id);
  if (el) el.style.display = show ? '' : 'none';
}

function renderPermsDisplay() {
  const el = document.getElementById('perms-display');
  const summary = document.getElementById('user-perms-summary');
  if (summary) {
    if (!S.perms.size || (S.perms.size === 1 && S.perms.has('*'))) {
      summary.textContent = S.user?.is_superadmin ? '⚡ Superadmin' : '';
    } else {
      summary.textContent = `${S.perms.size} permission${S.perms.size !== 1 ? 's' : ''}`;
    }
  }
  if (!el) return;
  if (!S.perms.size || (S.perms.size === 1 && S.perms.has('*'))) {
    el.innerHTML = S.user?.is_superadmin
      ? '<span class="perm-badge" style="background:#fce7f3;color:#831843">⚡ All permissions (superadmin)</span>'
      : '<div class="text-muted small">Select a business to see permissions</div>';
    return;
  }
  el.innerHTML = [...S.perms].map(p => `<span class="perm-badge">${p}</span>`).join('');
}

// ─────────────────────────────────────────────────────────────────────────────
// TOAST
// ─────────────────────────────────────────────────────────────────────────────
function toast(msg, type='success') {
  const el = document.getElementById('toast');
  el.className = `toast align-items-center border-0 text-bg-${type}`;
  document.getElementById('toast-msg').textContent = msg;
  new bootstrap.Toast(el, { delay: 3500 }).show();
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────────────────────────────────────
document.querySelectorAll('#authTabs .nav-link').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    document.querySelectorAll('#authTabs .nav-link').forEach(x => x.classList.remove('active'));
    a.classList.add('active');
    document.getElementById('tab-login').style.display = a.dataset.tab === 'login' ? '' : 'none';
    document.getElementById('tab-register').style.display = a.dataset.tab === 'register' ? '' : 'none';
  });
});

function fillLogin(email, pass) {
  document.getElementById('login-email').value = email;
  document.getElementById('login-password').value = pass;
}

function toggleNavSection(header) {
  const links = header.nextElementSibling;
  const isCollapsed = links.classList.toggle('collapsed');
  header.classList.toggle('collapsed', isCollapsed);
  // persist state
  const key = 'nav_collapsed_' + header.textContent.trim().replace(/\s+/g,'_');
  localStorage.setItem(key, isCollapsed ? '1' : '0');
}

function restoreNavSections() {
  document.querySelectorAll('.nav-section').forEach(header => {
    const key = 'nav_collapsed_' + header.textContent.trim().replace(/\s+/g,'_');
    if (localStorage.getItem(key) === '1') {
      header.classList.add('collapsed');
      header.nextElementSibling.classList.add('collapsed');
    }
  });
}

async function doLogin() {
  const errEl = document.getElementById('login-err');
  errEl.textContent = '';
  const btn = document.querySelector('#tab-login .btn-accent');
  if (btn) { btn.disabled = true; btn.textContent = 'Signing in…'; }
  try {
    const d = await api('POST', '/api/v1/auth/login', {
      email: document.getElementById('login-email').value,
      password: document.getElementById('login-password').value,
    });
    S.token = d.access_token;
    localStorage.setItem('wf_token', S.token);
    S.user = await api('GET', '/api/v1/auth/me');
    localStorage.setItem('wf_user', JSON.stringify(S.user));
    await bootApp();
  } catch(e) {
    // Ensure auth screen is visible if bootApp started then crashed
    document.getElementById('auth-screen').style.display = 'flex';
    document.getElementById('app-shell').style.display = 'none';
    errEl.textContent = e.detail || e.message || JSON.stringify(e) || 'Sign in failed';
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-box-arrow-in-right me-2"></i>Sign In'; }
  }
}

async function doRegister() {
  document.getElementById('reg-err').textContent = '';
  try {
    await api('POST', '/api/v1/auth/register', {
      email: document.getElementById('reg-email').value,
      password: document.getElementById('reg-password').value,
      is_superadmin: document.getElementById('reg-superadmin').checked,
    });
    toast('Account created — sign in now');
    document.querySelector('[data-tab="login"]').click();
  } catch(e) {
    document.getElementById('reg-err').textContent = e.detail || 'Registration failed';
  }
}

function doLogout() {
  ['wf_token','wf_user','wf_biz'].forEach(k => localStorage.removeItem(k));
  Object.assign(S, { token: null, user: null, businessId: '', perms: new Set() });
  document.getElementById('auth-screen').style.display = 'flex';
  document.getElementById('app-shell').style.display = 'none';
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOT
// ─────────────────────────────────────────────────────────────────────────────
async function bootApp() {
  document.getElementById('auth-screen').style.display = 'none';
  document.getElementById('app-shell').style.display = '';
  document.getElementById('user-email-disp').textContent = S.user.email;

  // Role label
  const demo = DEMO_EMAILS[S.user.email];
  document.getElementById('user-role-label').textContent =
    S.user.is_superadmin ? '⚡ Superadmin' : (demo ? demo.role : 'Member');

  // Superadmin nav
  setVis('nav-control', S.user.is_superadmin);
  setVis('biz-wrap', true);

  // Demo banner
  if (demo) {
    document.getElementById('demo-banner').style.display = '';
    document.getElementById('demo-banner-text').textContent = demo.desc;
  }

  // Load businesses
  await loadBusinessList();

  // Auto-select saved business or first match
  if (!S.businessId && S.businesses.length) {
    S.businessId = S.businesses[0].id;
    localStorage.setItem('wf_biz', S.businessId);
  }
  if (S.businessId) {
    document.getElementById('biz-selector').value = S.businessId;
    await loadPerms(S.businessId);
    updateBizBadge();
  }

  applyPermGates();
  renderPermsDisplay();
  restoreNavSections();
  await loadDashboard();
  nav('dashboard');
}

// ─────────────────────────────────────────────────────────────────────────────
// NAVIGATION
// ─────────────────────────────────────────────────────────────────────────────
const PAGE_TITLES = {
  dashboard:'Dashboard', 'ctrl-panel':'Control Panel',
  'ctrl-widgets':'Widget Editor', 'ctrl-perms':'Permissions Manager',
  'tenant-members':'Members', 'tenant-roles':'Roles & Permissions', 'tenant-locations':'Locations',
  'tenant-timesheets':'Timesheets', 'tenant-schedule':'Schedule Editor',
  'tenant-dashboard-admin':'Dashboard Admin',
  'tenant-job-postings':'Job Postings', 'tenant-shift-review':'Shift Requests',
  'tenant-swap-review':'Swap Requests', 'tenant-swap-rules':'Swap Permission Rules',
  'worker-hub':'My Work',
  'worker-messages':'Messages',
};

const PAGE_PERMS = {
  'tenant-members': 'members:read', 'tenant-roles': 'roles:read',
  'tenant-locations': 'locations:read', 'tenant-timesheets': 'timeclock:manage',
  'tenant-schedule': 'schedule:write', 'tenant-dashboard-admin': 'schedule:write',
  'tenant-job-postings': 'marketplace:manage', 'tenant-shift-review': 'marketplace:manage',
  'tenant-swap-review': 'schedule:write', 'tenant-swap-rules': 'schedule:write',
  'worker-hub': 'schedule:read',
  'worker-messages': 'messaging:read',
};

const LOADERS = {
  'ctrl-panel': loadCtrlPanel,
  'tenant-members': loadMembers, 'tenant-roles': loadRoles,
  'tenant-locations': loadLocations,
  'tenant-timesheets': () => { startLiveStatusPolling(); loadTimesheets(); },
  'tenant-schedule': loadScheduleEditor,
  'tenant-dashboard-admin': loadDashboardAdmin,
  'tenant-job-postings': loadTenantPostings, 'tenant-shift-review': loadTenantShiftRequests,
  'tenant-swap-review': loadTenantSwapRequests, 'tenant-swap-rules': loadSwapRules,
  'worker-hub': loadWorkerHub,
  'worker-messages': loadMessages,
  'worker-profile': loadMyProfile,
  'dashboard': loadDashboard,
};

function nav(name) {
  // Stop live-status polling when leaving timesheets
  if (name !== 'tenant-timesheets' && _liveInterval) {
    clearInterval(_liveInterval); _liveInterval = null;
  }

  // Check permission
  const requiredPerm = PAGE_PERMS[name];
  if (requiredPerm && !can(requiredPerm)) { name = 'no-access'; }

  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  const view = document.getElementById('view-' + name);
  if (view) view.classList.add('active');

  document.querySelectorAll('#sidebar .nav-link').forEach(a => a.classList.remove('active'));
  const link = document.querySelector(`#sidebar .nav-link[onclick*="'${name}'"]`);
  if (link) link.classList.add('active');

  document.getElementById('page-title').textContent = PAGE_TITLES[name] || name;
  if (LOADERS[name]) LOADERS[name]();
  return false;
}

function openModal(id) { new bootstrap.Modal(document.getElementById(id)).show(); }
function closeModal(id) { bootstrap.Modal.getInstance(document.getElementById(id))?.hide(); }

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS SELECTOR
// ─────────────────────────────────────────────────────────────────────────────
async function loadBusinessList() {
  S.businesses = [];
  const activeIds = new Set();
  if (S.user?.is_superadmin) {
    try {
      S.businesses = await api('GET', '/api/v1/control/businesses');
      S.businesses.forEach(b => activeIds.add(b.id));
    } catch(e) {}
  }
  // Also add businesses from memberships (skip any that the control API
  // already knows are soft-deleted)
  try {
    const mems = await api('GET', '/api/v1/worker/me/memberships');
    for (const m of mems) {
      // For superadmins: skip businesses not in the active set (they were deleted)
      if (S.user?.is_superadmin && !activeIds.has(m.business_id)) continue;
      if (!S.businesses.find(b => b.id === m.business_id)) {
        S.businesses.push({ id: m.business_id, name: m.business_id.slice(0,8) + '…' });
      }
    }
  } catch(e) {}

  const sel = document.getElementById('biz-selector');
  sel.innerHTML = '<option value="">— Select Business —</option>' +
    S.businesses.map(b => `<option value="${b.id}" ${b.id===S.businessId?'selected':''}>${b.name}</option>`).join('');
}

async function selectBusiness(id) {
  S.businessId = id;
  localStorage.setItem('wf_biz', id);
  _dirFiltersLoaded = false;  // reset directory filters on business change
  await loadPerms(id);
  await loadMyLocations();
  applyPermGates();
  renderPermsDisplay();
  updateBizBadge();
  // Refresh current view if it's business-scoped
  const active = document.querySelector('.view.active')?.id?.replace('view-','');
  if (active && LOADERS[active]) LOADERS[active]();
  if (!active || active === 'dashboard') loadDashboard();
}

function updateBizBadge() {
  const biz = S.businesses.find(b => b.id === S.businessId);
  const badge = document.getElementById('biz-badge');
  if (biz) { badge.textContent = biz.name; badge.style.display = ''; }
  else badge.style.display = 'none';
}

async function loadMyLocations() {
  S.myLocations = [];
  if (!S.businessId) return;
  try {
    const allLocs = await api('GET', `/api/v1/tenant/${S.businessId}/locations`);
    if (can('locations:read')) {
      // Managers / owners see all locations
      S.myLocations = allLocs;
    } else {
      // Workers: only locations they are assigned to (via primary_location_id)
      const mems = await api('GET', '/api/v1/worker/me/memberships');
      const myLocIds = new Set(mems
        .filter(m => m.business_id === S.businessId && m.primary_location_id)
        .map(m => m.primary_location_id));
      S.myLocations = allLocs.filter(l => myLocIds.has(l.id));
      // Fallback: if no primary location set, show all (graceful degradation)
      if (!S.myLocations.length) S.myLocations = allLocs;
    }
  } catch(_) {}
}

// ─────────────────────────────────────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────────────────────
// CONTROL PLANE
// ─────────────────────────────────────────────────────────────────────────────

const CTRL_TABS = ['businesses','users','agents','audit','widgets','perms'];
let _ctrlActiveTab = 'businesses';

function ctrlTab(tab, el) {
  _ctrlActiveTab = tab;
  document.querySelectorAll('#ctrl-panel-tabs .nav-link').forEach(l => l.classList.remove('active'));
  if (el) el.classList.add('active');
  CTRL_TABS.forEach(t => {
    const pane = document.getElementById(`ctrl-pane-${t}`);
    if (pane) pane.style.display = (t === tab) ? '' : 'none';
  });
  if      (tab === 'businesses') loadBusinesses();
  else if (tab === 'users')      loadUsers();
  else if (tab === 'agents')     loadAgents();
  else if (tab === 'audit')      loadAudit();
  else if (tab === 'widgets')    loadWidgetEditor();
  else if (tab === 'perms')      loadPermissionsManager();
}

async function loadCtrlPanel(tab) {
  if (tab && tab !== _ctrlActiveTab) _ctrlActiveTab = tab;
  const tabEl = document.getElementById(`ctrl-tab-${_ctrlActiveTab}`);
  ctrlTab(_ctrlActiveTab, tabEl);
  // Populate quick stats
  try {
    const [bizList, userList, agentList] = await Promise.all([
      api('GET','/api/v1/control/businesses'),
      api('GET','/api/v1/control/users'),
      api('GET','/api/v1/control/agents'),
    ]);
    document.getElementById('ctrl-stat-biz').textContent   = bizList.length ?? '—';
    document.getElementById('ctrl-stat-users').textContent  = userList.length ?? '—';
    document.getElementById('ctrl-stat-agents').textContent = agentList.length ?? '—';
  } catch(_) {}
}


  const tb = document.getElementById('biz-table');
  try {
    const rows = await api('GET', '/api/v1/control/businesses');
    tb.innerHTML = rows.length ? rows.map(b => `
      <tr><td><strong>${b.name}</strong></td>
      <td><span class="badge ${b.plan==='pro'?'bg-warning text-dark':b.plan==='starter'?'bg-info text-dark':'bg-secondary'}">${b.plan}</span></td>
      <td><small class="text-muted font-monospace">${b.id}</small></td>
      <td><button class="btn btn-sm btn-outline-primary" onclick="selectBusiness('${b.id}');nav('tenant-members')">Manage</button>
          <button class="btn btn-sm btn-outline-danger ms-1" onclick="deleteBusiness('${b.id}','${b.name}')">Delete</button></td></tr>`).join('')
      : '<tr><td colspan="4" class="empty-state py-4">No businesses yet</td></tr>';
  } catch(e) { tb.innerHTML = `<tr><td colspan="4" class="text-danger p-3">${e.detail||'Error loading'}</td></tr>`; }
}

async function createBusiness() {
  try {
    await api('POST', '/api/v1/control/businesses', { name: document.getElementById('nb-name').value, plan: document.getElementById('nb-plan').value });
    closeModal('modal-new-biz'); toast('Business created'); loadBusinesses(); loadBusinessList();
  } catch(e) { toast(e.detail||'Error', 'danger'); }
}

async function deleteBusiness(id, name) {
  showConfirm('Delete Business', `Delete "${name}"? This is a soft delete.`, 'Delete', 'btn-danger',
    async () => {
      try {
        await api('DELETE', `/api/v1/control/businesses/${id}`);
        toast('Deleted');
        // If the deleted business is currently selected, deselect it
        if (S.businessId === id) {
          S.businessId = '';
          localStorage.removeItem('wf_biz');
          S.perms = new Set();
          S.myLocations = [];
          applyPermGates();
          updateBizBadge();
        }
        loadBusinesses();
        loadBusinessList();
      } catch(e) { toast(e.detail||'Error','danger'); }
    });
}

async function loadUsers() {
  const tb = document.getElementById('users-table');
  try {
    const rows = await api('GET', '/api/v1/control/users');
    tb.innerHTML = rows.map(u => `
      <tr><td>${u.email}${DEMO_EMAILS[u.email]?` <span class="badge ms-1" style="background:#6366f1">${DEMO_EMAILS[u.email].role}</span>`:''}</td>
      <td>${u.is_superadmin?'<span class="badge bg-danger">Superadmin</span>':'<span class="badge bg-secondary">User</span>'}</td>
      <td><span class="badge ${u.status==='active'?'bg-success':u.status==='invited'?'bg-info text-dark':'bg-secondary'}">${u.status}</span></td>
      <td>${u.status==='active'?`<button class="btn btn-sm btn-outline-warning" onclick="setUserStatus('${u.id}','suspended')">Suspend</button>`:
           u.status==='suspended'?`<button class="btn btn-sm btn-outline-success" onclick="setUserStatus('${u.id}','active')">Activate</button>`:''}</td></tr>`).join('');
  } catch(e) { tb.innerHTML = `<tr><td colspan="4" class="text-danger p-3">${e.detail||'Error'}</td></tr>`; }
}

async function setUserStatus(id, status) {
  try { await api('PATCH', `/api/v1/control/users/${id}/status?status=${status}`); toast('Updated'); loadUsers(); } catch(e) { toast(e.detail||'Error','danger'); }
}

async function loadAgents() {
  const tb = document.getElementById('agents-table');
  try {
    const rows = await api('GET', '/api/v1/control/agents');
    tb.innerHTML = rows.length ? rows.map(a => `
      <tr><td><strong>${a.name}</strong></td>
      <td><span class="badge bg-secondary">${a.type}</span></td>
      <td><span class="badge ${a.status==='active'?'bg-success':'bg-danger'}">${a.status}</span></td>
      <td><small class="text-muted">${a.business_id?a.business_id.slice(0,8)+'…':'(platform)'}</small></td>
      <td><button class="btn btn-sm btn-outline-danger" onclick="revokeAgent('${a.id}','${a.name}')">Revoke</button></td></tr>`).join('')
      : '<tr><td colspan="5" class="empty-state py-4">No agents</td></tr>';
  } catch(e) { tb.innerHTML = `<tr><td colspan="5" class="text-danger p-3">${e.detail||'Error'}</td></tr>`; }
}

async function createAgent() {
  const scopes = document.getElementById('na-scopes').value.split(',').map(s=>s.trim()).filter(Boolean);
  const exp = document.getElementById('na-expires').value;
  try {
    const d = await api('POST', '/api/v1/control/agents', { name: document.getElementById('na-name').value, type: document.getElementById('na-type').value, scopes, expires_days: exp?parseInt(exp):null });
    closeModal('modal-new-agent');
    document.getElementById('apikey-display').textContent = d.api_key;
    openModal('modal-apikey');
    loadAgents();
  } catch(e) { toast(e.detail||'Error','danger'); }
}

async function revokeAgent(id, name) {
  showConfirm('Revoke Agent', `Revoke agent "${name}"? All API keys will stop working.`, 'Revoke', 'btn-danger',
    async () => { try { await api('DELETE', `/api/v1/control/agents/${id}`); toast('Revoked'); loadAgents(); } catch(e) { toast(e.detail||'Error','danger'); } });
}

function copyKey() { navigator.clipboard.writeText(document.getElementById('apikey-display').textContent); toast('Copied!'); }

async function loadAudit() {
  const tb = document.getElementById('audit-table');
  try {
    const rows = await api('GET', '/api/v1/control/audit?limit=50');
    tb.innerHTML = rows.length ? rows.map(e => `
      <tr><td><small class="text-muted">${new Date(e.created_at).toLocaleString()}</small></td>
      <td><span class="badge ${e.actor_type==='user'?'bg-primary':e.actor_type==='agent'?'bg-warning text-dark':'bg-secondary'}">${e.actor_type}</span></td>
      <td><strong>${e.action}</strong></td><td><code>${e.entity}</code></td>
      <td><small>${e.business_id?e.business_id.slice(0,8)+'…':'—'}</small></td>
      <td><small class="font-monospace text-muted">${(e.correlation_id||'').slice(0,8)}</small></td></tr>`).join('')
      : '<tr><td colspan="6" class="empty-state py-4">No events yet</td></tr>';
  } catch(e) { tb.innerHTML = `<tr><td colspan="6" class="text-danger p-3">${e.detail||'Error'}</td></tr>`; }
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT PLANE
// ─────────────────────────────────────────────────────────────────────────────
function requireBiz(tb, cols) {
  if (!S.businessId) {
    if(tb) tb.innerHTML=`<tr><td colspan="${cols}" class="text-warning p-3"><i class="bi bi-exclamation-triangle me-2"></i>Select a business from the sidebar</td></tr>`;
    return false;
  }
  return true;
}

let _dirData = [];

async function loadMembers() {
  if (!S.businessId) { document.getElementById('dir-results').innerHTML = '<div class="text-warning p-3"><i class="bi bi-exclamation-triangle me-2"></i>Select a business first</div>'; return; }

  // Populate filter dropdowns once
  await _populateDirFilters();

  const q          = document.getElementById('dir-q')?.value.trim() || '';
  const status     = document.getElementById('dir-status')?.value || '';
  const roleId     = document.getElementById('dir-role')?.value || '';
  const locationId = document.getElementById('dir-location')?.value || '';

  let url = `/api/v1/tenant/${S.businessId}/members?`;
  if (q)          url += `q=${encodeURIComponent(q)}&`;
  if (status)     url += `status=${status}&`;
  if (roleId)     url += `role_id=${roleId}&`;
  if (locationId) url += `location_id=${locationId}&`;

  try {
    _dirData = await api('GET', url);
    renderDirectory();
  } catch(e) {
    document.getElementById('dir-results').innerHTML = `<div class="text-danger p-3">${e.message||e.detail||'Error'}</div>`;
  }
}

let _dirFiltersLoaded = false;
async function _populateDirFilters() {
  if (_dirFiltersLoaded && document.getElementById('dir-role').options.length > 1) return;
  try {
    // Roles
    const roles = await api('GET', `/api/v1/tenant/${S.businessId}/roles`);
    const rSel = document.getElementById('dir-role');
    const prevRole = rSel.value;
    rSel.innerHTML = '<option value="">All Roles</option>' +
      roles.map(r => `<option value="${r.id}" ${r.id===prevRole?'selected':''}>${r.name}</option>`).join('');
    // Locations
    const lSel = document.getElementById('dir-location');
    const prevLoc = lSel.value;
    lSel.innerHTML = '<option value="">All Locations</option>' +
      S.myLocations.map(l => `<option value="${l.id}" ${l.id===prevLoc?'selected':''}>${l.name}</option>`).join('');
    _dirFiltersLoaded = true;
  } catch(e) {}
}

function renderDirectory() {
  const viewMode = document.getElementById('dir-view')?.value || 'cards';
  const data = _dirData;

  // Stats
  const counts = data.reduce((acc, m) => { acc[m.status] = (acc[m.status]||0)+1; return acc; }, {});
  const statColors = { active:'#10b981', invited:'#3b82f6', inactive:'#9ca3af', removed:'#ef4444' };
  document.getElementById('dir-stats').innerHTML = Object.entries(counts).map(([s,n]) => `
    <div class="col-auto">
      <div class="badge px-3 py-2 fs-6" style="background:${statColors[s]||'#6b7280'}20;color:${statColors[s]||'#6b7280'};border:1px solid ${statColors[s]||'#6b7280'}40">
        ${n} ${s}
      </div>
    </div>`).join('');

  if (!data.length) {
    document.getElementById('dir-results').innerHTML = '<div class="empty-state"><i class="bi bi-people"></i>No members match your filters</div>';
    return;
  }

  if (viewMode === 'cards') {
    document.getElementById('dir-results').innerHTML = `<div class="row g-3">${data.map(m => _memberCard(m)).join('')}</div>`;
  } else {
    document.getElementById('dir-results').innerHTML = _memberTable(data);
  }
}

const STATUS_COLOR = { active:'#10b981', invited:'#3b82f6', inactive:'#9ca3af', removed:'#ef4444' };
const STATUS_BG    = { active:'#f0fdf4', invited:'#eff6ff', inactive:'#f9fafb', removed:'#fff1f2' };

function _memberCard(m) {
  const initials = _profileInitials(m);
  const sc = STATUS_COLOR[m.status] || '#6b7280';
  const name = _profileDisplayName(m);
  const rolesHtml = m.roles.length
    ? m.roles.map(r => `<span class="badge me-1" style="background:#e0e7ff;color:#3730a3;font-size:.7rem">${r}</span>`).join('')
    : '<span class="text-muted" style="font-size:.75rem">No roles assigned</span>';
  return `
  <div class="col-md-6 col-lg-4">
    <div class="card h-100" style="border-left:4px solid ${sc}">
      <div class="card-body" style="cursor:pointer" onclick="openMemberProfile('${m.id}')">
        <div class="d-flex align-items-center gap-3 mb-2">
          <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
               style="width:42px;height:42px;background:${_avatarColor(m.email)};flex-shrink:0;font-size:.95rem">${initials}</div>
          <div class="overflow-hidden">
            <div class="fw-semibold text-truncate" style="font-size:.9rem" title="${m.email}">${name}</div>
            ${m.job_title ? `<div class="text-muted" style="font-size:.75rem">${m.job_title}</div>` : `<div class="text-muted" style="font-size:.75rem">${m.email}</div>`}
          </div>
        </div>
        <div class="d-flex flex-wrap gap-1 mb-2">
          <span class="badge" style="background:${sc}20;color:${sc}">${m.status}</span>
          ${rolesHtml}
        </div>
        <div class="text-muted" style="font-size:.72rem">
          ${m.phone ? `<i class="bi bi-telephone me-1"></i>${m.phone} ` : ''}
          ${m.primary_location_id ? `<i class="bi bi-geo-alt me-1"></i>${m.primary_location_id.slice(0,8)}` : ''}
          ${m.pay_rate ? `<i class="bi bi-currency-dollar ms-1"></i>${m.pay_rate}` : ''}
        </div>
      </div>
      ${can('members:write') ? `
      <div class="card-footer py-2 d-flex gap-1 justify-content-end flex-wrap">
        <button class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation();openMemberProfile('${m.id}',true)" title="Edit member"><i class="bi bi-pencil-square me-1"></i>Edit</button>
        ${m.status==='active'
          ? `<button class="btn btn-sm btn-outline-warning" onclick="event.stopPropagation();setMemberStatus('${m.id}','inactive')" title="Deactivate">Deactivate</button>`
          : m.status==='inactive'||m.status==='invited'
          ? `<button class="btn btn-sm btn-outline-success" onclick="event.stopPropagation();setMemberStatus('${m.id}','active')" title="Activate">Activate</button>`
          : ''}
        ${m.status!=='removed' ? `<button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation();removeMember('${m.id}')" title="Remove member"><i class="bi bi-person-x"></i></button>` : ''}
      </div>` : ''}
    </div>
  </div>`;
}

function _memberTable(data) {
  return `<div class="card"><div class="table-responsive"><table class="table table-hover table-sm mb-0">
    <thead><tr><th>Email</th><th>Status</th><th>Roles</th><th>Job Title</th><th>Location</th>${can('members:write')?'<th>Actions</th>':''}</tr></thead>
    <tbody>${data.map(m => {
      const sc = STATUS_COLOR[m.status]||'#6b7280';
      return `<tr>
        <td>
          <div class="d-flex align-items-center gap-2">
            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                 style="width:28px;height:28px;background:${sc};flex-shrink:0;font-size:.7rem">${(m.email||'?').slice(0,2).toUpperCase()}</div>
            <span style="font-size:.85rem">${m.email}</span>
          </div>
        </td>
        <td><span class="badge" style="background:${sc}20;color:${sc}">${m.status}</span></td>
        <td>${m.roles.map(r=>`<span class="badge me-1" style="background:#e0e7ff;color:#3730a3">${r}</span>`).join('')||'—'}</td>
        <td><small>${m.job_title||'—'}</small></td>
        <td><small class="text-muted">${m.primary_location_id||'—'}</small></td>
        ${can('members:write') ? `<td>
          <button class="btn btn-sm btn-outline-primary me-1" onclick="openMemberProfile('${m.id}',true)" title="Edit"><i class="bi bi-pencil-square"></i></button>
          ${m.status==='active'
          ? `<button class="btn btn-sm btn-outline-warning me-1" onclick="setMemberStatus('${m.id}','inactive')">Deactivate</button>`
          : m.status!=='removed'
          ? `<button class="btn btn-sm btn-outline-success me-1" onclick="setMemberStatus('${m.id}','active')">Activate</button>`
          : ''}
          ${m.status!=='removed' ? `<button class="btn btn-sm btn-outline-danger" onclick="removeMember('${m.id}')" title="Remove"><i class="bi bi-person-x"></i></button>` : ''}
        </td>` : ''}
      </tr>`;
    }).join('')}</tbody>
  </table></div></div>`;
}

async function inviteMember() {
  if (!S.businessId) { toast('Select a business first','warning'); return; }
  try {
    await api('POST', `/api/v1/tenant/${S.businessId}/members`, { email: document.getElementById('inv-email').value });
    closeModal('modal-invite'); toast('Invite sent'); _dirFiltersLoaded = false; loadMembers();
  } catch(e) { toast(e.detail||'Error','danger'); }
}

async function setMemberStatus(id, status) {
  try { await api('PATCH', `/api/v1/tenant/${S.businessId}/members/${id}/status?new_status=${status}`); toast('Updated'); loadMembers(); } catch(e) { toast(e.detail||'Error','danger'); }
}

async function removeMember(id) {
  if (!confirm('Remove this member from the business? They will lose access but their data will be retained.')) return;
  try { await api('PATCH', `/api/v1/tenant/${S.businessId}/members/${id}/remove`); toast('Member removed'); loadMembers(); } catch(e) { toast(e.detail||e.message||'Error','danger'); }
}

async function loadRoles() {
  const tb = document.getElementById('roles-table');
  if (!requireBiz(tb, 3)) return;
  try {
    const rows = await api('GET', `/api/v1/tenant/${S.businessId}/roles`);
    tb.innerHTML = rows.length ? rows.map(r => `
      <tr><td><strong>${r.name}</strong>${r.is_system_template?' <span class="badge bg-warning text-dark ms-1">System</span>':''}</td>
      <td id="role-perms-${r.id}"><span class="text-muted small">Loading…</span></td>
      <td>${can('roles:write')?`<button class="btn btn-sm btn-outline-primary" onclick="addPermModal('${r.id}','${r.name}')"><i class="bi bi-shield-plus me-1"></i>Add Perm</button>`:'<span class="text-muted small">Read-only</span>'}</td></tr>`).join('')
      : '<tr><td colspan="3" class="empty-state py-4">No roles yet</td></tr>';
    rows.forEach(r => loadRolePerms(r.id));
  } catch(e) { tb.innerHTML = `<tr><td colspan="3" class="text-danger p-3">${e.detail||'Error'}</td></tr>`; }

  // Show API key section for messaging managers
  const akSection = document.getElementById('msg-apikey-section');
  if (akSection) {
    const show = can('messaging:manage');
    akSection.style.display = show ? '' : 'none';
    if (show) loadMsgApiKeys();
  }
}

async function loadRolePerms(roleId) {
  // Re-use the permissions table to show perms — just show stored permissions from the perm badge display
  // Since we don't have a dedicated route, show what's seeded
  const el = document.getElementById(`role-perms-${roleId}`);
  if (!el) return;
  // We'll just note this via a placeholder since we don't have a GET /roles/{id}/permissions endpoint yet
  el.innerHTML = '<span class="text-muted small fst-italic">see /docs for details</span>';
}

async function createRole() {
  if (!S.businessId) { toast('Select a business first','warning'); return; }
  try {
    await api('POST', `/api/v1/tenant/${S.businessId}/roles`, { name: document.getElementById('nr-name').value });
    closeModal('modal-new-role'); toast('Role created'); loadRoles();
  } catch(e) { toast(e.detail||'Error','danger'); }
}

function addPermModal(roleId, roleName) {
  _permRoleId = roleId;
  document.getElementById('perm-role-name').textContent = roleName;
  document.querySelectorAll('.perm-cb').forEach(cb => cb.checked = false);
  document.getElementById('perm-custom').value = '';
  openModal('modal-add-perm');
}

let _permRoleId = null;
async function submitAddPerms() {
  const checked = [...document.querySelectorAll('.perm-cb:checked')].map(cb => cb.value);
  const custom = document.getElementById('perm-custom').value.trim();
  if (custom) checked.push(custom);
  if (!checked.length) { toast('Select at least one permission', 'danger'); return; }
  closeModal('modal-add-perm');
  for (const key of checked) await addPerm(_permRoleId, key);
}

async function addPerm(roleId, key) {
  try {
    await api('POST', `/api/v1/tenant/${S.businessId}/roles/${roleId}/permissions?permission_key=${encodeURIComponent(key)}`);
    toast(`"${key}" added to role`); loadRoles();
  } catch(e) { toast(e.detail||'Error','danger'); }
}

async function loadLocations() {
  const tb = document.getElementById('locations-table');
  if (!requireBiz(tb, 3)) return;
  try {
    const rows = await api('GET', `/api/v1/tenant/${S.businessId}/locations`);
    tb.innerHTML = rows.length ? rows.map(l => `
      <tr><td><strong>${l.name}</strong></td><td>${l.timezone}</td>
      <td><small class="font-monospace text-muted">${l.id}</small></td></tr>`).join('')
      : '<tr><td colspan="3" class="empty-state py-4">No locations yet</td></tr>';
  } catch(e) { tb.innerHTML = `<tr><td colspan="3" class="text-danger p-3">${e.detail||'Error'}</td></tr>`; }
}

async function createLocation() {
  if (!S.businessId) { toast('Select a business first','warning'); return; }
  try {
    await api('POST', `/api/v1/tenant/${S.businessId}/locations`, { name: document.getElementById('nl-name').value, timezone: document.getElementById('nl-tz').value });
    closeModal('modal-new-loc'); toast('Location created'); loadLocations();
  } catch(e) { toast(e.detail||'Error','danger'); }
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKER PLANE
// ─────────────────────────────────────────────────────────────────────────────
const DAYS = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];

// ── Worker Hub (merged tabbed view) ──────────────────────────────────────────

let _hubActiveTab = 'schedule';

function hubTab(tab, el) {
  _hubActiveTab = tab;
  document.querySelectorAll('#worker-hub-tabs .nav-link').forEach(l => l.classList.remove('active'));
  if (el) el.classList.add('active');
  ['schedule','availability','jobboard','requests'].forEach(t => {
    const pane = document.getElementById(`hub-pane-${t}`);
    if (pane) pane.style.display = (t === tab) ? '' : 'none';
  });
  if (tab === 'schedule')     loadSchedule();
  else if (tab === 'availability') loadAvailability();
  else if (tab === 'jobboard')     loadJobBoard();
  else if (tab === 'requests')     loadMyRequests();
}

async function loadWorkerHub(tab) {
  // If called with a specific tab (e.g. from a link), switch to it
  if (tab && tab !== _hubActiveTab) {
    _hubActiveTab = tab;
  }
  // Activate the correct tab button
  const tabEl = document.querySelector(`#worker-hub-tabs .nav-link[onclick*="'${_hubActiveTab}'"]`);
  hubTab(_hubActiveTab, tabEl);
}

// Allow deep-linking into a specific hub tab from elsewhere in the app
function navToHubTab(tab) {
  _hubActiveTab = tab;
  nav('worker-hub');
}

async function loadSchedule() {
  const el = document.getElementById('schedule-content');
  if (!S.businessId) { el.innerHTML = '<div class="empty-state"><i class="bi bi-building-x"></i>Select a business to view your schedule</div>'; return; }
  try {
    const shifts = await api('GET', `/api/v1/worker/me/schedule/${S.businessId}`);
    if (!shifts.length) { el.innerHTML = '<div class="empty-state"><i class="bi bi-calendar-x"></i>No shifts assigned yet</div>'; return; }
    const now = Date.now();
    const upcoming = shifts.filter(s => new Date(s.start_ts).getTime() > now);
    const past     = shifts.filter(s => new Date(s.start_ts).getTime() <= now);
    const renderRows = arr => arr.map(s => {
      const start = new Date(s.start_ts), end = new Date(s.end_ts);
      const isFuture = start.getTime() > now;
      const statusColor = s.shift_status === 'published' ? 'success' : s.shift_status === 'cancelled' ? 'secondary' : 'warning';
      return `<tr style="${!isFuture ? 'opacity:.55' : ''}">
        <td><div class="fw-semibold">${_escHtml(s.title||'Shift')}</div>${s.role_name ? `<div class="text-muted small">${_escHtml(s.role_name)}</div>` : ''}</td>
        <td>${start.toLocaleDateString('en',{weekday:'short',month:'short',day:'numeric'})}<br><span class="text-muted small">${start.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit'})}</span></td>
        <td>${end.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit'})}</td>
        <td><span class="badge bg-${statusColor}">${s.shift_status||s.status}</span></td>
      </tr>`;
    }).join('');
    el.innerHTML = `<div class="table-responsive"><table class="table mb-0">
      <thead><tr><th>Shift</th><th>Date</th><th>End</th><th>Status</th></tr></thead>
      <tbody>
        ${upcoming.length ? renderRows(upcoming) : '<tr><td colspan="4" class="text-muted text-center small py-3">No upcoming shifts</td></tr>'}
        ${past.length ? `<tr><td colspan="4" class="text-muted small py-2" style="background:#f8fafc">Past shifts</td></tr>${renderRows(past)}` : ''}
      </tbody>
    </table></div>`;
  } catch(e) { el.innerHTML = `<div class="text-danger p-3">${e.detail||'Error loading schedule'}</div>`; }
}

async function loadAvailability() {
  const el = document.getElementById('av-list');
  if (!el) return;
  if (!S.businessId) { el.innerHTML = '<div class="empty-state"><i class="bi bi-building-x"></i>Select a business first</div>'; return; }
  try {
    const rows = await api('GET', `/api/v1/worker/me/availability/${S.businessId}`);
    el.innerHTML = rows.length
      ? rows.map(a=>`
          <div class="d-flex align-items-center gap-3 py-2 border-bottom">
            <span class="badge bg-primary" style="min-width:90px">${DAYS[a.day_of_week]}</span>
            <span class="flex-grow-1">${a.start_hour}:00 – ${a.end_hour}:00</span>
            <button class="btn btn-sm btn-outline-danger py-0 px-1" style="font-size:.75rem" onclick="availDelete('${a.id}','standalone')">
              <i class="bi bi-x"></i>
            </button>
          </div>`).join('')
      : '<div class="empty-state"><i class="bi bi-clock-history"></i>No availability set yet</div>';
  } catch(e) { el.innerHTML = `<div class="text-danger">${e.detail||'Error'}</div>`; }
}

async function saveAvailability() {
  await availSave('av-day','av-start','av-end','av-list');
}

// ─────────────────────────────────────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────────────────────────────────────
(async () => {
  if (S.token && S.user) {
    try {
      S.user = await api('GET', '/api/v1/auth/me');
      localStorage.setItem('wf_user', JSON.stringify(S.user));
      await bootApp();
    } catch(e) { doLogout(); }
  }
})();

// ── TIMECLOCK ──────────────────────────────────────────────────────────────────

function fmtMs(ms) {
  const s = Math.floor(ms / 1000);
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
}
function fmtMins(mins) {
  if (!mins) return '0m';
  const h = Math.floor(mins / 60), m = Math.round(mins % 60);
  return h > 0 ? `${h}h ${m}m` : `${m}m`;
}

// ── TIMESHEETS (tenant) ────────────────────────────────────────────────────────

async function loadTimesheets() {
  loadLiveStatus();   // always refresh the live panel too
  const statusEl = document.getElementById('ts-filter-status');
  const status = statusEl ? statusEl.value : '';
  try {
    const url = `/api/v1/tenant/${S.businessId}/timeclock` + (status ? `?status=${status}` : '');
    const rows = await api('GET', url);

    // Build a user_id → email map from live status cache if available
    const emailOf = uid => (_liveUserEmails[uid] || uid.slice(0,8) + '…');

    const html = rows.length ? `<div class="table-responsive"><table class="table table-sm table-hover mb-0">
      <thead><tr><th>Employee</th><th>Clock In</th><th>Clock Out</th><th>Duration</th><th>Status</th><th>Notes</th><th>Actions</th></tr></thead>
      <tbody>${rows.map(e => {
        const cinStr = e.clocked_in_at;
        const cin = new Date(cinStr.endsWith('Z') ? cinStr : cinStr + 'Z');
        let coutDisp = '<span class="badge bg-success">Active</span>';
        if (e.clocked_out_at) {
          const cs = e.clocked_out_at;
          coutDisp = new Date(cs.endsWith('Z') ? cs : cs + 'Z').toLocaleTimeString();
        }
        const canReview = e.status !== 'active';
        return `<tr>
          <td><span title="${e.user_id}" style="font-size:.8rem">${emailOf(e.user_id)}</span></td>
          <td>${cin.toLocaleDateString()} ${cin.toLocaleTimeString()}</td>
          <td>${coutDisp}</td>
          <td>${fmtMins(e.total_minutes)}</td>
          <td><span class="badge ${
            e.status==='active'?'bg-success':e.status==='approved'?'bg-primary':e.status==='disputed'?'bg-danger':'bg-secondary'
          }">${e.status}</span></td>
          <td><small>${e.notes||''}</small></td>
          <td>${canReview ? `
            <button class="btn btn-outline-primary me-1" style="font-size:.7rem;padding:2px 6px" onclick="reviewEntry('${e.id}','approved')">✓</button>
            <button class="btn btn-outline-danger" style="font-size:.7rem;padding:2px 6px" onclick="reviewEntry('${e.id}','disputed')">✗</button>
          ` : ''}</td>
        </tr>`;
      }).join('')}</tbody></table></div>`
      : '<div class="empty-state"><i class="bi bi-clock-history"></i>No entries found</div>';
    document.getElementById('ts-list').innerHTML = html;
  } catch(e) { document.getElementById('ts-list').innerHTML = `<div class="text-danger p-3">${e.message}</div>`; }
}

// Live status panel ────────────────────────────────────────────────────────────

let _liveUserEmails = {};   // user_id → email cache for the whole timesheets view
let _liveInterval = null;

async function loadLiveStatus() {
  try {
    const data = await api('GET', `/api/v1/tenant/${S.businessId}/timeclock/live`);

    // Cache emails for use in the entries table
    data.clocked_in.forEach(e => { _liveUserEmails[e.user_id] = e.email; });
    data.expected.forEach(e => { _liveUserEmails[e.user_id] = e.email; });

    // Clocked-in list (green)
    const ci = data.clocked_in;
    document.getElementById('live-clocked-count').textContent = ci.length;
    document.getElementById('live-clocked-list').innerHTML = ci.length
      ? ci.map(e => {
          const h = Math.floor(e.elapsed_minutes / 60);
          const m = Math.round(e.elapsed_minutes % 60);
          const elapsed = h > 0 ? `${h}h ${m}m` : `${m}m`;
          return `<div class="d-flex justify-content-between align-items-center py-1 px-2 rounded mb-1" style="background:#f0fdf4">
            <div>
              <i class="bi bi-circle-fill me-2" style="color:#10b981;font-size:.55rem"></i>
              <span class="fw-semibold" style="color:#065f46;font-size:.85rem">${e.email}</span>
              ${e.notes ? `<span class="text-muted ms-1" style="font-size:.7rem">— ${e.notes}</span>` : ''}
            </div>
            <span class="badge" style="background:#d1fae5;color:#065f46">${elapsed}</span>
          </div>`;
        }).join('')
      : '<div class="text-muted small p-2">No one clocked in right now</div>';

    // Expected but missing (red)
    const ex = data.expected;
    document.getElementById('live-expected-count').textContent = ex.length;
    document.getElementById('live-expected-list').innerHTML = ex.length
      ? ex.map(e => `
          <div class="d-flex justify-content-between align-items-center py-1 px-2 rounded mb-1" style="background:#fff1f2">
            <div>
              <i class="bi bi-exclamation-circle-fill me-2" style="color:#ef4444;font-size:.75rem"></i>
              <span class="fw-semibold" style="color:#991b1b;font-size:.85rem">${e.email}</span>
              ${e.role_name ? `<span class="text-muted ms-1" style="font-size:.7rem">${e.role_name}</span>` : ''}
            </div>
            <span class="badge" style="background:#fee2e2;color:#991b1b">${e.shift_start||''}–${e.shift_end||''}</span>
          </div>`).join('')
      : '<div class="text-muted small p-2">All scheduled employees are clocked in</div>';

  } catch(e) {
    document.getElementById('live-clocked-list').innerHTML = `<div class="text-danger small p-2">${e.message}</div>`;
  }
}

function startLiveStatusPolling() {
  if (_liveInterval) clearInterval(_liveInterval);
  loadLiveStatus();
  _liveInterval = setInterval(loadLiveStatus, 30000);  // refresh every 30s
}


async function reviewEntry(entryId, status) {
  try {
    await api('PATCH', `/api/v1/tenant/${S.businessId}/timeclock/${entryId}`, { status });
    loadTimesheets();
  } catch(e) { alert(e.message); }
}

async function loadTimesheetSummary() {
  const card = document.getElementById('ts-summary-card');
  if (card) card.style.display = '';
  try {
    const rows = await api('GET', `/api/v1/tenant/${S.businessId}/timeclock/summary`);
    const html = rows.length ? `<div class="table-responsive"><table class="table table-sm mb-0">
      <thead><tr><th>User ID</th><th>Total Minutes</th><th>Total Hours</th></tr></thead>
      <tbody>${rows.map(r => `<tr>
        <td><small class="text-muted">${r.user_id.slice(0,8)}</small></td>
        <td>${r.total_minutes}</td>
        <td class="fw-semibold">${r.total_hours}h</td>
      </tr>`).join('')}</tbody></table></div>`
      : '<div class="empty-state"><i class="bi bi-bar-chart"></i>No completed entries yet</div>';
    document.getElementById('ts-summary').innerHTML = html;
  } catch(e) { document.getElementById('ts-summary').innerHTML = `<div class="text-danger p-3">${e.message}</div>`; }
}

// ── SHARED CONFIRM + DENY MODALS ──────────────────────────────────────────────

let _confirmCb = null;
function showConfirm(title, msg, okLabel, okClass, cb) {
  _confirmCb = cb;
  document.getElementById('confirm-title').textContent = title;
  document.getElementById('confirm-msg').textContent = msg;
  const btn = document.getElementById('confirm-ok-btn');
  btn.textContent = okLabel;
  btn.className = `btn btn-sm ${okClass}`;
  openModal('modal-confirm');
}
function confirmOk() {
  closeModal('modal-confirm');
  if (_confirmCb) { _confirmCb(); _confirmCb = null; }
}

let _denyTarget = null;   // { type: 'shift'|'swap', id }
function showDenyModal(type, id) {
  _denyTarget = { type, id };
  document.getElementById('deny-modal-title').textContent =
    type === 'shift' ? 'Deny Shift Request' : 'Deny Swap Request';
  document.querySelectorAll('input[name="deny-reason-radio"]').forEach(r => r.checked = false);
  document.getElementById('deny-note-text').value = '';
  openModal('modal-deny');
}
async function submitDeny() {
  const radio = document.querySelector('input[name="deny-reason-radio"]:checked');
  const custom = document.getElementById('deny-note-text').value.trim();
  let note = null;
  if (radio && radio.value !== '__other__') {
    note = radio.value + (custom ? ` — ${custom}` : '');
  } else {
    note = custom || null;
  }
  closeModal('modal-deny');
  if (!_denyTarget) return;
  try {
    if (_denyTarget.type === 'shift') {
      await api('PATCH', `/api/v1/tenant/${S.businessId}/marketplace/shift-requests/${_denyTarget.id}`, { status: 'denied', review_note: note });
      toast('Request denied'); loadTenantShiftRequests();
    } else {
      await api('PATCH', `/api/v1/tenant/${S.businessId}/marketplace/swap-requests/${_denyTarget.id}`, { status: 'denied', review_note: note });
      toast('Swap denied'); loadTenantSwapRequests();
    }
  } catch(e) { toast(e.message,'danger'); }
  _denyTarget = null;
}


const STATUS_BADGE = {
  pending:'<span class="badge bg-warning text-dark">Pending</span>',
  approved:'<span class="badge bg-success">Approved</span>',
  denied:'<span class="badge bg-danger">Denied</span>',
  withdrawn:'<span class="badge bg-secondary">Withdrawn</span>',
  auto_approved:'<span class="badge bg-primary">Auto-Approved</span>',
  awaiting_peer:'<span class="badge bg-info text-dark">Awaiting Peer</span>',
  pending_coverage:'<span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Pending Coverage</span>',
  completed:'<span class="badge bg-success"><i class="bi bi-check2-all me-1"></i>Completed</span>',
  open:'<span class="badge bg-success">Open</span>',
  filled:'<span class="badge bg-primary">Filled</span>',
  cancelled:'<span class="badge bg-secondary">Cancelled</span>',
};

// JOB BOARD (worker view) ──────────────────────────────────────────────────────

async function loadJobBoard() {
  const q = document.getElementById('jb-q')?.value || '';
  const date = document.getElementById('jb-date')?.value || '';
  const role = document.getElementById('jb-role')?.value || '';
  let url = `/api/v1/marketplace/postings?business_id=${S.businessId}`;
  if (q) url += `&q=${encodeURIComponent(q)}`;
  if (date) url += `&shift_date=${date}`;
  if (role) url += `&role_name=${encodeURIComponent(role)}`;
  try {
    // Load postings + user's existing requests in parallel
    const [rows, myReqs] = await Promise.all([
      api('GET', url),
      api('GET', `/api/v1/worker/me/marketplace/${S.businessId}/shift-requests`).catch(() => []),
    ]);
    // Build set of posting IDs the worker already has a pending/approved request for
    const appliedIds = new Set(
      myReqs.filter(r => r.status === 'pending' || r.status === 'approved').map(r => r.posting_id)
    );

    const el = document.getElementById('jb-results');
    if (!rows.length) { el.innerHTML = '<div class="col-12 empty-state"><i class="bi bi-briefcase"></i>No open postings found</div>'; return; }
    el.innerHTML = rows.map(p => {
      const applied = appliedIds.has(p.id);
      const applyBtn = applied
        ? `<button class="btn btn-sm btn-secondary w-100" disabled><i class="bi bi-check-circle me-1"></i>Applied</button>`
        : `<button class="btn btn-sm btn-accent w-100" onclick="applyToPosting('${p.id}',${JSON.stringify(p.title)},${JSON.stringify(p.role_name||'')},${JSON.stringify(p.shift_date||'')},${JSON.stringify(p.shift_start||'')},${JSON.stringify(p.pay_rate||'')})">
             <i class="bi bi-send me-1"></i>Apply for this Shift
           </button>`;
      return `
      <div class="col-md-6 col-lg-4">
        <div class="card h-100${applied ? ' border-success border-opacity-50' : ''}">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <h6 class="mb-0 fw-semibold">${p.title}</h6>
              ${applied ? '<span class="badge bg-success"><i class="bi bi-check me-1"></i>Applied</span>' : (STATUS_BADGE[p.status]||'')}
            </div>
            ${p.role_name ? `<div class="badge bg-light text-dark mb-2">${p.role_name}</div>` : ''}
            ${p.description ? `<p class="small text-muted mb-2">${p.description}</p>` : ''}
            <div class="small text-muted mb-1">
              ${p.shift_date ? `<i class="bi bi-calendar me-1"></i>${p.shift_date}` : ''}
              ${p.shift_start ? ` ${p.shift_start}–${p.shift_end||'?'}` : ''}
            </div>
            ${p.pay_rate ? `<div class="small fw-semibold text-success"><i class="bi bi-currency-dollar"></i>${p.pay_rate}</div>` : ''}
            ${p.tags ? `<div class="mt-1">${p.tags.split(',').map(t=>`<span class="badge bg-light text-dark me-1">${t.trim()}</span>`).join('')}</div>` : ''}
            <div class="mt-2 text-muted" style="font-size:.7rem">${p.slots} slot(s) available</div>
          </div>
          <div class="card-footer">${applyBtn}</div>
        </div>
      </div>`;
    }).join('');
  } catch(e) { document.getElementById('jb-results').innerHTML = `<div class="col-12 text-danger">${e.message}</div>`; }
}

let _applyPostingId = null;
function applyToPosting(postingId, title, role, date, start, pay) {
  _applyPostingId = postingId;
  document.getElementById('apply-posting-summary').innerHTML =
    `<strong>${title}</strong>${role ? ` · <span class="badge bg-light text-dark">${role}</span>` : ''}` +
    `${date ? `<br><i class="bi bi-calendar me-1"></i>${date}${start ? ' ' + start : ''}` : ''}` +
    `${pay ? `<br><i class="bi bi-currency-dollar"></i>${pay}` : ''}`;
  document.getElementById('apply-msg').value = '';
  openModal('modal-apply-posting');
}

async function submitApply() {
  const msg = document.getElementById('apply-msg').value.trim() || null;
  closeModal('modal-apply-posting');
  try {
    await api('POST', `/api/v1/worker/me/marketplace/${S.businessId}/shift-requests/${_applyPostingId}`, { message: msg });
    toast('Application submitted!');
    loadJobBoard();
  } catch(e) { toast(e.message, 'danger'); }
}

// MY REQUESTS (worker view) ────────────────────────────────────────────────────

let _activeReqTab = 'shift-reqs';
function showReqTab(tab) {
  ['shift-reqs','training-reqs','swap-reqs'].forEach(t => {
    const el = document.getElementById(`req-tab-${t}`);
    if (el) el.style.display = t === tab ? '' : 'none';
  });
  document.querySelectorAll('#req-tabs .nav-link').forEach((a,i) => {
    a.classList.toggle('active', ['shift-reqs','training-reqs','swap-reqs'][i] === tab);
  });
  _activeReqTab = tab;
  if (tab === 'shift-reqs') loadMyShiftRequests();
  if (tab === 'training-reqs') loadMyTrainingRequests();
  if (tab === 'swap-reqs') loadMySwapRequests();
}

async function loadMyRequests() {
  showReqTab('shift-reqs');
}

async function loadMyShiftRequests() {
  try {
    const rows = await api('GET', `/api/v1/worker/me/marketplace/${S.businessId}/shift-requests`);
    const el = document.getElementById('my-shift-reqs');
    el.innerHTML = rows.length ? rows.map(r => `
      <div class="d-flex justify-content-between align-items-center border-bottom py-2 px-1">
        <div>
          <div class="fw-semibold small">${r.posting_id.slice(0,8)}</div>
          ${r.message ? `<div class="text-muted" style="font-size:.75rem">${r.message}</div>` : ''}
          <div class="text-muted" style="font-size:.7rem">${new Date(r.created_at).toLocaleDateString()}</div>
        </div>
        <div class="d-flex align-items-center gap-2">
          ${STATUS_BADGE[r.status]||''}
          ${r.status==='pending' ? `<button class="btn btn-sm btn-outline-secondary" onclick="withdrawShiftReq('${r.id}')"><i class="bi bi-x"></i></button>` : ''}
        </div>
      </div>`).join('')
      : '<div class="empty-state"><i class="bi bi-inbox"></i>No shift requests yet</div>';
  } catch(e) {}
}

async function withdrawShiftReq(id) {
  showConfirm('Withdraw Application', 'Withdraw your application for this shift?', 'Withdraw', 'btn-warning',
    async () => {
      try { await api('DELETE', `/api/v1/worker/me/marketplace/${S.businessId}/shift-requests/${id}`); loadMyShiftRequests(); }
      catch(e) { toast(e.message,'danger'); }
    });
}

async function loadMyTrainingRequests() {
  try {
    const rows = await api('GET', `/api/v1/worker/me/marketplace/${S.businessId}/training-requests`);
    const el = document.getElementById('my-training-reqs');
    el.innerHTML = rows.length ? rows.map(r => `
      <div class="d-flex justify-content-between align-items-center border-bottom py-2 px-1">
        <div>
          <div class="fw-semibold small">${r.skill_name}</div>
          ${r.notes ? `<div class="text-muted" style="font-size:.75rem">${r.notes}</div>` : ''}
          <div class="text-muted" style="font-size:.7rem">${new Date(r.created_at).toLocaleDateString()}</div>
        </div>
        ${STATUS_BADGE[r.status]||''}
      </div>`).join('')
      : '<div class="empty-state mt-2"><i class="bi bi-mortarboard"></i>No training requests yet</div>';
  } catch(e) {}
}

async function submitTrainingRequest() {
  const skill = document.getElementById('tr-skill').value.trim();
  if (!skill) { toast('Skill name required','danger'); return; }
  try {
    await api('POST', `/api/v1/worker/me/marketplace/${S.businessId}/training-requests`, {
      skill_name: skill, notes: document.getElementById('tr-notes').value.trim() || null,
    });
    document.getElementById('tr-skill').value = '';
    document.getElementById('tr-notes').value = '';
    toast('Training request submitted!');
    loadMyTrainingRequests();
  } catch(e) { toast(e.message,'danger'); }
}

async function loadMySwapRequests() {
  try {
    const rows = await api('GET', `/api/v1/worker/me/marketplace/${S.businessId}/swap-requests`);
    const el = document.getElementById('my-swap-reqs');
    const DAYS_SHORT = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
    el.innerHTML = rows.length ? rows.map(r => {
      const isPeer = r.peer_worker_id === S.user?.id && r.status === 'pending';
      return `<div class="border rounded p-2 mb-2">
        <div class="d-flex justify-content-between">
          <div>
            <div class="fw-semibold small">My shift: ${r.their_shift_date||'—'} ${r.their_shift_start||''}</div>
            ${r.peer_shift_date ? `<div class="text-muted" style="font-size:.75rem">↔ ${r.peer_shift_date} ${r.peer_shift_start||''}</div>` : '<div class="text-muted" style="font-size:.75rem">Open offer</div>'}
            ${r.message ? `<div class="text-muted" style="font-size:.7rem">${r.message}</div>` : ''}
          </div>
          <div class="text-end">
            ${STATUS_BADGE[r.status]||''}
            ${r.status==='pending_coverage' ? `<div class="text-muted" style="font-size:.7rem;max-width:150px" class="text-end">Your manager is arranging coverage</div>` : ''}
            ${r.status==='completed' ? `<div class="text-success" style="font-size:.7rem">Shift covered ✓</div>` : ''}
            ${r.status==='pending' && r.initiator_id===S.user?.id ? `<br><button class="btn btn-xs btn-outline-secondary mt-1" style="font-size:.7rem;padding:2px 6px" onclick="withdrawSwap('${r.id}')">Withdraw</button>` : ''}
            ${isPeer ? `<br><button class="btn btn-xs btn-outline-success mt-1 me-1" style="font-size:.7rem;padding:2px 6px" onclick="respondSwap('${r.id}',true)">Accept</button><button class="btn btn-xs btn-outline-danger mt-1" style="font-size:.7rem;padding:2px 6px" onclick="respondSwap('${r.id}',false)">Decline</button>` : ''}
          </div>
        </div>
      </div>`;
    }).join('')
      : '<div class="empty-state"><i class="bi bi-arrow-left-right"></i>No swap requests yet</div>';
  } catch(e) {}
}

async function submitSwapRequest() {
  try {
    await api('POST', `/api/v1/worker/me/marketplace/${S.businessId}/swap-requests`, {
      their_shift_date:  document.getElementById('sw-my-date').value || null,
      their_shift_start: document.getElementById('sw-my-start').value || null,
      their_shift_end:   document.getElementById('sw-my-end').value || null,
      peer_worker_id:    document.getElementById('sw-peer-id').value || null,
      peer_shift_date:   document.getElementById('sw-peer-date').value || null,
      peer_shift_start:  document.getElementById('sw-peer-start').value || null,
      peer_shift_end:    document.getElementById('sw-peer-end').value || null,
      message:           document.getElementById('sw-msg').value || null,
    });
    toast('Swap request submitted!');
    loadMySwapRequests();
  } catch(e) { toast(e.message,'danger'); }
}

async function respondSwap(id, accept) {
  try {
    await api('POST', `/api/v1/worker/me/marketplace/${S.businessId}/swap-requests/${id}/respond?accept=${accept}`);
    toast(accept ? 'Swap accepted' : 'Swap declined');
    loadMySwapRequests();
  } catch(e) { toast(e.message,'danger'); }
}

async function withdrawSwap(id) {
  showConfirm('Withdraw Swap', 'Withdraw this swap request?', 'Withdraw', 'btn-warning',
    async () => {
      try { await api('DELETE', `/api/v1/worker/me/marketplace/${S.businessId}/swap-requests/${id}`); loadMySwapRequests(); }
      catch(e) { toast(e.message,'danger'); }
    });
}

function openQuickSwap(shiftId, title, startIso, endIso) {
  const start = new Date(startIso);
  const end   = new Date(endIso);
  const dateStr  = start.toLocaleDateString('en', {weekday:'long', month:'short', day:'numeric'});
  const timeStr  = start.toLocaleTimeString('en', {hour:'2-digit', minute:'2-digit'}) +
                   ' – ' + end.toLocaleTimeString('en', {hour:'2-digit', minute:'2-digit'});
  document.getElementById('qswap-shift-label').textContent = title || 'Shift';
  document.getElementById('qswap-shift-time').textContent  = `${dateStr} · ${timeStr}`;
  document.getElementById('qswap-date').value  = start.toISOString().slice(0,10);
  document.getElementById('qswap-start').value = start.toTimeString().slice(0,5);
  document.getElementById('qswap-end').value   = end.toTimeString().slice(0,5);
  document.getElementById('qswap-ref').value   = shiftId;
  document.getElementById('qswap-msg').value   = '';
  openModal('modal-quick-swap');
}

async function submitQuickSwap() {
  try {
    await api('POST', `/api/v1/worker/me/marketplace/${S.businessId}/swap-requests`, {
      their_shift_date:  document.getElementById('qswap-date').value  || null,
      their_shift_start: document.getElementById('qswap-start').value || null,
      their_shift_end:   document.getElementById('qswap-end').value   || null,
      message:           document.getElementById('qswap-msg').value   || null,
    });
    closeModal('modal-quick-swap');
    toast('Swap request submitted!');
  } catch(e) { toast(e.message || 'Failed to submit swap request', 'danger'); }
}

// TENANT: JOB POSTINGS ─────────────────────────────────────────────────────────

async function loadTenantPostings() {
  const status = document.getElementById('jp-filter')?.value || '';
  try {
    const url = `/api/v1/tenant/${S.businessId}/marketplace/postings` + (status ? `?status=${status}` : '');
    const rows = await api('GET', url);
    const el = document.getElementById('tenant-postings-list');
    el.innerHTML = rows.length ? rows.map(p => `
      <div class="card mb-2">
        <div class="card-body py-2">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <span class="fw-semibold">${p.title}</span>
              ${p.role_name ? `<span class="badge bg-light text-dark ms-2">${p.role_name}</span>` : ''}
              ${STATUS_BADGE[p.status]||''}
              <div class="text-muted small">${p.shift_date||''} ${p.shift_start||''} ${p.pay_rate ? '· '+p.pay_rate : ''} · ${p.slots} slot(s)</div>
              ${p.tags ? `<div class="mt-1">${p.tags.split(',').map(t=>`<span class="badge bg-light text-dark me-1">${t.trim()}</span>`).join('')}</div>` : ''}
            </div>
            <div class="d-flex gap-1">
              ${p.status==='open' ? `<button class="btn btn-sm btn-outline-secondary" onclick="updatePostingStatus('${p.id}','cancelled')"><i class="bi bi-x-circle"></i></button>` : ''}
            </div>
          </div>
        </div>
      </div>`).join('')
      : '<div class="empty-state"><i class="bi bi-briefcase"></i>No postings yet</div>';
  } catch(e) { document.getElementById('tenant-postings-list').innerHTML = `<div class="text-danger p-3">${e.message}</div>`; }
}

async function createPosting() {
  const title = document.getElementById('jp-title').value.trim();
  if (!title) { toast('Title required','danger'); return; }
  try {
    await api('POST', `/api/v1/tenant/${S.businessId}/marketplace/postings`, {
      title, role_name: document.getElementById('jp-role').value||null,
      description: document.getElementById('jp-desc').value||null,
      shift_date: document.getElementById('jp-date').value||null,
      shift_start: document.getElementById('jp-start').value||null,
      shift_end: document.getElementById('jp-end').value||null,
      pay_rate: document.getElementById('jp-pay').value||null,
      slots: parseInt(document.getElementById('jp-slots').value)||1,
      tags: document.getElementById('jp-tags').value||null,
    });
    ['jp-title','jp-role','jp-desc','jp-date','jp-start','jp-end','jp-pay','jp-tags'].forEach(id=>{
      const el=document.getElementById(id); if(el) el.value='';
    });
    document.getElementById('jp-slots').value='1';
    toast('Posting created!');
    loadTenantPostings();
  } catch(e) { toast(e.message,'danger'); }
}

async function updatePostingStatus(id, status) {
  try {
    await api('PATCH', `/api/v1/tenant/${S.businessId}/marketplace/postings/${id}`, { status });
    loadTenantPostings();
  } catch(e) { toast(e.message,'danger'); }
}

// COVERAGE ARRANGEMENT ─────────────────────────────────────────────────────────

let _covTab = 'manual';
let _covSelectedMemberId = null;

function covTab(tab, el) {
  _covTab = tab;
  document.querySelectorAll('#cov-tabs .nav-link').forEach(l => l.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('cov-tab-manual').style.display = tab === 'manual' ? '' : 'none';
  document.getElementById('cov-tab-job_board').style.display = tab === 'job_board' ? '' : 'none';
  const btn = document.getElementById('cov-submit-btn');
  btn.innerHTML = tab === 'manual'
    ? '<i class="bi bi-person-check me-1"></i>Assign Worker'
    : '<i class="bi bi-megaphone me-1"></i>Post to Job Board';
}

async function openArrangeCoverage(swapId) {
  _covTab = 'manual';
  _covSelectedMemberId = null;
  document.getElementById('cov-swap-id').value = swapId;
  document.getElementById('cov-tab-manual').style.display = '';
  document.getElementById('cov-tab-job_board').style.display = 'none';
  document.querySelectorAll('#cov-tabs .nav-link').forEach((l,i) => l.classList.toggle('active', i===0));
  document.getElementById('cov-submit-btn').innerHTML = '<i class="bi bi-person-check me-1"></i>Assign Worker';
  document.getElementById('cov-eligible-list').innerHTML = '<div class="text-muted small text-center py-3"><i class="bi bi-hourglass"></i> Loading eligible workers…</div>';
  openModal('modal-arrange-coverage');
  try {
    const workers = await api('GET', `/api/v1/tenant/${S.businessId}/marketplace/swap-requests/${swapId}/eligible-workers`);
    _renderEligibleWorkers(workers);
  } catch(e) {
    document.getElementById('cov-eligible-list').innerHTML = `<div class="text-danger small">${e.detail||e.message||'Error loading workers'}</div>`;
  }
}

function _renderEligibleWorkers(workers) {
  const el = document.getElementById('cov-eligible-list');
  if (!workers.length) { el.innerHTML = '<div class="text-muted small text-center py-3">No active workers found</div>'; return; }
  el.innerHTML = workers.map(w => {
    const name = w.job_title || w.membership_id.slice(0,8);
    const roles = (w.qualified_roles||[]).join(', ') || '—';
    const badgeColor = w.eligible ? 'success' : 'secondary';
    const eligibleLabel = w.eligible ? '✓ Eligible' : '✗ Ineligible';
    const reasons = (w.reasons||[]).join(' · ');
    return `<div class="d-flex align-items-start gap-2 p-2 mb-1 rounded border cursor-pointer cov-worker-row ${w.eligible ? '' : 'opacity-50'}"
        style="cursor:${w.eligible?'pointer':'not-allowed'};background:rgba(255,255,255,.03)"
        id="cov-row-${w.membership_id}"
        onclick="${w.eligible ? `selectCovWorker('${w.membership_id}')` : "toast('Worker is not eligible for this shift','warning')"}">
      <div class="flex-grow-1">
        <div class="fw-semibold small">${_escHtml(name)}</div>
        <div class="text-muted" style="font-size:.72rem">Roles: ${_escHtml(roles)}</div>
        ${reasons ? `<div class="text-muted" style="font-size:.7rem">${_escHtml(reasons)}</div>` : ''}
      </div>
      <span class="badge bg-${badgeColor} align-self-center">${eligibleLabel}</span>
    </div>`;
  }).join('');
}

function selectCovWorker(memberId) {
  _covSelectedMemberId = memberId;
  document.querySelectorAll('.cov-worker-row').forEach(el => {
    el.style.border = el.id === `cov-row-${memberId}` ? '2px solid #6366f1' : '';
    el.style.background = el.id === `cov-row-${memberId}` ? 'rgba(99,102,241,.15)' : 'rgba(255,255,255,.03)';
  });
}

async function submitArrangeCoverage() {
  const swapId = document.getElementById('cov-swap-id').value;
  try {
    if (_covTab === 'manual') {
      if (!_covSelectedMemberId) { toast('Select a worker first','warning'); return; }
      await api('POST', `/api/v1/tenant/${S.businessId}/marketplace/swap-requests/${swapId}/arrange-coverage`, {
        type: 'manual',
        membership_id: _covSelectedMemberId,
      });
      toast('Shift assigned — swap completed!','success');
    } else {
      const title = document.getElementById('cov-title').value.trim();
      const rules = {
        required_role: document.getElementById('cov-rule-role').value.trim() || undefined,
        require_availability: document.getElementById('cov-rule-avail').checked,
        require_location_match: document.getElementById('cov-rule-loc').checked,
      };
      const mh = document.getElementById('cov-rule-hours').value;
      if (mh) rules.max_weekly_hours = parseInt(mh);
      await api('POST', `/api/v1/tenant/${S.businessId}/marketplace/swap-requests/${swapId}/arrange-coverage`, {
        type: 'job_board',
        title: title || undefined,
        description: document.getElementById('cov-desc').value.trim() || undefined,
        pay_rate: document.getElementById('cov-pay').value.trim() || undefined,
        eligibility_rules: rules,
      });
      toast('Posted to job board — eligible workers will see this shift','success');
    }
    closeModal('modal-arrange-coverage');
    loadTenantSwapRequests();
  } catch(e) { toast(e.detail||e.message||'Error','danger'); }
}

async function loadTenantShiftRequests() {
  const status = document.getElementById('sr-filter')?.value || '';
  try {
    const url = `/api/v1/tenant/${S.businessId}/marketplace/shift-requests` + (status ? `?status=${status}` : '');
    const rows = await api('GET', url);
    const el = document.getElementById('tenant-shift-reqs');
    el.innerHTML = rows.length ? `<div class="table-responsive"><table class="table table-sm table-hover mb-0">
      <thead><tr><th>Worker</th><th>Posting</th><th>Message</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>${rows.map(r => `<tr>
        <td><small class="text-muted">${r.worker_id.slice(0,8)}</small></td>
        <td><small class="text-muted">${r.posting_id.slice(0,8)}</small></td>
        <td><small>${r.message||''}</small></td>
        <td>${STATUS_BADGE[r.status]||r.status}</td>
        <td>${r.status==='pending' ? `
          <button class="btn btn-sm btn-outline-success me-1" onclick="reviewShiftReq('${r.id}','approved')">✓</button>
          <button class="btn btn-sm btn-outline-danger" onclick="reviewShiftReq('${r.id}','denied')">✗</button>` : ''}
        </td>
      </tr>`).join('')}</tbody></table></div>`
      : '<div class="empty-state"><i class="bi bi-inbox"></i>No requests</div>';
  } catch(e) { document.getElementById('tenant-shift-reqs').innerHTML = `<div class="text-danger p-3">${e.message}</div>`; }
}

async function reviewShiftReq(id, status) {
  if (status === 'denied') { showDenyModal('shift', id); return; }
  try {
    await api('PATCH', `/api/v1/tenant/${S.businessId}/marketplace/shift-requests/${id}`, { status });
    toast('Approved!'); loadTenantShiftRequests();
  } catch(e) { toast(e.message,'danger'); }
}

// TENANT: SWAP REQUESTS ────────────────────────────────────────────────────────

async function loadTenantSwapRequests() {
  const status = document.getElementById('swp-filter')?.value || '';
  try {
    const url = `/api/v1/tenant/${S.businessId}/marketplace/swap-requests` + (status ? `?status=${status}` : '');
    const rows = await api('GET', url);
    const el = document.getElementById('tenant-swap-reqs');
    el.innerHTML = rows.length ? `<div class="table-responsive"><table class="table table-sm table-hover mb-0">
      <thead><tr><th>Initiator</th><th>Their Shift</th><th>Peer</th><th>Peer Shift</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>${rows.map(r => `<tr>
        <td><small class="text-muted">${r.initiator_id.slice(0,8)}</small></td>
        <td><small>${r.their_shift_date||'—'} ${r.their_shift_start||''}</small></td>
        <td><small class="text-muted">${r.peer_worker_id ? r.peer_worker_id.slice(0,8) : 'Open'}</small></td>
        <td><small>${r.peer_shift_date||'—'} ${r.peer_shift_start||''}</small></td>
        <td>${STATUS_BADGE[r.status]||r.status}</td>
        <td class="text-nowrap">${(r.status==='pending'||r.status==='awaiting_peer') ? `
          <button class="btn btn-sm btn-outline-success me-1" onclick="reviewSwapReq('${r.id}','approved')">✓ Approve</button>
          <button class="btn btn-sm btn-outline-danger" onclick="reviewSwapReq('${r.id}','denied')">✗ Deny</button>`
          : r.status==='pending_coverage' ? `
          <button class="btn btn-sm btn-accent" onclick="openArrangeCoverage('${r.id}')"><i class="bi bi-person-fill-gear me-1"></i>Arrange Coverage</button>` : ''}
        </td>
      </tr>`).join('')}</tbody></table></div>`
      : '<div class="empty-state"><i class="bi bi-arrow-left-right"></i>No swap requests</div>';
  } catch(e) { document.getElementById('tenant-swap-reqs').innerHTML = `<div class="text-danger p-3">${e.message}</div>`; }
}

async function reviewSwapReq(id, status) {
  if (status === 'denied') { showDenyModal('swap', id); return; }
  try {
    await api('PATCH', `/api/v1/tenant/${S.businessId}/marketplace/swap-requests/${id}`, { status });
    toast('Swap approved — arrange coverage to complete the swap.'); loadTenantSwapRequests();
  } catch(e) { toast(e.message,'danger'); }
}

// TENANT: SWAP RULES ───────────────────────────────────────────────────────────

async function loadSwapRules() {
  try {
    const rows = await api('GET', `/api/v1/tenant/${S.businessId}/marketplace/swap-rules`);
    const el = document.getElementById('swap-rules-list');
    const DAYS_LBL = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
    el.innerHTML = rows.length ? rows.map(r => `
      <div class="d-flex justify-content-between align-items-start border-bottom py-2">
        <div>
          <span class="badge ${r.effect==='allow'?'bg-success':'bg-danger'} me-2">${r.effect==='allow'?'✅ Allow':'🚫 Deny'}</span>
          <span class="fw-semibold small">Priority ${r.priority}</span>
          <div class="text-muted" style="font-size:.75rem">
            ${r.membership_id ? `Employee: ${r.membership_id.slice(0,8)} ` : 'All employees '}
            ${r.role_name ? `· Role: ${r.role_name} ` : ''}
            ${r.day_of_week!=null ? `· ${DAYS_LBL[r.day_of_week]} ` : ''}
            ${r.window_start ? `· ${r.window_start}–${r.window_end||'?'} ` : ''}
          </div>
          ${r.note ? `<div class="text-muted" style="font-size:.7rem">${r.note}</div>` : ''}
        </div>
        <button class="btn btn-sm btn-outline-danger" onclick="deleteSwapRule('${r.id}')"><i class="bi bi-trash"></i></button>
      </div>`).join('')
      : '<div class="empty-state"><i class="bi bi-sliders"></i>No rules yet — all swaps require manager approval</div>';
  } catch(e) {}
}

async function createSwapRule() {
  try {
    const dow = document.getElementById('rule-dow').value;
    await api('POST', `/api/v1/tenant/${S.businessId}/marketplace/swap-rules`, {
      effect: document.getElementById('rule-effect').value,
      membership_id: document.getElementById('rule-member').value || null,
      role_name: document.getElementById('rule-role').value || null,
      day_of_week: dow !== '' ? parseInt(dow) : null,
      window_start: document.getElementById('rule-wstart').value || null,
      window_end: document.getElementById('rule-wend').value || null,
      priority: parseInt(document.getElementById('rule-priority').value) || 10,
      note: document.getElementById('rule-note').value || null,
    });
    toast('Rule created!');
    loadSwapRules();
  } catch(e) { toast(e.message,'danger'); }
}

async function deleteSwapRule(id) {
  showConfirm('Delete Rule', 'Remove this swap permission rule?', 'Delete', 'btn-danger',
    async () => {
      try { await api('DELETE', `/api/v1/tenant/${S.businessId}/marketplace/swap-rules/${id}`); loadSwapRules(); }
      catch(e) { toast(e.message,'danger'); }
    });
}

async function deleteSwapRule(id) {
  showConfirm('Delete Rule', 'Remove this swap permission rule?', 'Delete', 'btn-danger',
    async () => {
      try { await api('DELETE', `/api/v1/tenant/${S.businessId}/marketplace/swap-rules/${id}`); loadSwapRules(); }
      catch(e) { toast(e.message,'danger'); }
    });
}

// ── Schedule Editor ────────────────────────────────────────────────────────────

const CAL_START_HOUR = 6;   // 6 AM
const CAL_END_HOUR   = 23;  // 11 PM
const CAL_HOUR_PX    = 60;  // pixels per hour
const CAL_DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

let _calShifts     = [];     // loaded shifts
let _calWeekStart  = null;  // current week's Monday (Date object)
let _editShiftId   = null;  // null = new shift, string = editing existing
let _calMembers    = [];    // [{id,name,email}] for assignment picker

function _monday(d) {
  const dt = new Date(d);
  const day = dt.getDay();
  const diff = (day === 0 ? -6 : 1 - day);
  dt.setDate(dt.getDate() + diff);
  dt.setHours(0, 0, 0, 0);
  return dt;
}

function _isoDate(d) {
  // Use local date parts — toISOString() would give UTC date which can be wrong day in +/- UTC timezones
  const pad = n => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
}

function _fmtTime(tsStr) {
  const d = new Date(tsStr);
  return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true });
}

function _fmtDatetimeLocal(tsStr) {
  const d = new Date(tsStr);
  // Format for datetime-local input: YYYY-MM-DDTHH:MM
  const pad = n => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

async function loadScheduleEditor() {
  if (!S.businessId) return;
  if (!_calWeekStart) _calWeekStart = _monday(new Date());
  // Populate location filter from user's accessible locations
  const locSel = document.getElementById('cal-filter-location');
  if (locSel) {
    const prev = locSel.value;
    locSel.innerHTML = '<option value="">All Locations</option>' +
      S.myLocations.map(l => `<option value="${l.id}"${l.id===prev?' selected':''}>${_escHtml(l.name)}</option>`).join('');
    // Auto-select if only one location
    if (!prev && S.myLocations.length === 1) locSel.value = S.myLocations[0].id;
  }
  await _calLoadShifts();
}

async function _calLoadShifts() {
  try {
    const locId = document.getElementById('cal-filter-location')?.value || '';
    const locParam = locId ? `&location_id=${encodeURIComponent(locId)}` : '';
    _calShifts = await api('GET',
      `/api/v1/tenant/${S.businessId}/schedule?week=${_isoDate(_calWeekStart)}${locParam}`);
    renderCalendar();
  } catch(e) { toast(e.message || 'Failed to load schedule', 'danger'); }
}

function calNav(dir) {
  if (dir === 0) { _calWeekStart = _monday(new Date()); }
  else {
    const d = new Date(_calWeekStart);
    d.setDate(d.getDate() + dir * 7);
    _calWeekStart = d;
  }
  if (S.businessId) _calLoadShifts();
}

function renderCalendar() {
  if (!_calWeekStart) return;
  const grid = document.getElementById('cal-grid');
  const filterStatus = document.getElementById('cal-filter-status')?.value || '';

  // Build week dates
  const dates = Array.from({length: 7}, (_, i) => {
    const d = new Date(_calWeekStart);
    d.setDate(d.getDate() + i);
    return d;
  });

  // Update week label
  const fmt = d => d.toLocaleDateString([], {month:'short', day:'numeric'});
  document.getElementById('cal-week-label').textContent =
    `${fmt(dates[0])} – ${fmt(dates[6])}, ${dates[0].getFullYear()}`;

  const today = new Date(); today.setHours(0,0,0,0);
  const hours = CAL_END_HOUR - CAL_START_HOUR;
  const totalPx = hours * CAL_HOUR_PX;

  // Filter shifts
  const visible = _calShifts.filter(s => !filterStatus || s.status === filterStatus);

  // Group shifts by day index (0=Mon…6=Sun)
  const byDay = Array.from({length:7}, () => []);
  visible.forEach(s => {
    const sd = new Date(s.start_ts);
    const dayIdx = dates.findIndex(d => d.toDateString() === new Date(sd).setHours(0,0,0,0) && true);
    // find matching date
    for (let i = 0; i < 7; i++) {
      const dd = new Date(dates[i]); dd.setHours(0,0,0,0);
      const sd2 = new Date(s.start_ts); sd2.setHours(0,0,0,0);
      if (dd.getTime() === sd2.getTime()) { byDay[i].push(s); break; }
    }
  });

  // Build grid HTML
  let html = '';

  // Header row
  html += `<div class="cal-header cal-time-col">Time</div>`;
  dates.forEach((d, i) => {
    const isToday = d.getTime() === today.getTime();
    const dayLabel = `${CAL_DAYS[i]} ${d.getDate()}`;
    html += `<div class="cal-header${isToday?' today':''}">${dayLabel}</div>`;
  });

  // Time column + day columns
  const timeColHtml = Array.from({length: hours}, (_, h) => {
    const hr = CAL_START_HOUR + h;
    const label = hr === 12 ? '12 PM' : hr < 12 ? `${hr} AM` : `${hr-12} PM`;
    return `<div class="cal-time-label">${label}</div>`;
  }).join('');
  html += `<div class="cal-time-col">${timeColHtml}</div>`;

  // Day columns
  for (let i = 0; i < 7; i++) {
    const d = dates[i];
    const isToday = d.getTime() === today.getTime();
    const canWrite = can('schedule:write');

    // Hour click grid
    let hoursHtml = Array.from({length: hours}, (_, h) => {
      const hr = CAL_START_HOUR + h;
      const dateStr = _isoDate(d);
      return canWrite
        ? `<div class="cal-hour-row" onclick="openShiftModal('${dateStr}', ${hr})"></div>`
        : `<div class="cal-hour-row"></div>`;
    }).join('');

    // Now-line
    let nowLine = '';
    if (isToday) {
      const now = new Date();
      const nowHour = now.getHours() + now.getMinutes() / 60;
      if (nowHour >= CAL_START_HOUR && nowHour < CAL_END_HOUR) {
        const top = (nowHour - CAL_START_HOUR) * CAL_HOUR_PX;
        nowLine = `<div class="cal-now-line" style="top:${top}px"></div>`;
      }
    }

    // Shift blocks
    let blocksHtml = '';
    byDay[i].forEach(s => {
      const st = new Date(s.start_ts);
      const en = new Date(s.end_ts);
      const startH = st.getHours() + st.getMinutes() / 60;
      const endH   = en.getHours() + en.getMinutes() / 60;
      const top    = Math.max(0, (startH - CAL_START_HOUR) * CAL_HOUR_PX);
      const height = Math.max(22, (endH - startH) * CAL_HOUR_PX - 4);

      const style = s.color
        ? `background:${s.color}22;color:${s.color};border-left-color:${s.color}`
        : '';
      const cls = `shift-block status-${s.status}`;

      const people = s.assignments.length
        ? s.assignments.map(a => a.name || a.email || '?').join(', ')
        : `${s.assigned_count}/${s.needed_count} filled`;

      blocksHtml += `
        <div class="${cls}" style="top:${top}px;height:${height}px;${style}"
             onclick="event.stopPropagation();openShiftEdit('${s.id}')">
          <div class="sb-title">${_escHtml(s.title)}</div>
          <div class="sb-time">${_fmtTime(s.start_ts)}–${_fmtTime(s.end_ts)}</div>
          ${s.role_name ? `<div class="sb-time">${_escHtml(s.role_name)}</div>` : ''}
          ${height > 50 ? `<div class="sb-people"><i class="bi bi-people-fill"></i> ${_escHtml(people)}</div>` : ''}
        </div>`;
    });

    html += `<div class="cal-day-col" style="height:${totalPx}px">${nowLine}${hoursHtml}${blocksHtml}</div>`;
  }

  grid.innerHTML = html;
}

function _escHtml(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Shift Modal ────────────────────────────────────────────────────────────────

async function openShiftModal(dateStr, hour) {
  _editShiftId = null;
  document.getElementById('shift-modal-title').textContent = 'New Shift';
  document.getElementById('sm-delete-btn').style.display = 'none';
  document.getElementById('sm-assignments-section').style.display = 'none';

  // Defaults
  const start = dateStr
    ? (() => { const d = new Date(`${dateStr}T${String(hour||9).padStart(2,'0')}:00`); return _fmtDatetimeLocal(d.toISOString()); })()
    : _fmtDatetimeLocal(new Date().toISOString());
  const endD = new Date(start); endD.setHours(endD.getHours() + 8);
  document.getElementById('sm-title').value = '';
  document.getElementById('sm-start').value = start;
  document.getElementById('sm-end').value = _fmtDatetimeLocal(endD.toISOString());
  document.getElementById('sm-count').value = 1;
  document.getElementById('sm-role').value = '';
  document.getElementById('sm-status').value = 'draft';
  document.getElementById('sm-notes').value = '';
  document.getElementById('sm-color').value = '#6366f1';

  await _loadLocationOptions();
  document.getElementById('sm-location').value = '';

  new bootstrap.Modal(document.getElementById('modal-shift')).show();
}

async function openShiftEdit(shiftId) {
  _editShiftId = shiftId;
  const s = _calShifts.find(x => x.id === shiftId);
  if (!s) return;

  document.getElementById('shift-modal-title').textContent = 'Edit Shift';
  document.getElementById('sm-delete-btn').style.display = can('schedule:write') ? '' : 'none';
  document.getElementById('sm-title').value = s.title || '';
  document.getElementById('sm-start').value = _fmtDatetimeLocal(s.start_ts);
  document.getElementById('sm-end').value = _fmtDatetimeLocal(s.end_ts);
  document.getElementById('sm-count').value = s.needed_count || 1;
  document.getElementById('sm-role').value = s.role_name || '';
  document.getElementById('sm-status').value = s.status || 'draft';
  document.getElementById('sm-notes').value = s.notes || '';
  document.getElementById('sm-color').value = s.color || '#6366f1';

  await _loadLocationOptions(s.location_id);

  // Assignments
  document.getElementById('sm-assignments-section').style.display = '';
  await _loadMemberOptions();
  _renderAssignments(s.assignments);

  new bootstrap.Modal(document.getElementById('modal-shift')).show();
}

async function _loadLocationOptions(selectedId) {
  const sel = document.getElementById('sm-location');
  sel.innerHTML = '<option value="">— None —</option>' +
    S.myLocations.map(l => `<option value="${l.id}"${l.id===selectedId?' selected':''}>${_escHtml(l.name)}</option>`).join('');
}

async function _loadMemberOptions() {
  try {
    if (!_calMembers.length) {
      const members = await api('GET', `/api/v1/tenant/${S.businessId}/members`);
      _calMembers = members.map(m => ({
        id: m.id,
        email: m.email,
        name: (m.first_name || m.last_name) ? `${m.first_name||''} ${m.last_name||''}`.trim() : m.email,
      }));
    }
    const sel = document.getElementById('sm-assign-member');
    sel.innerHTML = '<option value="">— Select member —</option>' +
      _calMembers.map(m => `<option value="${m.id}">${_escHtml(m.name)}</option>`).join('');
  } catch(_) {}
}

function _renderAssignments(assignments) {
  const el = document.getElementById('sm-assignments-list');
  if (!assignments.length) {
    el.innerHTML = '<div class="text-muted small py-2">No employees assigned yet</div>';
    return;
  }
  el.innerHTML = assignments.map(a => `
    <div class="d-flex align-items-center justify-content-between py-1 border-bottom">
      <div>
        <span class="fw-semibold small">${_escHtml(a.name || a.email || '?')}</span>
        <span class="text-muted small ms-2">${a.email || ''}</span>
        <span class="badge ms-2 ${
          a.status==='confirmed'?'bg-success':a.status==='declined'?'bg-danger':a.status==='no_show'?'bg-warning text-dark':'bg-secondary'
        }">${a.status}</span>
      </div>
      ${can('schedule:write') ? `<button class="btn btn-sm btn-outline-danger py-0" onclick="removeAssignment('${a.id}')"><i class="bi bi-x"></i></button>` : ''}
    </div>`).join('');
}

async function addShiftAssignment() {
  if (!_editShiftId) return;
  const mid = document.getElementById('sm-assign-member').value;
  if (!mid) return;
  try {
    await api('POST', `/api/v1/tenant/${S.businessId}/schedule/shifts/${_editShiftId}/assignments`,
      { membership_id: mid });
    toast('Assigned!');
    // Reload shift data
    const s = await api('GET', `/api/v1/tenant/${S.businessId}/schedule/shifts/${_editShiftId}`);
    // Update local cache
    const idx = _calShifts.findIndex(x => x.id === _editShiftId);
    if (idx >= 0) _calShifts[idx] = s;
    _renderAssignments(s.assignments);
    renderCalendar();
  } catch(e) { toast(e.message || 'Error', 'danger'); }
}

async function removeAssignment(assignmentId) {
  if (!_editShiftId) return;
  try {
    await api('DELETE', `/api/v1/tenant/${S.businessId}/schedule/shifts/${_editShiftId}/assignments/${assignmentId}`);
    toast('Removed');
    const s = await api('GET', `/api/v1/tenant/${S.businessId}/schedule/shifts/${_editShiftId}`);
    const idx = _calShifts.findIndex(x => x.id === _editShiftId);
    if (idx >= 0) _calShifts[idx] = s;
    _renderAssignments(s.assignments);
    renderCalendar();
  } catch(e) { toast(e.message || 'Error', 'danger'); }
}

async function saveShift() {
  const title = document.getElementById('sm-title').value.trim();
  if (!title) { toast('Title is required', 'warning'); return; }
  const start = document.getElementById('sm-start').value;
  const end   = document.getElementById('sm-end').value;
  if (!start || !end) { toast('Start and end time required', 'warning'); return; }

  const payload = {
    title,
    start_ts: new Date(start).toISOString(),
    end_ts:   new Date(end).toISOString(),
    role_name: document.getElementById('sm-role').value.trim() || null,
    location_id: document.getElementById('sm-location').value || null,
    needed_count: parseInt(document.getElementById('sm-count').value) || 1,
    status: document.getElementById('sm-status').value,
    notes: document.getElementById('sm-notes').value.trim() || null,
    color: document.getElementById('sm-color').value || null,
  };

  try {
    if (_editShiftId) {
      const updated = await api('PATCH',
        `/api/v1/tenant/${S.businessId}/schedule/shifts/${_editShiftId}`, payload);
      const idx = _calShifts.findIndex(x => x.id === _editShiftId);
      if (idx >= 0) _calShifts[idx] = updated; else _calShifts.push(updated);
    } else {
      const created = await api('POST',
        `/api/v1/tenant/${S.businessId}/schedule/shifts`, payload);
      _calShifts.push(created);
    }
    bootstrap.Modal.getInstance(document.getElementById('modal-shift'))?.hide();
    toast(_editShiftId ? 'Shift updated!' : 'Shift created!');
    _calMembers = []; // reset member cache in case of changes
    renderCalendar();
  } catch(e) { toast(e.message || 'Error saving shift', 'danger'); }
}

async function deleteShiftFromModal() {
  if (!_editShiftId) return;
  showConfirm('Delete Shift', 'Permanently delete this shift and all assignments?', 'Delete', 'btn-danger',
    async () => {
      try {
        await api('DELETE', `/api/v1/tenant/${S.businessId}/schedule/shifts/${_editShiftId}`);
        _calShifts = _calShifts.filter(s => s.id !== _editShiftId);
        bootstrap.Modal.getInstance(document.getElementById('modal-shift'))?.hide();
        toast('Shift deleted');
        renderCalendar();
      } catch(e) { toast(e.message,'danger'); }
    });
}


let _myProfileData = null;
let _myWorkerProfileData = null;

function _profileInitials(data) {
  if (data.first_name || data.last_name)
    return ((data.first_name||'')[0]+(data.last_name||'')[0]).toUpperCase() || '?';
  return (data.email||'?')[0].toUpperCase();
}

function _profileDisplayName(data) {
  if (data.first_name || data.last_name)
    return [data.first_name, data.last_name].filter(Boolean).join(' ');
  return data.email;
}

const _avatarColors = ['#6366f1','#8b5cf6','#ec4899','#f59e0b','#10b981','#3b82f6','#ef4444'];
function _avatarColor(str) {
  let h = 0; for (const c of str) h = (h*31 + c.charCodeAt(0)) % _avatarColors.length;
  return _avatarColors[h];
}

async function loadMyProfile() {
  try {
    _myProfileData = await api('GET', '/api/v1/worker/me/profile');
    const initials = _profileInitials(_myProfileData);
    const color = _avatarColor(_myProfileData.email);
    const name = _profileDisplayName(_myProfileData);
    const $= id => document.getElementById(id);
    $('profile-avatar').textContent = initials;
    $('profile-avatar').style.background = color;
    $('profile-display-name').textContent = name;
    $('profile-email').textContent = _myProfileData.email;
    $('pv-phone').textContent = _myProfileData.phone || '—';
    $('pv-bio').textContent = _myProfileData.bio || '—';
    $('profile-ec-name').textContent = _myProfileData.emergency_contact_name || '—';
    $('profile-ec-phone').textContent = _myProfileData.emergency_contact_phone || '—';
    // Role badge from S.user
    $('profile-role-badge').innerHTML = S.user.is_superadmin
      ? '<span class="perm-badge" style="background:#fce7f3;color:#831843">⚡ Superadmin</span>'
      : '';

    if (S.businessId) {
      try {
        _myWorkerProfileData = await api('GET', `/api/v1/worker/me/profile/${S.businessId}`);
        $('pv-job-title').textContent = _myWorkerProfileData.job_title || '—';
        $('pv-pay-rate').textContent = _myWorkerProfileData.pay_rate ? `$${_myWorkerProfileData.pay_rate}/hr` : '—';
        $('pv-hire-date').textContent = _myWorkerProfileData.hire_date || '—';
        $('profile-worker-card').style.display = '';
        $('profile-worker-edit-card').style.display = '';
        $('profile-skills-edit-card').style.display = '';
      } catch(_) {}
      // Show and load the availability section
      const availSec = document.getElementById('profile-avail-section');
      if (availSec) { availSec.style.display = ''; availLoad('prof-av'); }
    }
  } catch(e) { toast(e.message,'danger'); }
}

function toggleProfileEdit() {
  const viewMode = document.getElementById('profile-view-mode');
  const editMode = document.getElementById('profile-edit-mode');
  const editing = editMode.style.display === '';
  if (!editing && _myProfileData) {
    // Populate edit fields
    const f = _myProfileData;
    document.getElementById('pe-first-name').value = f.first_name || '';
    document.getElementById('pe-last-name').value = f.last_name || '';
    document.getElementById('pe-phone').value = f.phone || '';
    document.getElementById('pe-bio').value = f.bio || '';
    document.getElementById('pe-ec-name').value = f.emergency_contact_name || '';
    document.getElementById('pe-ec-phone').value = f.emergency_contact_phone || '';
    if (_myWorkerProfileData) {
      document.getElementById('pe-job-title').value = _myWorkerProfileData.job_title || '';
      document.getElementById('pe-hire-date').value = _myWorkerProfileData.hire_date || '';
      document.getElementById('pe-qualified-roles').value = (_myWorkerProfileData.qualified_roles||[]).join(', ');
      document.getElementById('pe-skills').value = (_myWorkerProfileData.skills||[]).join(', ');
      document.getElementById('pe-certifications').value = (_myWorkerProfileData.certifications||[]).join(', ');
      document.getElementById('pe-max-hours').value = _myWorkerProfileData.max_weekly_hours || '';
    }
  }
  viewMode.style.display = editing ? '' : 'none';
  editMode.style.display = editing ? 'none' : '';
}

async function saveMyProfile() {
  try {
    const payload = {};
    ['first_name','last_name','phone','bio'].forEach(f => {
      const v = document.getElementById(`pe-${f.replace('_','-')}`).value.trim();
      if (v) payload[f] = v; else payload[f] = null;
    });
    payload.emergency_contact_name = document.getElementById('pe-ec-name').value.trim() || null;
    payload.emergency_contact_phone = document.getElementById('pe-ec-phone').value.trim() || null;
    await api('PATCH', '/api/v1/worker/me/profile', payload);
    toast('Profile saved!');
    toggleProfileEdit();
    loadMyProfile();
  } catch(e) { toast(e.message,'danger'); }
}

async function saveMyWorkerProfile() {
  if (!S.businessId) return;
  try {
    const payload = {};
    const jt = document.getElementById('pe-job-title').value.trim();
    const hd = document.getElementById('pe-hire-date').value;
    if (jt) payload.job_title = jt; else payload.job_title = null;
    if (hd) payload.hire_date = hd; else payload.hire_date = null;
    await api('PATCH', `/api/v1/worker/me/profile/${S.businessId}`, payload);
    toast('Work info saved!');
    loadMyProfile();
  } catch(e) { toast(e.message,'danger'); }
}

async function saveMySkillsProfile() {
  if (!S.businessId) return;
  try {
    const splitTags = v => v.split(',').map(s => s.trim()).filter(Boolean);
    await api('PATCH', `/api/v1/worker/me/profile/${S.businessId}`, {
      qualified_roles: splitTags(document.getElementById('pe-qualified-roles').value),
      skills: splitTags(document.getElementById('pe-skills').value),
      certifications: splitTags(document.getElementById('pe-certifications').value),
      max_weekly_hours: parseInt(document.getElementById('pe-max-hours').value) || null,
    });
    toast('Skills & qualifications saved!');
    loadMyProfile();
  } catch(e) { toast(e.message,'danger'); }
}

// ── Member Profile Drawer ─────────────────────────────────────────────────────

// ── MESSAGING ────────────────────────────────────────────────────────────────

let _msgChannels    = [];   // cached channel list
let _msgActiveId    = null; // active channel_id
let _msgPollTimer   = null; // polling timer (fallback when WS unavailable)
let _msgPanelOpen   = false; // slide-over panel state
let _msgWs          = null; // WebSocket if open
let _msgUnreadPoll  = null; // unread count polling interval

async function loadMessages() {
  setVis('msg-new-ch-btn', can('messaging:manage'));
  setVis('msg-dm-btn', can('messaging:write'));
  setVis('msg-broadcast-btn', can('messaging:broadcast'));

  try {
    _msgChannels = await api('GET', '/api/v1/messaging/channels') || [];
  } catch(e) { _msgChannels = []; }

  _msgRenderChannelList();
  if (_msgChannels.length > 0 && !_msgActiveId) {
    await _msgSelectChannel(_msgChannels[0].id);
  } else if (_msgActiveId) {
    await _msgSelectChannel(_msgActiveId);
  }
  _msgStartUnreadPoll();
}

function _msgRenderChannelList() {
  const el = document.getElementById('msg-channel-list');
  if (!el) return;
  if (!_msgChannels.length) {
    el.innerHTML = `<div class="text-muted small text-center p-3">No channels yet</div>`;
    return;
  }
  el.innerHTML = _msgChannels.map(ch => {
    const icon = ch.type === 'announcement' ? 'bi-megaphone' : ch.type === 'direct' ? 'bi-person' : 'bi-hash';
    const isActive = ch.id === _msgActiveId;
    return `<div class="d-flex align-items-center gap-2 p-2 rounded mb-1"
              style="cursor:pointer;color:#1e293b;${isActive ? 'background:#e0e7ff;color:#4338ca;font-weight:600' : ''}" 
              onmouseover="if(!'${isActive}')this.style.background='#f1f5f9'" 
              onmouseout="this.style.background='${isActive?'#e0e7ff':''}'"
              onclick="_msgSelectChannel('${ch.id}')">
      <i class="bi ${icon}" style="color:${isActive?'#6366f1':'#94a3b8'}"></i>
      <span class="flex-grow-1 text-truncate small">${ch.name}</span>
      ${ch.type === 'announcement' ? '<span class="badge bg-warning text-dark" style="font-size:.55rem">ANN</span>' : ''}
    </div>`;
  }).join('');
}

async function _msgSelectChannel(channelId) {
  _msgActiveId = channelId;
  const ch = _msgChannels.find(c => c.id === channelId);
  _msgRenderChannelList();

  const nameEl = document.getElementById('msg-channel-name');
  const badgeEl = document.getElementById('msg-channel-type-badge');
  if (nameEl) nameEl.textContent = ch ? ch.name : channelId;
  if (badgeEl) {
    const colors = { announcement: 'bg-warning text-dark', group: 'bg-info text-dark', direct: 'bg-secondary' };
    badgeEl.className = `badge ms-2 ${colors[ch?.type] || 'bg-secondary'}`;
    badgeEl.style.fontSize = '.65rem';
    badgeEl.textContent = ch?.type || '';
  }

  const inputArea = document.getElementById('msg-input-area');
  if (inputArea) {
    const canPost = ch?.type !== 'announcement' ? can('messaging:write') : can('messaging:broadcast');
    inputArea.style.display = canPost ? '' : 'none';
  }

  setVis('msg-members-btn', ch?.type !== 'direct' && can('messaging:manage'));
  await _msgLoadMessages(channelId);
  _msgConnectWs(channelId);
}

async function _msgLoadMessages(channelId) {
  const listEl = document.getElementById('msg-message-list');
  if (!listEl) return;
  listEl.innerHTML = `<div class="text-muted small text-center py-3"><span class="spinner-border spinner-border-sm me-2"></span>Loading…</div>`;
  try {
    const msgs = await api('GET', `/api/v1/messaging/channels/${channelId}/messages?limit=50`);
    _msgRenderMessages(msgs || []);
  } catch(e) {
    listEl.innerHTML = `<div class="text-danger small p-3">${e.message}</div>`;
  }
}

function _msgRenderMessages(msgs) {
  const listEl = document.getElementById('msg-message-list');
  if (!listEl) return;
  if (!msgs.length) {
    listEl.innerHTML = `<div class="text-muted small text-center py-5"><i class="bi bi-chat-dots d-block mb-2" style="font-size:2rem"></i>No messages yet. Say hello!</div>`;
    return;
  }
  listEl.innerHTML = msgs.map(m => {
    const isMe = m.sender_id === S.user?.id;
    const isApi = m.source === 'api_key';
    const time = new Date(m.created_at).toLocaleTimeString('en', { hour: '2-digit', minute: '2-digit' });
    const date = new Date(m.created_at).toLocaleDateString('en', { month: 'short', day: 'numeric' });
    const nameLabel = isMe ? 'You' : (m.sender_name || m.sender_email || 'Unknown');
    const senderLabel = isApi
      ? `<span class="badge bg-secondary me-1" style="font-size:.6rem">API</span>${_escHtml(m.sender_name)}`
      : _escHtml(nameLabel);
    return `<div class="d-flex flex-column ${isMe ? 'align-items-end' : 'align-items-start'}">
      <div class="mb-1" style="font-size:.7rem;color:#64748b">${senderLabel} · ${date} ${time}</div>
      <div class="px-3 py-2 rounded-3" style="max-width:70%;word-break:break-word;font-size:.9rem;${isMe
        ? 'background:#6366f1;color:#fff'
        : 'background:#f1f5f9;color:#1e293b;border:1px solid #e2e8f0'}">
        ${_escHtml(m.content)}
        ${isMe ? `<i class="bi bi-trash ms-2" style="cursor:pointer;font-size:.7rem;opacity:.6" onclick="msgDeleteMessage('${m.id}')"></i>` : ''}
      </div>
    </div>`;
  }).join('');
  listEl.scrollTop = listEl.scrollHeight;
}

function _escHtml(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

async function msgSend() {
  const input = document.getElementById('msg-input');
  const content = input?.value.trim();
  if (!content || !_msgActiveId) return;
  input.value = '';
  try {
    await api('POST', `/api/v1/messaging/channels/${_msgActiveId}/messages`, { content });
    if (!_msgWs || _msgWs.readyState !== WebSocket.OPEN) {
      await _msgLoadMessages(_msgActiveId);
    }
  } catch(e) { toast(e.message || 'Failed to send'); }
}

async function msgDeleteMessage(messageId) {
  if (!_msgActiveId) return;
  try {
    await api('DELETE', `/api/v1/messaging/channels/${_msgActiveId}/messages/${messageId}`);
    await _msgLoadMessages(_msgActiveId);
  } catch(e) { toast(e.message || 'Failed to delete'); }
}

function _msgConnectWs(channelId) {
  if (_msgWs) { try { _msgWs.close(); } catch(e) {} _msgWs = null; }
  if (_msgPollTimer) { clearInterval(_msgPollTimer); _msgPollTimer = null; }

  const token = localStorage.getItem('wf_token');
  if (!token) return;

  const proto = location.protocol === 'https:' ? 'wss' : 'ws';
  const wsUrl = `${proto}://${location.host}/api/v1/messaging/ws/${channelId}?token=${token}`;

  try {
    const ws = new WebSocket(wsUrl);
    ws.onopen = () => { _msgWs = ws; };
    ws.onmessage = (e) => {
      try {
        const pkt = JSON.parse(e.data);
        if (pkt.event === 'message' && pkt.data?.channel_id === _msgActiveId) {
          _msgLoadMessages(_msgActiveId);
        }
      } catch(err) {}
    };
    ws.onerror = () => { _msgWs = null; _msgStartPolling(channelId); };
    ws.onclose = (e) => { if (e.code !== 1000) _msgStartPolling(channelId); _msgWs = null; };
  } catch(e) {
    _msgStartPolling(channelId);
  }
}

function _msgStartPolling(channelId) {
  if (_msgPollTimer) clearInterval(_msgPollTimer);
  _msgPollTimer = setInterval(() => {
    if (_msgActiveId === channelId) _msgLoadMessages(channelId);
  }, 3000);
}

function _msgStartUnreadPoll() {
  if (_msgUnreadPoll) clearInterval(_msgUnreadPoll);
  _msgUnreadPoll = setInterval(_msgUpdateUnread, 10000);
  _msgUpdateUnread();
}

async function _msgUpdateUnread() {
  if (!can('messaging:read')) return;
  try {
    const counts = await api('GET', '/api/v1/messaging/unread');
    const total = Object.values(counts || {}).reduce((a, b) => a + b, 0);
    // Update FAB badge
    const fab = document.getElementById('msg-fab-badge');
    if (fab) {
      if (total > 0) { fab.textContent = total > 99 ? '99+' : total; fab.style.display = 'flex'; }
      else { fab.style.display = 'none'; }
    }
    // Pulse FAB if unread
    const fabBtn = document.getElementById('msg-fab');
    if (fabBtn) fabBtn.style.animation = total > 0 ? 'pulse 2s infinite' : '';
    // Re-render panel channel list if open
    if (document.getElementById('msg-panel')?.classList.contains('open')) {
      _panelRenderChannels();
    }
    // Re-render widget(s) if present
    _dashLayout?.forEach((slot, i) => {
      if (slot.type === 'messages') {
        const el = document.getElementById(`wbody-${i}`);
        if (el) widgetMessages(slot, i).then(html => { if (el) el.innerHTML = html; });
      }
    });
  } catch(e) {}
}

// ── Messaging Panel (slide-over) ──────────────────────────────────────────────

function toggleMsgPanel() {
  const panel = document.getElementById('msg-panel');
  if (panel?.classList.contains('open')) closeMsgPanel();
  else openMsgPanel();
}

async function openMsgPanel() {
  const panel    = document.getElementById('msg-panel');
  const backdrop = document.getElementById('msg-backdrop');
  panel.classList.add('open');
  backdrop.style.display = 'block';
  _msgPanelOpen = true;
  // Show permission-gated buttons
  setVis('panel-new-ch-btn',  can('messaging:manage'));
  setVis('panel-dm-btn',      can('messaging:write'));
  setVis('panel-broadcast-btn', can('messaging:broadcast'));
  // Load channels if not loaded yet
  if (!_msgChannels.length) {
    try { _msgChannels = await api('GET', '/api/v1/messaging/channels') || []; } catch(e) {}
  }
  _panelRenderChannels();
  // Select previously active channel or first available
  const target = _msgActiveId || (_msgChannels[0]?.id);
  if (target) await _panelSelectChannel(target);
}

function closeMsgPanel() {
  document.getElementById('msg-panel')?.classList.remove('open');
  document.getElementById('msg-backdrop').style.display = 'none';
  _msgPanelOpen = false;
  if (_msgPollTimer) { clearInterval(_msgPollTimer); _msgPollTimer = null; }
}

function _panelRenderChannels() {
  const el = document.getElementById('panel-channel-list');
  if (!el) return;
  if (!_msgChannels.length) {
    el.innerHTML = '<div class="text-muted small text-center p-3">No channels yet</div>';
    return;
  }
  el.innerHTML = _msgChannels.map(ch => {
    const isActive = ch.id === _msgActiveId;
    const unread = ch.unread_count || 0;
    const icon = ch.type === 'direct' ? 'bi-person' : ch.type === 'announcement' ? 'bi-megaphone' : 'bi-hash';
    return `<div class="msg-widget-ch${unread?' has-unread':''}" style="${isActive?'background:rgba(99,102,241,.25)':''}"
              onclick="_panelSelectChannel('${ch.id}')">
      <div class="d-flex align-items-center gap-1">
        <i class="bi ${icon} text-muted" style="font-size:.75rem;width:14px"></i>
        <span class="small text-white text-truncate flex-grow-1" style="font-size:.8rem">${_escHtml(ch.name)}</span>
        ${unread ? `<span class="badge bg-danger rounded-pill" style="font-size:.6rem">${unread}</span>` : ''}
      </div>
    </div>`;
  }).join('');
}

async function _panelSelectChannel(channelId) {
  _msgActiveId = channelId;
  const ch = _msgChannels.find(c => c.id === channelId);
  // Update header
  document.getElementById('panel-channel-name').textContent = ch?.name || 'Channel';
  const typeBadge = document.getElementById('panel-channel-type-badge');
  typeBadge.textContent = ch?.type || '';
  typeBadge.className = `badge ms-1 ${ch?.type==='announcement'?'bg-warning text-dark':ch?.type==='direct'?'bg-info text-dark':'bg-secondary'}`;
  setVis('panel-members-btn', ch?.type !== 'direct' && can('messaging:manage'));
  // Show/hide input
  const canPost = ch?.type !== 'announcement' ? can('messaging:write') : can('messaging:broadcast');
  document.getElementById('panel-input-area').style.display = canPost ? '' : 'none';
  // Re-highlight channel list
  _panelRenderChannels();
  // Load messages
  try {
    const msgs = await api('GET', `/api/v1/messaging/channels/${channelId}/messages?limit=50`);
    _panelRenderMessages(msgs || []);
    // Mark read
    api('POST', `/api/v1/messaging/channels/${channelId}/read`).catch(() => {});
    ch && (ch.unread_count = 0);
    _panelRenderChannels();
  } catch(e) {}
  // Start real-time (WS or polling)
  _msgConnectWs(channelId);
}

function _panelRenderMessages(msgs) {
  const el = document.getElementById('panel-message-list');
  if (!el) return;
  if (!msgs.length) {
    el.innerHTML = '<div class="text-muted small text-center py-5"><i class="bi bi-chat-dots d-block mb-2" style="font-size:1.8rem"></i>No messages yet</div>';
    return;
  }
  const me = S.user?.email;
  el.innerHTML = msgs.map(m => {
    const isMine = m.sender_email === me || m.sender_id === S.user?.id;
    const ts = new Date(m.created_at).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
    const nameLabel = isMine ? 'You' : _escHtml(m.sender_name || m.sender_email || 'Unknown');
    return `<div class="d-flex flex-column ${isMine?'align-items-end':'align-items-start'} mb-1">
      <div style="font-size:.65rem;margin-bottom:2px;color:#a5b4fc">${nameLabel}&nbsp;·&nbsp;${ts}</div>
      <div class="px-2 py-1 rounded" style="max-width:82%;font-size:.82rem;word-break:break-word;color:#e2e8f0;background:${isMine?'rgba(99,102,241,.5)':'rgba(255,255,255,.12)'}">
        ${_escHtml(m.content)}
      </div>
    </div>`;
  }).join('');
  el.scrollTop = el.scrollHeight;
}

async function panelMsgSend() {
  const input = document.getElementById('panel-msg-input');
  const content = input?.value?.trim();
  if (!content || !_msgActiveId) return;
  input.value = '';
  try {
    await api('POST', `/api/v1/messaging/channels/${_msgActiveId}/messages`, { content });
    const msgs = await api('GET', `/api/v1/messaging/channels/${_msgActiveId}/messages?limit=50`);
    _panelRenderMessages(msgs || []);
  } catch(e) { toast(e.message || 'Send failed', 'danger'); }
}

function msgNewChannel() {
  document.getElementById('msg-ch-name').value = '';
  document.getElementById('msg-ch-desc').value = '';
  openModal('modal-msg-channel');
}

async function msgCreateChannel() {
  const name = document.getElementById('msg-ch-name').value.trim();
  const type = document.getElementById('msg-ch-type').value;
  const description = document.getElementById('msg-ch-desc').value.trim() || null;
  if (!name) return;
  try {
    await api('POST', '/api/v1/messaging/channels', { name, type, description, business_id: S.businessId });
    closeModal('modal-msg-channel');
    toast('Channel created');
    await loadMessages();
  } catch(e) { toast(e.message || 'Failed to create channel'); }
}

async function msgNewDm() {
  try {
    const members = await api('GET', `/api/v1/tenant/${S.businessId}/members`);
    const sel = document.getElementById('msg-dm-target');
    sel.innerHTML = (members || [])
      .filter(m => m.user_id !== S.user?.id)
      .map(m => `<option value="${m.user_id}">${m.email || m.user_id}</option>`)
      .join('');
    document.getElementById('msg-dm-first').value = '';
    openModal('modal-msg-dm');
  } catch(e) { toast('Could not load members'); }
}

async function msgSendDm() {
  const targetUserId = document.getElementById('msg-dm-target').value;
  const content = document.getElementById('msg-dm-first').value.trim();
  if (!targetUserId || !content) return;
  try {
    const result = await api('POST', `/api/v1/messaging/dm/${targetUserId}`, { content });
    closeModal('modal-msg-dm');
    toast('DM sent');
    await loadMessages();
    if (result?.channel?.id) await _msgSelectChannel(result.channel.id);
  } catch(e) { toast(e.message || 'Failed to send DM'); }
}

function msgBroadcast() {
  document.getElementById('msg-broadcast-text').value = '';
  openModal('modal-msg-broadcast');
}

async function msgSendBroadcast() {
  const content = document.getElementById('msg-broadcast-text').value.trim();
  if (!content) return;
  try {
    const result = await api('POST', '/api/v1/messaging/broadcast', { content, business_id: S.businessId });
    closeModal('modal-msg-broadcast');
    toast(`Broadcast sent to ${result.broadcast_count} channel(s)`);
    await loadMessages();
  } catch(e) { toast(e.message || 'Broadcast failed'); }
}

async function msgShowMembers() {
  if (!_msgActiveId) return;
  const ch = _msgChannels.find(c => c.id === _msgActiveId);
  toast(`${ch?.name || 'Channel'} — ${ch?.member_count || '?'} member(s)`);
}

// ── API Key management (tenant) ───────────────────────────────────────────────

async function loadMsgApiKeys() {
  if (!S.businessId || !can('messaging:manage')) return;
  const el = document.getElementById('msg-apikey-list');
  if (!el) return;
  try {
    const keys = await api('GET', `/api/v1/tenant/${S.businessId}/messaging/api-keys`);
    if (!keys.length) { el.innerHTML = `<div class="text-muted small p-2">No API keys yet</div>`; return; }
    el.innerHTML = `<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Name</th><th>Permissions</th><th>Status</th><th>Last Used</th><th></th></tr></thead><tbody>
      ${keys.map(k => `<tr>
        <td class="small fw-semibold">${_escHtml(k.name)}</td>
        <td><span class="badge bg-secondary">${(k.permissions||[]).join(', ')}</span></td>
        <td>${k.is_active ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-secondary">Revoked</span>'}</td>
        <td class="small text-muted">${k.last_used_at ? new Date(k.last_used_at).toLocaleDateString() : 'Never'}</td>
        <td>${k.is_active ? `<button class="btn btn-sm btn-outline-danger py-0" onclick="msgRevokeApiKey('${k.id}')">Revoke</button>` : ''}</td>
      </tr>`).join('')}
    </tbody></table></div>`;
  } catch(e) { el.innerHTML = `<div class="text-danger small p-2">${e.message}</div>`; }
}

function msgOpenNewApiKey() {
  document.getElementById('msg-ak-name').value = '';
  document.getElementById('msg-ak-key-display').classList.add('d-none');
  openModal('modal-msg-apikey');
}

async function msgCreateApiKey() {
  const name = document.getElementById('msg-ak-name').value.trim();
  if (!name) return;
  const permissions = [];
  if (document.getElementById('msg-ak-read').checked) permissions.push('read');
  if (document.getElementById('msg-ak-write').checked) permissions.push('write');
  try {
    const result = await api('POST', `/api/v1/tenant/${S.businessId}/messaging/api-keys`, { name, permissions, channel_ids: [] });
    document.getElementById('msg-ak-key-value').textContent = result.key;
    document.getElementById('msg-ak-key-display').classList.remove('d-none');
    toast('API key created — save it now!');
    loadMsgApiKeys();
  } catch(e) { toast(e.message || 'Failed to create key'); }
}

async function msgRevokeApiKey(keyId) {
  try {
    await api('DELETE', `/api/v1/tenant/${S.businessId}/messaging/api-keys/${keyId}`);
    toast('API key revoked');
    loadMsgApiKeys();
  } catch(e) { toast(e.message || 'Failed to revoke'); }
}

// ── Member Profile Drawer ─────────────────────────────────────────────────────

let _mpMembershipId = null;

async function openMemberProfile(membershipId, goToEdit=false) {
  _mpMembershipId = membershipId;
  try {
    const [d, allRoles] = await Promise.all([
      api('GET', `/api/v1/tenant/${S.businessId}/members/${membershipId}/profile`),
      api('GET', `/api/v1/tenant/${S.businessId}/roles`).catch(() => []),
    ]);
    const initials = _profileInitials(d);
    const color = _avatarColor(d.email);
    const name = _profileDisplayName(d);
    document.getElementById('mp-avatar').textContent = initials;
    document.getElementById('mp-avatar').style.background = color;
    document.getElementById('mp-name').textContent = name;
    document.getElementById('mp-email').textContent = d.email;

    const setT = (id, val) => { document.getElementById(id).textContent = val || '—'; };
    setT('mp-phone', d.phone);
    setT('mp-bio', d.bio);
    setT('mp-ec-name', d.emergency_contact_name);
    setT('mp-ec-phone', d.emergency_contact_phone);
    setT('mp-job-title', d.job_title);
    setT('mp-pay-rate', d.pay_rate ? `$${d.pay_rate}/hr` : null);
    setT('mp-hire-date', d.hire_date);
    setT('mp-notes', d.notes);
    setT('mp-member-since', d.member_since ? d.member_since.slice(0,10) : null);

    const statusColors = {active:'success',invited:'primary',inactive:'secondary',removed:'danger'};
    document.getElementById('mp-status').innerHTML =
      `<span class="badge bg-${statusColors[d.status]||'secondary'}">${d.status}</span>`;
    document.getElementById('mp-roles').innerHTML =
      (d.roles||[]).map(r=>`<span class="perm-badge">${r.name}</span>`).join('') || '—';
    document.getElementById('mp-location').textContent = d.primary_location_id || '—';

    // Show edit tab only if user has members:write
    const canEdit = can('members:write');
    document.getElementById('mp-edit-tab-li').style.display = canEdit ? '' : 'none';
    // Show location roles tab if user has roles:write
    document.getElementById('mp-locroles-tab-li').style.display = can('roles:write') ? '' : 'none';
    if (canEdit) {
      // Pre-fill edit fields
      document.getElementById('mpe-first-name').value = d.first_name || '';
      document.getElementById('mpe-last-name').value = d.last_name || '';
      document.getElementById('mpe-phone').value = d.phone || '';
      document.getElementById('mpe-bio').value = d.bio || '';
      document.getElementById('mpe-ec-name').value = d.emergency_contact_name || '';
      document.getElementById('mpe-ec-phone').value = d.emergency_contact_phone || '';
      document.getElementById('mpe-job-title').value = d.job_title || '';
      document.getElementById('mpe-pay-rate').value = d.pay_rate || '';
      document.getElementById('mpe-hire-date').value = d.hire_date || '';
      document.getElementById('mpe-notes').value = d.notes || '';
      document.getElementById('mpe-status').value = d.status || 'active';
      // Location dropdown
      const locSel = document.getElementById('mpe-location');
      locSel.innerHTML = '<option value="">— None —</option>' +
        (S.myLocations||[]).map(l => `<option value="${l.id}" ${l.id===d.primary_location_id?'selected':''}>${_escHtml(l.name)}</option>`).join('');
      // Roles checkboxes
      const memberRoleIds = new Set((d.roles||[]).map(r => r.id));
      document.getElementById('mpe-roles-wrap').innerHTML = allRoles.length
        ? allRoles.map(r => `
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" id="mpe-role-${r.id}" value="${r.id}" ${memberRoleIds.has(r.id)?'checked':''}>
            <label class="form-check-label small" for="mpe-role-${r.id}">${_escHtml(r.name)}</label>
          </div>`).join('')
        : '<span class="text-muted small">No roles defined for this business</span>';
    }

    // Tab to activate
    const activeTab = (goToEdit && canEdit) ? 'edit' : 'info';
    document.querySelectorAll('[data-mptab]').forEach(a => {
      a.classList.toggle('active', a.dataset.mptab === activeTab);
    });
    ['mp-tab-info','mp-tab-work','mp-tab-edit','mp-tab-locroles'].forEach(id =>
      document.getElementById(id).style.display = id === `mp-tab-${activeTab}` ? '' : 'none');

    new bootstrap.Modal(document.getElementById('modal-member-profile')).show();
  } catch(e) { toast(e.message,'danger'); }
}

// Tab switching in member profile modal
document.addEventListener('click', e => {
  const a = e.target.closest('[data-mptab]');
  if (!a) return;
  e.preventDefault();
  const tab = a.dataset.mptab;
  document.querySelectorAll('[data-mptab]').forEach(x => x.classList.remove('active'));
  a.classList.add('active');
  ['mp-tab-info','mp-tab-work','mp-tab-edit','mp-tab-locroles'].forEach(id =>
    document.getElementById(id).style.display = id === `mp-tab-${tab}` ? '' : 'none');
  if (tab === 'locroles') loadLocationRolesTab();
});

async function saveMemberProfile() {
  if (!_mpMembershipId) return;
  try {
    const payload = {};
    const fields = {
      'mpe-first-name':'first_name','mpe-last-name':'last_name','mpe-phone':'phone',
      'mpe-bio':'bio','mpe-ec-name':'emergency_contact_name','mpe-ec-phone':'emergency_contact_phone',
      'mpe-job-title':'job_title','mpe-pay-rate':'pay_rate','mpe-hire-date':'hire_date','mpe-notes':'notes'
    };
    for (const [id, key] of Object.entries(fields)) {
      const el = document.getElementById(id);
      const v = el.value.trim();
      payload[key] = v || null;
      if (key === 'pay_rate' && v) payload[key] = parseFloat(v);
    }
    // Status and location
    const statusEl = document.getElementById('mpe-status');
    if (statusEl) payload.status = statusEl.value;
    const locEl = document.getElementById('mpe-location');
    if (locEl) payload.primary_location_id = locEl.value || null;

    // Collect selected role IDs
    const roleIds = [...document.querySelectorAll('#mpe-roles-wrap input[type=checkbox]:checked')].map(cb => cb.value);

    await Promise.all([
      api('PATCH', `/api/v1/tenant/${S.businessId}/members/${_mpMembershipId}/profile`, payload),
      api('PUT',   `/api/v1/tenant/${S.businessId}/members/${_mpMembershipId}/roles`, { role_ids: roleIds }),
    ]);
    toast('Member updated!');
    bootstrap.Modal.getInstance(document.getElementById('modal-member-profile'))?.hide();
    _dirFiltersLoaded = false;
    loadMembers();
  } catch(e) { toast(e.message,'danger'); }
}

async function loadLocationRolesTab() {
  if (!_mpMembershipId || !S.businessId) return;
  const el = document.getElementById('mpe-locroles-body');
  el.innerHTML = '<div class="text-muted text-center py-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading…</div>';
  try {
    const [locs, roles, current] = await Promise.all([
      api('GET', `/api/v1/tenant/${S.businessId}/locations`),
      api('GET', `/api/v1/tenant/${S.businessId}/roles`),
      api('GET', `/api/v1/tenant/${S.businessId}/members/${_mpMembershipId}/location-roles`),
    ]);
    if (!locs?.length) {
      el.innerHTML = '<div class="text-muted small text-center py-4">No locations defined for this business.</div>';
      return;
    }
    el.innerHTML = locs.map(loc => {
      const assigned = new Set(current[loc.id] || []);
      return `<div class="mb-3 p-3 rounded" style="border:1px solid rgba(0,0,0,.1)">
        <div class="fw-semibold small mb-2"><i class="bi bi-geo-alt-fill text-primary me-1"></i>${_escHtml(loc.name)}</div>
        <div class="d-flex flex-wrap gap-3">
          ${roles.map(r => `
            <div class="form-check form-check-inline">
              <input class="form-check-input loc-role-cb" type="checkbox"
                id="lr-${loc.id}-${r.id}" value="${r.id}" data-loc="${loc.id}"
                ${assigned.has(r.id) ? 'checked' : ''}>
              <label class="form-check-label small" for="lr-${loc.id}-${r.id}">${_escHtml(r.name)}</label>
            </div>`).join('')}
        </div>
      </div>`;
    }).join('');
  } catch(e) { el.innerHTML = `<div class="text-danger small text-center py-3">${e.message}</div>`; }
}

async function saveLocationRoles() {
  if (!_mpMembershipId || !S.businessId) return;
  const cbs = document.querySelectorAll('.loc-role-cb');
  const assignments = {};
  cbs.forEach(cb => {
    if (!assignments[cb.dataset.loc]) assignments[cb.dataset.loc] = [];
    if (cb.checked) assignments[cb.dataset.loc].push(cb.value);
    else assignments[cb.dataset.loc]; // ensure key exists so we clear unchecked locations too
  });
  try {
    await api('PUT', `/api/v1/tenant/${S.businessId}/members/${_mpMembershipId}/location-roles`, { assignments });
    toast('Location roles saved!');
  } catch(e) { toast(e.message, 'danger'); }
}


// ██████████  WIDGET DASHBOARD  ████████████████████████████████████████████
// ═══════════════════════════════════════════════════════════════════════════

const WIDGET_META = {
  calendar:        { icon:'bi-calendar3',       title:'Schedule Calendar',   desc:'Weekly mini-calendar with upcoming shifts' },
  timeclock:       { icon:'bi-stopwatch',        title:'Time Clock',          desc:'Clock in/out with elapsed timer' },
  upcoming_shifts: { icon:'bi-calendar-week',   title:'Upcoming Shifts',     desc:'Next scheduled shifts' },
  quick_stats:     { icon:'bi-speedometer2',     title:'Quick Stats',         desc:'Key numbers at a glance' },
  announcements:   { icon:'bi-megaphone',        title:'Announcements',       desc:'Notice board / text block' },
  marketplace_feed:{ icon:'bi-shop',             title:'Job Board Feed',      desc:'Latest open job postings' },
  custom_text:     { icon:'bi-file-text',        title:'Custom Text',         desc:'Rich-text note or link widget' },
  availability:    { icon:'bi-clock',            title:'My Availability',     desc:'View and edit your weekly availability' },
  messages:        { icon:'bi-chat-dots-fill',   title:'Messages',            desc:'Quick-access messaging panel' },
};

let _dashLayout = [];
let _dashEditMode = false;
let _dashLocked = false;
let _dashDragIdx = null;

async function loadDashboard() {
  _tcwStopAll();   // clear any running timeclock widget timers
  if (!S.businessId) {
    // No business selected — show default welcome
    document.getElementById('dash-grid').innerHTML = `
      <div class="col-12"><div class="card"><div class="card-body text-center py-5">
        <i class="bi bi-layout-wtf fs-1 text-muted mb-3 d-block"></i>
        <div class="fw-semibold">Select a business to load your dashboard</div>
      </div></div></div>`;
    document.getElementById('dash-customize-btn').style.display = 'none';
    return;
  }
  try {
    const data = await api('GET', `/api/v1/worker/me/dashboard/${S.businessId}`);
    _dashLayout = data.layout || [];
    _dashLocked = data.is_locked;
    _dashEditMode = false;
    document.getElementById('dash-customize-btn').style.display = data.can_customize ? '' : 'none';
    document.getElementById('dash-save-btn').classList.add('d-none');
    document.getElementById('dash-cancel-btn').classList.add('d-none');
    document.getElementById('dash-add-panel').classList.add('d-none');
    renderDashGrid();
  } catch(e) {
    document.getElementById('dash-grid').innerHTML = `<div class="col-12"><div class="alert alert-danger">Failed to load dashboard: ${e.detail || e.message || JSON.stringify(e)}</div></div>`;
  }
}

function renderDashGrid() {
  const grid = document.getElementById('dash-grid');
  if (!_dashLayout.length) {
    grid.innerHTML = `<div class="col-12"><div class="card"><div class="card-body text-center py-5">
      <i class="bi bi-grid fs-1 text-muted mb-3 d-block"></i>
      <div class="fw-semibold mb-2">Your dashboard is empty</div>
      ${!_dashLocked ? '<button class="btn btn-accent btn-sm" onclick="enterDashEditMode()"><i class="bi bi-plus-lg me-1"></i>Add Widgets</button>' : ''}
    </div></div></div>`;
    return;
  }
  grid.innerHTML = _dashLayout.map((slot, i) => {
    const meta = WIDGET_META[slot.type] || { icon:'bi-grid', title: slot.title || slot.type };
    const w = slot.w || 6;
    const editControls = _dashEditMode ? `
      <div class="d-flex gap-1 ms-auto">
        <button class="btn btn-sm btn-outline-secondary" onclick="moveDashSlot(${i},-1)" title="Move left"><i class="bi bi-arrow-left"></i></button>
        <button class="btn btn-sm btn-outline-secondary" onclick="moveDashSlot(${i},1)" title="Move right"><i class="bi bi-arrow-right"></i></button>
        <button class="btn btn-sm btn-outline-danger" onclick="removeDashSlot(${i})" title="Remove"><i class="bi bi-x-lg"></i></button>
      </div>` : '';
    return `<div class="col-md-${w}" id="dash-slot-${i}" ${_dashEditMode?`draggable="true" ondragstart="dashDragStart(${i})" ondragover="dashDragOver(event,${i})" ondrop="dashDrop(event,${i})" style="cursor:grab"`:''}">
      <div class="card h-100 ${_dashEditMode?'border-primary border-2':''}">
        <div class="card-header d-flex align-items-center gap-2">
          <i class="bi ${meta.icon} text-primary"></i>
          <span class="fw-semibold">${slot.title || meta.title}</span>
          ${editControls}
        </div>
        <div class="card-body p-3" id="wbody-${i}">
          <div class="text-center text-muted py-3"><div class="spinner-border spinner-border-sm"></div></div>
        </div>
      </div>
    </div>`;
  }).join('');
  // Load widget content async
  _dashLayout.forEach((slot, i) => renderWidgetContent(slot, i));
}

async function renderWidgetContent(slot, idx) {
  const el = document.getElementById(`wbody-${idx}`);
  if (!el) return;
  try {
    switch (slot.type) {
      case 'timeclock':
        el.innerHTML = widgetTimeclockHtml(slot, idx);
        initTcWidget(idx);   // kick off async init after HTML is in DOM
        break;
      case 'upcoming_shifts': el.innerHTML = await widgetUpcomingShifts(slot, idx); break;
      case 'quick_stats':   el.innerHTML = await widgetQuickStats(slot); break;
      case 'calendar':      el.innerHTML = await widgetMiniCalendar(slot); break;
      case 'announcements': el.innerHTML = widgetAnnouncements(slot); break;
      case 'marketplace_feed': el.innerHTML = await widgetMarketplaceFeed(slot); break;
      case 'custom_text':   el.innerHTML = widgetCustomText(slot); break;
      case 'availability':  el.innerHTML = widgetAvailabilityHtml(idx); availLoad(idx); break;
      case 'messages':      el.innerHTML = await widgetMessages(slot); break;
      default:              el.innerHTML = `<div class="text-muted small text-center py-3">Unknown widget type: ${slot.type}</div>`;
    }
  } catch(e) {
    el.innerHTML = `<div class="alert alert-warning py-1 px-2 small">Failed to load widget: ${e.detail || e.message || JSON.stringify(e)}</div>`;
  }
}

// ── Individual Widget Renderers ───────────────────────────────────────────────

// ── MESSAGES WIDGET ──────────────────────────────────────────────────────────

async function widgetMessages(slot) {
  if (!can('messaging:read') || !S.businessId) {
    return `<div class="text-muted small text-center py-4"><i class="bi bi-lock d-block mb-2"></i>No access</div>`;
  }
  try {
    if (!_msgChannels.length) {
      _msgChannels = await api('GET', '/api/v1/messaging/channels') || [];
    }
    const counts = await api('GET', '/api/v1/messaging/unread').catch(() => ({}));
    if (!_msgChannels.length) {
      return `<div class="text-muted small text-center py-4"><i class="bi bi-chat-dots d-block mb-2" style="font-size:1.8rem"></i>No channels</div>`;
    }
    const chRows = _msgChannels.slice(0, 6).map(ch => {
      const unread = counts[ch.id] || 0;
      const icon = ch.type === 'direct' ? 'bi-person' : ch.type === 'announcement' ? 'bi-megaphone' : 'bi-hash';
      return `<div class="d-flex align-items-center gap-2 px-2 py-2 rounded mb-1"
                style="cursor:pointer;background:rgba(255,255,255,.05)"
                onmouseenter="this.style.background='rgba(99,102,241,.2)'"
                onmouseleave="this.style.background='rgba(255,255,255,.05)'"
                onclick="openMsgPanel().then(()=>_panelSelectChannel('${ch.id}'))">
        <i class="bi ${icon} text-muted"></i>
        <span class="flex-grow-1 text-truncate small text-white">${_escHtml(ch.name)}</span>
        ${unread ? `<span class="badge bg-danger rounded-pill">${unread > 99 ? '99+' : unread}</span>` : '<i class="bi bi-chevron-right text-muted" style="font-size:.7rem"></i>'}
      </div>`;
    }).join('');
    const more = _msgChannels.length > 6 ? `<div class="text-muted text-center" style="font-size:.75rem">${_msgChannels.length - 6} more channel${_msgChannels.length-6>1?'s':''}</div>` : '';
    return `<div>${chRows}${more}
      <div class="text-center mt-2">
        <button class="btn btn-sm btn-outline-primary w-100" onclick="openMsgPanel()">
          <i class="bi bi-chat-dots-fill me-1"></i>Open Chat
        </button>
      </div>
    </div>`;
  } catch(e) {
    return `<div class="text-danger small text-center py-3">Failed to load messages</div>`;
  }
}

// ── AVAILABILITY (shared logic for widget + profile) ─────────────────────────

const DAYS_SHORT = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

// Build the availability editor HTML for a given scope key (widget idx or 'prof')
function widgetAvailabilityHtml(idx) {
  const p = `av-w${idx}`;
  return `
    <div class="row g-2 mb-2">
      <div class="col-12">
        <select class="form-select form-select-sm" id="${p}-day">
          <option value="0">Monday</option><option value="1">Tuesday</option>
          <option value="2">Wednesday</option><option value="3">Thursday</option>
          <option value="4">Friday</option><option value="5">Saturday</option><option value="6">Sunday</option>
        </select>
      </div>
      <div class="col-6"><input type="number" class="form-control form-control-sm" id="${p}-start" min="0" max="23" value="9" placeholder="Start"></div>
      <div class="col-6"><input type="number" class="form-control form-control-sm" id="${p}-end" min="1" max="24" value="17" placeholder="End"></div>
    </div>
    <button class="btn btn-accent btn-sm w-100 mb-3" onclick="availSave('${p}-day','${p}-start','${p}-end','${p}-list')">
      <i class="bi bi-plus-circle me-1"></i>Add Block
    </button>
    <div id="${p}-list"></div>`;
}

// Load availability blocks into a list container
async function availLoad(idxOrKey) {
  const p = typeof idxOrKey === 'number' ? `av-w${idxOrKey}` : idxOrKey;
  const el = document.getElementById(`${p}-list`);
  if (!el) return;
  if (!S.businessId) { el.innerHTML = '<div class="text-muted small">Select a business first.</div>'; return; }
  try {
    const rows = await api('GET', `/api/v1/worker/me/availability/${S.businessId}`);
    if (!rows.length) {
      el.innerHTML = '<div class="empty-state small"><i class="bi bi-clock-history"></i> No availability set yet</div>';
      return;
    }
    el.innerHTML = rows.map(a => `
      <div class="d-flex align-items-center justify-content-between py-1 border-bottom gap-2">
        <span class="badge bg-primary" style="min-width:36px">${DAYS_SHORT[a.day_of_week]}</span>
        <span class="small flex-grow-1">${a.start_hour}:00 – ${a.end_hour}:00</span>
        <button class="btn btn-sm btn-outline-danger py-0 px-1" style="font-size:.75rem" onclick="availDelete('${a.id}','${p}')">
          <i class="bi bi-x"></i>
        </button>
      </div>`).join('');
  } catch(e) { el.innerHTML = `<div class="text-danger small">${e.detail||e.message||'Error'}</div>`; }
}

async function availSave(dayId, startId, endId, listId) {
  if (!S.businessId) { toast('Select a business first','warning'); return; }
  try {
    await api('POST', `/api/v1/worker/me/availability/${S.businessId}`, {
      day_of_week: parseInt(document.getElementById(dayId).value),
      start_hour:  parseFloat(document.getElementById(startId).value),
      end_hour:    parseFloat(document.getElementById(endId).value),
    });
    toast('Availability saved');
    // Derive the prefix from listId (strip trailing '-list') and reload
    const prefix = listId.replace(/-list$/, '');
    const idxOrKey = prefix.startsWith('av-w') ? parseInt(prefix.replace('av-w','')) : prefix;
    availLoad(idxOrKey);
    // Also reload the standalone view if it's visible
    loadAvailability();
  } catch(e) { toast(e.detail||e.message||'Error','danger'); }
}

async function availDelete(blockId, prefix) {
  if (!S.businessId) return;
  try {
    await api('DELETE', `/api/v1/worker/me/availability/${S.businessId}/${blockId}`);
    toast('Block removed');
    if (prefix !== 'standalone') {
      const idxOrKey = prefix.startsWith('av-w') ? parseInt(prefix.replace('av-w','')) : prefix;
      availLoad(idxOrKey);
    }
    loadAvailability();
  } catch(e) { toast(e.detail||e.message||'Error','danger'); }
}

// ── TIMECLOCK WIDGET ─────────────────────────────────────────────────────────

const _tcw = {};   // keyed by slot idx: { interval, entry, todayMins }

function widgetTimeclockHtml(slot, idx) {
  return `
    <div class="tc-widget" id="tcw-${idx}">
      <!-- Status badge -->
      <div class="text-center mb-3">
        <div id="tcw-badge-${idx}" class="d-inline-flex align-items-center gap-2 px-3 py-1 rounded-pill fw-semibold small"
             style="background:rgba(255,255,255,.08);color:#94a3b8">
          <i class="bi bi-circle-fill" style="font-size:.5rem"></i> Loading…
        </div>
      </div>
      <!-- Clock display -->
      <div class="text-center mb-3">
        <div id="tcw-time-${idx}" class="fw-bold" style="font-size:2.6rem;letter-spacing:.04em;font-variant-numeric:tabular-nums;color:#e0e7ff">
          --:--:--
        </div>
        <div id="tcw-since-${idx}" class="text-muted small mt-1" style="min-height:1.2em"></div>
      </div>
      <!-- Today total -->
      <div class="text-center mb-3">
        <div id="tcw-today-${idx}" class="small text-muted"></div>
      </div>
      <!-- Notes -->
      <div class="mb-3">
        <input class="form-control form-control-sm bg-dark text-light border-secondary"
               id="tcw-notes-${idx}" placeholder="Optional notes…">
      </div>
      <!-- Action button -->
      <button id="tcw-btn-${idx}" class="btn btn-success w-100 fw-semibold"
              onclick="tcwToggle(${idx})" disabled>
        <i class="bi bi-play-circle me-2"></i>Clock In
      </button>
      <!-- Recent entries -->
      <div id="tcw-entries-${idx}" class="mt-3" style="max-height:160px;overflow-y:auto"></div>
    </div>`;
}

async function initTcWidget(idx) {
  if (_tcw[idx]?.interval) clearInterval(_tcw[idx].interval);
  _tcw[idx] = { interval: null, entry: null, todayMins: 0 };

  if (!S.businessId) {
    _tcwSetUnavailable(idx, 'Select a business first');
    return;
  }

  try {
    const st = await api('GET', `/api/v1/worker/me/timeclock/${S.businessId}/status`);
    if (st.can_clock_in === false) {
      const ms = st.membership_status || 'inactive';
      _tcwSetUnavailable(idx, `Account ${ms} — clock-in disabled`);
      return;
    }
    _tcw[idx].entry = st.clocked_in ? st.entry : null;
    await _tcwLoadToday(idx);
    _tcwRender(idx);
    _tcw[idx].interval = setInterval(() => _tcwTick(idx), 1000);
  } catch(e) {
    _tcwSetUnavailable(idx, 'Status unavailable');
  }
}

async function _tcwLoadToday(idx) {
  try {
    const rows = await api('GET', `/api/v1/worker/me/timeclock/${S.businessId}/entries?limit=30`);
    const today = new Date().toDateString();
    let total = 0;
    const recentHtml = rows.slice(0, 5).map(e => {
      const cinStr = e.clocked_in_at;
      const cin = new Date(cinStr.endsWith('Z') ? cinStr : cinStr + 'Z');
      const isToday = cin.toDateString() === today;
      if (isToday && e.total_minutes) total += e.total_minutes;
      const coutStr = e.clocked_out_at;
      const cout = coutStr ? new Date(coutStr.endsWith('Z') ? coutStr : coutStr + 'Z') : null;
      const dur = e.total_minutes ? fmtMins(e.total_minutes) : (e.status === 'active' ? '<span class="text-success">Active</span>' : '—');
      return `<div class="d-flex justify-content-between align-items-center py-1 border-bottom border-secondary" style="font-size:.75rem">
        <span class="text-muted">${cin.toLocaleDateString('en',{month:'short',day:'numeric'})} ${cin.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit'})}</span>
        <span class="fw-semibold">${dur}</span>
      </div>`;
    }).join('');
    _tcw[idx].todayMins = total;
    const el = document.getElementById(`tcw-entries-${idx}`);
    if (el && rows.length) {
      el.innerHTML = `<div class="text-muted small fw-semibold mb-1" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em">Recent</div>${recentHtml}`;
    }
  } catch(e) {}
}

function _tcwRender(idx) {
  const state = _tcw[idx];
  if (!state) return;

  const badge   = document.getElementById(`tcw-badge-${idx}`);
  const timeEl  = document.getElementById(`tcw-time-${idx}`);
  const sinceEl = document.getElementById(`tcw-since-${idx}`);
  const todayEl = document.getElementById(`tcw-today-${idx}`);
  const btn     = document.getElementById(`tcw-btn-${idx}`);
  if (!btn) return;

  btn.disabled = false;

  if (state.entry) {
    // Clocked in
    badge.style.background = 'rgba(16,185,129,.15)';
    badge.style.color = '#10b981';
    badge.innerHTML = '<i class="bi bi-circle-fill" style="font-size:.5rem"></i> Clocked In';

    const cinStr = state.entry.clocked_in_at;
    const cin = new Date(cinStr.endsWith('Z') ? cinStr : cinStr + 'Z');
    sinceEl.textContent = `Since ${cin.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit'})}`;

    btn.className = 'btn btn-danger w-100 fw-semibold';
    btn.innerHTML = '<i class="bi bi-stop-circle me-2"></i>Clock Out';

    // Immediate tick to populate clock
    _tcwTick(idx);
  } else {
    // Not clocked in
    badge.style.background = 'rgba(255,255,255,.06)';
    badge.style.color = '#94a3b8';
    badge.innerHTML = '<i class="bi bi-circle" style="font-size:.5rem"></i> Not Clocked In';

    timeEl.style.color = '#475569';
    timeEl.textContent = '--:--:--';
    sinceEl.textContent = '';

    btn.className = 'btn btn-success w-100 fw-semibold';
    btn.innerHTML = '<i class="bi bi-play-circle me-2"></i>Clock In';
  }

  // Today total
  if (todayEl) {
    const total = state.todayMins + (state.entry ? _tcwElapsedMins(state.entry) : 0);
    todayEl.innerHTML = total > 0
      ? `<i class="bi bi-clock me-1"></i>Today: <strong>${fmtMins(total)}</strong>`
      : '';
  }
}

function _tcwTick(idx) {
  const state = _tcw[idx];
  if (!state?.entry) return;
  const timeEl = document.getElementById(`tcw-time-${idx}`);
  const todayEl = document.getElementById(`tcw-today-${idx}`);
  if (!timeEl) { clearInterval(state.interval); return; }

  const cinStr = state.entry.clocked_in_at;
  const cin = new Date(cinStr.endsWith('Z') ? cinStr : cinStr + 'Z');
  const elapsed = Date.now() - cin.getTime();

  timeEl.style.color = '#10b981';
  timeEl.textContent = fmtMs(elapsed);

  if (todayEl) {
    const total = state.todayMins + _tcwElapsedMins(state.entry);
    todayEl.innerHTML = total > 0
      ? `<i class="bi bi-clock me-1"></i>Today: <strong>${fmtMins(total)}</strong>`
      : '';
  }
}

function _tcwElapsedMins(entry) {
  if (!entry) return 0;
  const cinStr = entry.clocked_in_at;
  const cin = new Date(cinStr.endsWith('Z') ? cinStr : cinStr + 'Z');
  return (Date.now() - cin.getTime()) / 60000;
}

function _tcwSetUnavailable(idx, msg) {
  const badge = document.getElementById(`tcw-badge-${idx}`);
  const btn   = document.getElementById(`tcw-btn-${idx}`);
  if (badge) {
    badge.style.background = 'rgba(239,68,68,.12)';
    badge.style.color = '#ef4444';
    badge.innerHTML = `<i class="bi bi-slash-circle me-1"></i>${msg}`;
  }
  if (btn) { btn.disabled = true; btn.className = 'btn btn-secondary w-100 fw-semibold'; btn.innerHTML = '<i class="bi bi-slash-circle me-2"></i>Clock In Unavailable'; }
}

async function tcwToggle(idx) {
  const state = _tcw[idx];
  if (!state) return;
  const btn = document.getElementById(`tcw-btn-${idx}`);
  const notes = document.getElementById(`tcw-notes-${idx}`)?.value.trim() || null;
  if (btn) btn.disabled = true;
  try {
    if (state.entry) {
      // Clock out
      await api('POST', `/api/v1/worker/me/timeclock/${S.businessId}/clock-out`, { notes });
      if (_tcw[idx]?.interval) clearInterval(_tcw[idx].interval);
      _tcw[idx].entry = null;
    } else {
      // Clock in
      const entry = await api('POST', `/api/v1/worker/me/timeclock/${S.businessId}/clock-in`, { notes });
      _tcw[idx].entry = entry;
      _tcw[idx].interval = setInterval(() => _tcwTick(idx), 1000);
    }
    if (document.getElementById(`tcw-notes-${idx}`)) {
      document.getElementById(`tcw-notes-${idx}`).value = '';
    }
    await _tcwLoadToday(idx);
    _tcwRender(idx);
    toast(state.entry ? 'Clocked in!' : 'Clocked out!', state.entry ? 'success' : 'secondary');
  } catch(e) {
    toast(e.detail || e.message || 'Error', 'danger');
    if (btn) btn.disabled = false;
  }
}

function _tcwStopAll() {
  Object.values(_tcw).forEach(s => { if (s?.interval) clearInterval(s.interval); });
  for (const k in _tcw) delete _tcw[k];
}

async function widgetUpcomingShifts(slot, idx) {
  const max = slot.config?.max_items || 5;
  const filterLocIds = slot.config?.location_ids || [];
  try {
    // Use the worker endpoint — returns only this user's assigned shifts
    const shifts = await api('GET', `/api/v1/worker/me/schedule/${S.businessId}`);
    const now = Date.now();
    let mine = (shifts || []).filter(s => new Date(s.start_ts).getTime() > now);
    if (filterLocIds.length) mine = mine.filter(s => filterLocIds.includes(s.location_id));
    mine = mine.slice(0, max);

    const locOptions = S.myLocations.map(l =>
      `<div class="form-check form-check-sm">
        <input class="form-check-input" type="checkbox" value="${l.id}" id="wus-loc-${idx}-${l.id}"
          ${filterLocIds.includes(l.id) ? 'checked' : ''}
          onchange="widgetUpcomingShiftsUpdateLocs(${idx})">
        <label class="form-check-label small" for="wus-loc-${idx}-${l.id}">${_escHtml(l.name)}</label>
      </div>`).join('');
    const filterPanel = S.myLocations.length > 1 ? `
      <div class="mb-2">
        <a class="small text-muted text-decoration-none d-flex align-items-center gap-1" data-bs-toggle="collapse" href="#wus-filter-${idx}">
          <i class="bi bi-funnel"></i>Filter locations
        </a>
        <div class="collapse mt-1" id="wus-filter-${idx}">${locOptions}</div>
      </div>` : '';

    if (!mine.length) return filterPanel + `<div class="text-muted small text-center py-3">No upcoming shifts</div>`;
    const canSwap = can('marketplace:write');
    return filterPanel + mine.map(s => {
      const start = new Date(s.start_ts), end = new Date(s.end_ts);
      const badge = s.shift_status === 'published' ? 'success' : s.shift_status === 'cancelled' ? 'secondary' : 'warning';
      const locName = S.myLocations.find(l => l.id === s.location_id)?.name || '';
      const titleEsc = (s.title || 'Shift').replace(/'/g, "\\'");
      const swapBtn = canSwap && s.shift_status === 'published'
        ? `<button class="btn btn-sm btn-outline-secondary py-0 px-1" style="font-size:.7rem;white-space:nowrap"
             title="Request shift swap" onclick="openQuickSwap('${s.shift_id}','${titleEsc}','${s.start_ts}','${s.end_ts}')">
             <i class="bi bi-arrow-left-right"></i> Swap</button>` : '';
      return `<div class="d-flex align-items-center gap-2 mb-2 p-2 rounded" style="background:rgba(255,255,255,.05)">
        <div class="text-center" style="min-width:40px">
          <div class="small fw-bold">${start.toLocaleDateString('en',{weekday:'short'})}</div>
          <div class="text-muted small">${start.getDate()}</div>
        </div>
        <div class="flex-grow-1">
          <div class="fw-semibold small">${_escHtml(s.title||'Shift')}</div>
          <div class="text-muted" style="font-size:.75rem">${start.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit'})} – ${end.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit'})}${locName ? ' · '+_escHtml(locName) : ''}${s.role_name ? ' · '+_escHtml(s.role_name) : ''}</div>
        </div>
        <div class="d-flex flex-column align-items-end gap-1">
          <span class="badge bg-${badge}">${s.shift_status||s.status}</span>
          ${swapBtn}
        </div>
      </div>`;
    }).join('');
  } catch(e) { return `<div class="text-muted small text-center py-3">Shifts unavailable</div>`; }
}

async function widgetUpcomingShiftsUpdateLocs(idx) {
  const slot = _dashLayout[idx];
  if (!slot) return;
  const checked = [...document.querySelectorAll(`[id^="wus-loc-${idx}-"]:checked`)].map(el => el.value);
  if (!slot.config) slot.config = {};
  slot.config.location_ids = checked;
  // Persist immediately
  try {
    await api('PATCH', `/api/v1/worker/me/dashboard/${S.businessId}`, { layout: _dashLayout });
  } catch(_) {}
  // Re-render just this widget body
  const el = document.getElementById(`wbody-${idx}`);
  if (el) el.innerHTML = await widgetUpcomingShifts(slot, idx);
}

async function widgetQuickStats(slot) {
  const stats = [];
  try {
    // Hours this week from timeclock
    try {
      const sheets = await api('GET', `/api/v1/worker/me/timeclock/${S.businessId}/entries?limit=100`);
      const weekStart = new Date(); weekStart.setDate(weekStart.getDate() - weekStart.getDay());
      const weekHours = (sheets || []).filter(e => {
        const d = new Date(e.clocked_in_at);
        return d >= weekStart && e.total_minutes;
      }).reduce((sum, e) => sum + (e.total_minutes || 0), 0) / 60;
      stats.push({ icon:'bi-clock', label:'Hours This Week', value: weekHours.toFixed(1), color:'text-primary' });
    } catch(e) {}
    // Pending requests
    try {
      const reqs = await api('GET', `/api/v1/worker/me/marketplace/${S.businessId}/shift-requests`);
      const pending = (reqs || []).filter(r => r.status === 'pending').length;
      stats.push({ icon:'bi-inbox', label:'Pending Requests', value: pending, color:'text-warning' });
    } catch(e) {}
    // Upcoming shifts count
    try {
      const today = new Date().toISOString().slice(0,10);
      const shifts = await api('GET', `/api/v1/tenant/${S.businessId}/schedule?week=${today}`);
      stats.push({ icon:'bi-calendar-check', label:'Shifts This Week', value: (shifts||[]).length, color:'text-success' });
    } catch(e) {}
  } catch(e) {}
  if (!stats.length) return `<div class="text-muted small text-center py-3">No data available</div>`;
  return `<div class="row g-2">${stats.map(s=>`
    <div class="col-4 text-center">
      <div class="fw-bold fs-4 ${s.color}">${s.value}</div>
      <div class="text-muted" style="font-size:.7rem">${s.label}</div>
    </div>`).join('')}</div>`;
}

async function widgetMiniCalendar(slot) {
  // Simple 5-day strip
  const days = [];
  const now = new Date();
  for (let i = 0; i < 5; i++) {
    const d = new Date(now); d.setDate(now.getDate() + i);
    days.push(d);
  }
  let shifts = [];
  try {
    const today = now.toISOString().slice(0,10);
    shifts = await api('GET', `/api/v1/tenant/${S.businessId}/schedule?week=${today}`) || [];
  } catch(e) {}
  return `<div class="d-flex gap-1 overflow-auto">${days.map(d => {
    const ds = d.toISOString().slice(0,10);
    const dayShifts = shifts.filter(s => s.start_ts?.slice(0,10) === ds);
    const isToday = ds === now.toISOString().slice(0,10);
    return `<div class="flex-fill text-center rounded p-1" style="min-width:50px;background:${isToday?'rgba(99,102,241,.25)':'rgba(255,255,255,.05)'}">
      <div class="small fw-bold ${isToday?'text-primary':''}">${d.toLocaleDateString('en',{weekday:'short'})}</div>
      <div class="fw-bold ${isToday?'text-white':''}">${d.getDate()}</div>
      <div class="mt-1">${dayShifts.map(s=>`<div class="badge bg-success mb-1" style="font-size:.6rem;display:block">${s.start_ts?.slice(11,16)}</div>`).join('') || '<div class="text-muted" style="font-size:.7rem">—</div>'}</div>
    </div>`;
  }).join('')}</div>`;
}

function widgetAnnouncements(slot) {
  const bg = slot.config?.bg_color || '#ede9fe';
  const color = slot.config?.text_color || '#1e1b4b';
  const text = slot.config?.text || 'No announcement text configured.';
  return `<div class="rounded p-3" style="background:${bg};color:${color}">${text}</div>`;
}

async function widgetMarketplaceFeed(slot) {
  const max = slot.config?.max_items || 3;
  try {
    const postings = await api('GET', `/api/v1/marketplace/postings?business_id=${S.businessId}&limit=${max}`);
    if (!postings?.length) return `<div class="text-muted small text-center py-3">No open jobs posted</div>`;
    return postings.map(p => `<div class="mb-2 p-2 rounded" style="background:rgba(255,255,255,.05)">
      <div class="fw-semibold small">${p.title}</div>
      <div class="text-muted" style="font-size:.75rem">${p.location_name||''} · ${p.pay_rate||'Rate TBD'}</div>
    </div>`).join('') + `<div class="text-center mt-2"><a href="#" onclick="navToHubTab('jobboard');return false" class="btn btn-sm btn-outline-primary">View All Jobs</a></div>`;
  } catch(e) { return `<div class="text-muted small text-center py-3">Job feed unavailable</div>`; }
}

function widgetCustomText(slot) {
  const title = slot.config?.title || '';
  const html = slot.config?.html || '<p class="text-muted">No content configured. Edit this widget to add content.</p>';
  return (title ? `<div class="fw-semibold small mb-2">${title}</div>` : '') + html;
}

// ── Edit Mode ────────────────────────────────────────────────────────────────

function enterDashEditMode() {
  _dashEditMode = true;
  document.getElementById('dash-customize-btn').style.display = 'none';
  document.getElementById('dash-save-btn').classList.remove('d-none');
  document.getElementById('dash-cancel-btn').classList.remove('d-none');
  document.getElementById('dash-add-panel').classList.remove('d-none');
  renderDashGrid();
  renderWidgetPalette('dash-widget-palette', 'addDashSlot');
}

function cancelDashEdit() {
  _dashEditMode = false;
  loadDashboard();
}

function addDashSlot(type) {
  const meta = WIDGET_META[type] || { title: type };
  _dashLayout.push({ slot: crypto.randomUUID(), type, w: 6, title: meta.title, config: {} });
  renderDashGrid();
}

function removeDashSlot(i) {
  _dashLayout.splice(i, 1);
  renderDashGrid();
}

function moveDashSlot(i, dir) {
  const j = i + dir;
  if (j < 0 || j >= _dashLayout.length) return;
  [_dashLayout[i], _dashLayout[j]] = [_dashLayout[j], _dashLayout[i]];
  renderDashGrid();
}

function dashDragStart(i) { _dashDragIdx = i; }
function dashDragOver(e, i) { e.preventDefault(); }
function dashDrop(e, i) {
  e.preventDefault();
  if (_dashDragIdx === null || _dashDragIdx === i) return;
  const moved = _dashLayout.splice(_dashDragIdx, 1)[0];
  _dashLayout.splice(i, 0, moved);
  _dashDragIdx = null;
  renderDashGrid();
}

async function saveDashLayout() {
  try {
    await api('PATCH', `/api/v1/worker/me/dashboard/${S.businessId}`, { layout: _dashLayout });
    toast('Dashboard saved!');
    _dashEditMode = false;
    loadDashboard();
  } catch(e) { toast(e.message, 'danger'); }
}

// ── Widget Palette Helper ────────────────────────────────────────────────────

function renderWidgetPalette(elId, onAddFnName) {
  const el = document.getElementById(elId);
  if (!el) return;
  el.innerHTML = Object.entries(WIDGET_META).map(([type, meta]) => `
    <div class="col-auto">
      <button class="btn btn-sm btn-outline-secondary" onclick="${onAddFnName}('${type}')">
        <i class="bi ${meta.icon} me-1"></i>${meta.title}
      </button>
    </div>`).join('');
}

// ═══════════════════════════════════════════════════════════════════════════
// ██████████  DASHBOARD ADMIN (Tenant)  ████████████████████████████████████
// ═══════════════════════════════════════════════════════════════════════════

let _allTemplates = [];
let _editTplId = null;
let _editTplLayout = [];

async function loadDashboardAdmin() {
  if (!S.businessId) return;
  try {
    _allTemplates = await api('GET', `/api/v1/tenant/${S.businessId}/dashboard/templates`);
    renderTemplateList();
  } catch(e) { toast(e.message, 'danger'); }
  try {
    const members = await api('GET', `/api/v1/tenant/${S.businessId}/dashboard/members`);
    renderDashMembersTable(members);
  } catch(e) {}
}

function renderTemplateList() {
  const el = document.getElementById('tpl-list');
  if (!_allTemplates.length) {
    el.innerHTML = `<div class="text-muted small text-center py-3">No templates yet. Create one above.</div>`;
    return;
  }
  el.innerHTML = _allTemplates.map(t => `
    <div class="d-flex align-items-center p-2 rounded mb-2" style="background:rgba(255,255,255,.06)">
      <div class="flex-grow-1">
        <div class="fw-semibold small">${t.name}</div>
        <div class="text-muted" style="font-size:.72rem">${t.layout?.length||0} slots${t.is_default?' · <span class="text-success">default</span>':''}</div>
      </div>
      <div class="d-flex gap-1">
        <button class="btn btn-sm btn-outline-primary" onclick="editTemplate('${t.id}')"><i class="bi bi-pencil"></i></button>
        <button class="btn btn-sm btn-outline-danger" onclick="deleteTemplate('${t.id}')"><i class="bi bi-trash"></i></button>
      </div>
    </div>`).join('');
}

function renderDashMembersTable(members) {
  const tbody = document.getElementById('dash-members-table');
  if (!members.length) { tbody.innerHTML = `<tr><td colspan="5" class="text-muted text-center py-3">No active members</td></tr>`; return; }
  tbody.innerHTML = members.map(m => {
    const tplName = _allTemplates.find(t=>t.id===m.template_id)?.name || '(default)';
    return `<tr>
      <td class="small">${m.email || m.user_id.slice(0,8)}</td>
      <td><span class="badge bg-secondary">${tplName}</span></td>
      <td>${m.is_locked ? '<i class="bi bi-lock-fill text-warning"></i>' : '<i class="bi bi-unlock text-muted"></i>'}</td>
      <td>${m.has_custom_layout ? '<i class="bi bi-check text-success"></i>' : '—'}</td>
      <td><button class="btn btn-sm btn-outline-primary" onclick="openAssignDash('${m.membership_id}','${m.email||''}')"><i class="bi bi-sliders"></i></button></td>
    </tr>`;
  }).join('');
}

async function createTemplate() {
  const name = document.getElementById('tpl-name-input').value.trim();
  if (!name) return toast('Enter a template name', 'warning');
  const desc = document.getElementById('tpl-desc-input').value.trim();
  const is_default = document.getElementById('tpl-default-cb').checked;
  try {
    await api('POST', `/api/v1/tenant/${S.businessId}/dashboard/templates`, {
      name, description: desc, layout: [], is_default
    });
    toast('Template created!');
    closeModal('modal-new-template');
    await loadDashboardAdmin();
  } catch(e) { toast(e.message, 'danger'); }
}

async function deleteTemplate(id) {
  if (!confirm('Delete this template?')) return;
  try {
    await api('DELETE', `/api/v1/tenant/${S.businessId}/dashboard/templates/${id}`);
    toast('Deleted');
    loadDashboardAdmin();
  } catch(e) { toast(e.message, 'danger'); }
}

function editTemplate(id) {
  _editTplId = id;
  const tpl = _allTemplates.find(t=>t.id===id);
  _editTplLayout = JSON.parse(JSON.stringify(tpl?.layout || []));
  document.getElementById('tpl-editor-title').textContent = `Edit: ${tpl?.name}`;
  document.getElementById('tpl-editor').classList.remove('d-none');
  renderTplEditorGrid();
  renderWidgetPalette('tpl-widget-palette', 'addTplSlot');
  document.getElementById('tpl-editor').scrollIntoView({ behavior:'smooth' });
}

function closeTplEditor() {
  _editTplId = null;
  _editTplLayout = [];
  document.getElementById('tpl-editor').classList.add('d-none');
}

function renderTplEditorGrid() {
  const grid = document.getElementById('tpl-editor-grid');
  if (!_editTplLayout.length) {
    grid.innerHTML = `<div class="col-12 text-muted small text-center py-3">No slots yet — add widgets below</div>`;
    return;
  }
  grid.innerHTML = _editTplLayout.map((slot, i) => {
    const meta = WIDGET_META[slot.type] || { icon:'bi-grid', title: slot.title||slot.type };
    const wOpts = [3,4,6,8,12].map(v=>`<option value="${v}" ${slot.w==v?'selected':''}>${v} cols</option>`).join('');
    return `<div class="col-md-${slot.w||6}">
      <div class="card border-primary border-2 h-100">
        <div class="card-body p-2">
          <div class="d-flex align-items-center gap-2 mb-1">
            <i class="bi ${meta.icon} text-primary"></i>
            <span class="fw-semibold small flex-grow-1">${slot.title||meta.title}</span>
            <button class="btn btn-sm btn-outline-danger p-0 px-1" onclick="removeTplSlot(${i})"><i class="bi bi-x"></i></button>
          </div>
          <div class="d-flex align-items-center gap-2">
            <input class="form-control form-control-sm" value="${slot.title||meta.title}" oninput="_editTplLayout[${i}].title=this.value" style="font-size:.75rem">
            <select class="form-select form-select-sm" style="width:90px;font-size:.75rem" onchange="_editTplLayout[${i}].w=+this.value;renderTplEditorGrid()">${wOpts}</select>
          </div>
        </div>
      </div>
    </div>`;
  }).join('');
}

function addTplSlot(type) {
  const meta = WIDGET_META[type] || { title: type };
  _editTplLayout.push({ slot: crypto.randomUUID(), type, w: 6, title: meta.title, config: {} });
  renderTplEditorGrid();
}

function removeTplSlot(i) {
  _editTplLayout.splice(i, 1);
  renderTplEditorGrid();
}

async function saveTplLayout() {
  if (!_editTplId) return;
  const tpl = _allTemplates.find(t=>t.id===_editTplId);
  try {
    await api('PATCH', `/api/v1/tenant/${S.businessId}/dashboard/templates/${_editTplId}`, {
      name: tpl.name, description: tpl.description, layout: _editTplLayout, is_default: tpl.is_default
    });
    toast('Template saved!');
    closeTplEditor();
    loadDashboardAdmin();
  } catch(e) { toast(e.message,'danger'); }
}

function openAssignDash(mid, email) {
  document.getElementById('assign-mid').value = mid;
  document.getElementById('assign-member-label').textContent = email;
  const sel = document.getElementById('assign-tpl-sel');
  sel.innerHTML = `<option value="">— Use Default —</option>` +
    _allTemplates.map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  document.getElementById('assign-locked-cb').checked = false;
  document.getElementById('assign-reset-cb').checked = false;
  openModal('modal-assign-dash');
}

async function saveDashAssignment() {
  const mid = document.getElementById('assign-mid').value;
  const template_id = document.getElementById('assign-tpl-sel').value || null;
  const is_locked = document.getElementById('assign-locked-cb').checked;
  const reset_layout = document.getElementById('assign-reset-cb').checked;
  try {
    await api('POST', `/api/v1/tenant/${S.businessId}/dashboard/assign`, {
      membership_id: mid, template_id, is_locked, reset_layout
    });
    toast('Dashboard assigned!');
    closeModal('modal-assign-dash');
    loadDashboardAdmin();
  } catch(e) { toast(e.message,'danger'); }
}

// ═══════════════════════════════════════════════════════════════════════════
// ██████████  WIDGET EDITOR (Superadmin)  ██████████████████████████████████
// ═══════════════════════════════════════════════════════════════════════════

async function loadWidgetEditor() {
  try {
    const widgets = await api('GET', '/api/v1/control/widgets');
    const tbody = document.getElementById('widgets-table');
    if (!widgets.length) { tbody.innerHTML = `<tr><td colspan="7" class="text-muted text-center py-3">No widgets defined</td></tr>`; return; }
    tbody.innerHTML = widgets.map(w => `<tr>
      <td><i class="bi ${w.icon} fs-5 text-primary"></i></td>
      <td><code>${w.type}</code></td>
      <td>${w.title}</td>
      <td class="text-muted small">${w.description||'—'}</td>
      <td class="small">${w.business_id?'Tenant':'Global'}</td>
      <td>${w.is_system?'<span class="badge bg-info">system</span>':'<span class="badge bg-secondary">custom</span>'}</td>
      <td>
        <div class="d-flex gap-1">
          <button class="btn btn-sm btn-outline-primary" onclick="openEditWidget('${w.id}')"><i class="bi bi-pencil"></i></button>
          ${!w.is_system?`<button class="btn btn-sm btn-outline-danger" onclick="deleteWidget('${w.id}')"><i class="bi bi-trash"></i></button>`:''}
        </div>
      </td>
    </tr>`).join('');
  } catch(e) { toast(e.message,'danger'); }
}

function openEditWidget(id) {
  // Fetch and populate the modal
  api('GET', '/api/v1/control/widgets').then(widgets => {
    const w = widgets.find(x=>x.id===id);
    if (!w) return;
    document.getElementById('widget-edit-id').value = id;
    document.getElementById('widget-modal-title').textContent = 'Edit Widget';
    document.getElementById('widget-type-input').value = w.type;
    document.getElementById('widget-title-input').value = w.title;
    document.getElementById('widget-desc-input').value = w.description||'';
    document.getElementById('widget-icon-input').value = w.icon||'bi-grid';
    document.getElementById('widget-cfg-input').value = JSON.stringify(w.default_config||{}, null, 2);
    openModal('modal-new-widget');
  });
}

async function saveWidgetDef() {
  const id = document.getElementById('widget-edit-id').value;
  let cfg = {};
  try { cfg = JSON.parse(document.getElementById('widget-cfg-input').value); } catch(e) { toast('Invalid JSON in config','danger'); return; }
  const payload = {
    type: document.getElementById('widget-type-input').value.trim(),
    title: document.getElementById('widget-title-input').value.trim(),
    description: document.getElementById('widget-desc-input').value.trim(),
    icon: document.getElementById('widget-icon-input').value.trim()||'bi-grid',
    default_config: cfg,
  };
  try {
    if (id) {
      await api('PATCH', `/api/v1/control/widgets/${id}`, payload);
      toast('Widget updated!');
    } else {
      await api('POST', '/api/v1/control/widgets', payload);
      toast('Widget created!');
    }
    document.getElementById('widget-edit-id').value = '';
    document.getElementById('widget-modal-title').textContent = 'New Widget';
    closeModal('modal-new-widget');
    loadWidgetEditor();
  } catch(e) { toast(e.message,'danger'); }
}

async function deleteWidget(id) {
  if (!confirm('Delete this widget definition?')) return;
  try {
    await api('DELETE', `/api/v1/control/widgets/${id}`);
    toast('Deleted');
    loadWidgetEditor();
  } catch(e) { toast(e.message,'danger'); }
}

// ═══════════════════════════════════════════════════════════════════════════
// ██████████  PERMISSIONS MANAGER (Superadmin)  ████████████████████████████
// ═══════════════════════════════════════════════════════════════════════════

let _permsData = null;

async function loadPermissionsManager() {
  try {
    _permsData = await api('GET', '/api/v1/control/permissions-manager');
    renderPermsManager(_permsData.businesses);
  } catch(e) { toast(e.message,'danger'); }
}

function filterPermsManager() {
  if (!_permsData) return;
  const q = document.getElementById('perms-filter').value.toLowerCase();
  const filtered = _permsData.businesses.filter(b =>
    b.name.toLowerCase().includes(q) ||
    b.roles.some(r => r.permissions.some(p => p.toLowerCase().includes(q)))
  );
  renderPermsManager(filtered);
}

function renderPermsManager(businesses) {
  const el = document.getElementById('perms-manager-body');
  if (!businesses.length) { el.innerHTML = `<div class="text-muted text-center py-5">No businesses found</div>`; return; }
  const allPerms = _permsData?.all_permissions || [];
  el.innerHTML = businesses.map((biz, bi) => `
    <div class="accordion-item border-secondary mb-2 rounded" style="background:#1e1b4b">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#pm-biz-${bi}" style="background:#2d2a6e;border-radius:8px">
          <i class="bi bi-building me-2 text-primary"></i><span class="fw-semibold">${biz.name}</span>
          <span class="badge bg-secondary ms-2">${biz.plan}</span>
          <span class="badge ms-2" style="background:rgba(255,255,255,.12);color:#c7d2fe">${biz.roles.length} roles</span>
        </button>
      </h2>
      <div id="pm-biz-${bi}" class="accordion-collapse collapse">
        <div class="accordion-body p-3" style="background:#1e1b4b">
          ${biz.roles.map(role => `
            <div class="mb-4 p-3 rounded" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1)">
              <div class="d-flex align-items-center mb-3">
                <span class="fw-semibold text-white">${role.name}</span>
                ${role.is_system_template?'<span class="badge bg-info ms-2">system</span>':''}
                <button class="btn btn-sm btn-outline-primary ms-auto" onclick="saveRolePerms('${role.id}', this)">
                  <i class="bi bi-floppy me-1"></i>Save
                </button>
              </div>
              <div class="row g-1">
                ${allPerms.map(p => {
                  const checked = role.permissions.includes(p.key);
                  return `<div class="col-auto">
                    <div class="form-check form-check-inline m-0">
                      <input class="form-check-input rp-cb" type="checkbox" id="rp-${role.id}-${p.id}"
                        value="${p.key}" data-role="${role.id}" ${checked?'checked':''}>
                      <label class="form-check-label small text-light" for="rp-${role.id}-${p.id}" style="opacity:.9">${p.key}</label>
                    </div>
                  </div>`;
                }).join('')}
              </div>
            </div>
          `).join('')}
        </div>
      </div>
    </div>`).join('');
}

async function saveRolePerms(roleId, btn) {
  const checks = document.querySelectorAll(`.rp-cb[data-role="${roleId}"]`);
  const perms = Array.from(checks).filter(c=>c.checked).map(c=>c.value);
  try {
    btn.disabled = true;
    await api('POST', '/api/v1/control/permissions-manager/role-perms', { role_id: roleId, permissions: perms });
    toast('Permissions saved!');
  } catch(e) { toast(e.message,'danger'); }
  finally { btn.disabled = false; }
}

async function addGlobalPerm() {
  const key = document.getElementById('add-perm-key').value.trim();
  const desc = document.getElementById('add-perm-desc').value.trim();
  if (!key) return toast('Enter a permission key','warning');
  try {
    await api('POST', `/api/v1/control/permissions-manager/add-perm?key=${encodeURIComponent(key)}&description=${encodeURIComponent(desc)}`);
    toast(`Permission '${key}' added!`);
    closeModal('modal-add-perm');
    loadPermissionsManager();
  } catch(e) { toast(e.message,'danger'); }
}

</script>

<!-- ── Messaging FAB ───────────────────────────────────────────────────────── -->
<button id="msg-fab" onclick="toggleMsgPanel()" title="Messages" style="display:none">
  <i class="bi bi-chat-dots-fill"></i>
  <span id="msg-fab-badge" style="display:none"></span>
</button>

<!-- ── Messaging Slide-over Panel ────────────────────────────────────────── -->
<div id="msg-backdrop" onclick="closeMsgPanel()"></div>
<div id="msg-panel">
  <!-- Panel header -->
  <div class="d-flex align-items-center justify-content-between px-3 py-2" style="border-bottom:1px solid rgba(255,255,255,.12);background:rgba(0,0,0,.2);flex-shrink:0">
    <div class="d-flex align-items-center gap-2">
      <i class="bi bi-chat-dots-fill text-primary"></i>
      <span class="fw-semibold text-white">Messages</span>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <button class="btn btn-sm btn-outline-warning py-0 px-2" id="panel-broadcast-btn" onclick="msgBroadcast()" style="display:none;font-size:.75rem" title="Broadcast"><i class="bi bi-megaphone"></i></button>
      <button class="btn btn-sm btn-outline-secondary py-0 px-2" onclick="closeMsgPanel()" title="Close"><i class="bi bi-x-lg"></i></button>
    </div>
  </div>
  <!-- Body: same two-column layout -->
  <div class="d-flex flex-grow-1" style="overflow:hidden">
    <!-- Channel sidebar -->
    <div style="width:200px;flex-shrink:0;border-right:1px solid rgba(255,255,255,.1);display:flex;flex-direction:column">
      <div class="px-2 py-2 d-flex align-items-center justify-content-between" style="border-bottom:1px solid rgba(255,255,255,.08);flex-shrink:0">
        <span class="small text-muted fw-semibold" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.8px">Channels</span>
        <div class="d-flex gap-1">
          <button class="btn btn-xs py-0 px-1 btn-outline-secondary" style="font-size:.7rem" onclick="msgNewChannel()" id="panel-new-ch-btn" style="display:none" title="New Channel"><i class="bi bi-plus-circle"></i></button>
          <button class="btn btn-xs py-0 px-1 btn-outline-primary" style="font-size:.7rem" onclick="msgNewDm()" id="panel-dm-btn" style="display:none" title="DM"><i class="bi bi-person-plus"></i></button>
        </div>
      </div>
      <div id="panel-channel-list" style="flex:1;overflow-y:auto;padding:.4rem"></div>
    </div>
    <!-- Messages area -->
    <div style="flex:1;display:flex;flex-direction:column;overflow:hidden">
      <div id="panel-channel-header" class="px-3 py-2 d-flex align-items-center gap-2" style="border-bottom:1px solid rgba(255,255,255,.1);flex-shrink:0;min-height:44px">
        <span id="panel-channel-name" class="fw-semibold text-white small">Select a channel</span>
        <span id="panel-channel-type-badge" class="badge ms-1" style="font-size:.6rem"></span>
        <button class="btn btn-xs btn-outline-secondary ms-auto py-0 px-1" id="panel-members-btn" onclick="msgShowMembers()" style="display:none;font-size:.7rem" title="Members"><i class="bi bi-people"></i></button>
      </div>
      <div id="panel-message-list" style="flex:1;overflow-y:auto;padding:.75rem;display:flex;flex-direction:column;gap:.4rem">
        <div class="text-muted text-center small py-5">Select a channel to start messaging</div>
      </div>
      <div id="panel-input-area" style="padding:.6rem;border-top:1px solid rgba(255,255,255,.1);display:none;flex-shrink:0">
        <div class="d-flex gap-2">
          <input type="text" id="panel-msg-input" class="form-control form-control-sm bg-dark text-light border-secondary"
                 placeholder="Message… (Enter to send)"
                 onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();panelMsgSend();}">
          <button class="btn btn-sm btn-primary" onclick="panelMsgSend()"><i class="bi bi-send"></i></button>
        </div>
      </div>
    </div>
  </div>
</div>

</body>
</html>
